Add support for EB_GDK_PIXBUF_EXTRA_MODULES_FILES as a : seperated list of
extra loaders.cache files for Gdk Pixbuf plugins supplied via environment modules.

author: micketeer@gmail.com
--- gdk-pixbuf/gdk-pixbuf-io.c.orig	2026-06-01 17:21:15.744293318 +0200
+++ gdk-pixbuf/gdk-pixbuf-io.c	2026-06-01 17:25:30.583629915 +0200
@@ -700,6 +700,16 @@
 gdk_pixbuf_io_init (void)
 {
 #ifdef USE_GMODULE
+        const char *env = g_getenv ("EB_GDK_PIXBUF_EXTRA_MODULE_FILES");
+        if (env && *env) {
+                gchar **paths = g_strsplit (env, ":", -1);
+                for (gchar **p = paths; *p; p++) {
+                        if (**p)
+                                ret &= gdk_pixbuf_io_init_modules (*p, NULL);
+                }
+                g_strfreev (paths);
+        }
+
 	char *module_file;
 
 	module_file = gdk_pixbuf_get_module_file ();
