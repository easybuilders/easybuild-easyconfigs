easyblock = 'PythonBundle'

name = 'GEOUNED'
version = '1.6.2'

homepage = 'https://github.com/GEOUNED-org/GEOUNED'
description = """A tool to convert from CAD to CSG & CSG to CAD for Monte Carlo
 transport codes (OpenMC, Phits, Serpent, MCNP)."""

toolchain = {'name': 'intel', 'version': '2025b'}

dependencies = [
    ('Python', '3.13.5'),
    ('tqdm', '4.67.1'),
    ('FreeCAD', '1.1.0'),
]

use_pip = True

exts_download_dep_fail = True

exts_list = [
    ('geouned', version, {
        'checksums': ['61a409867597859a316c15de30ff4838827f96f13d2c5522cabe8ccce2e320ec'],
    }),
]

sanity_check_commands = ["geouned_cadtocsg --help"]

moduleclass = 'tools'
