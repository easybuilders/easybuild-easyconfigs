easyblock = 'ConfigureMake'

name = 'groff'
version = '1.24.1'

homepage = 'https://www.gnu.org/software/groff'
description = """Groff (GNU troff) is a typesetting system that reads plain text mixed with formatting commands
 and produces formatted output."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = [GNU_SOURCE]
sources = [SOURCE_TAR_GZ]
checksums = ['74e2819795b6aff431aeac983d63a9c8968eeaba2a2eba7df8ba4c7b41e7cfd8']

builddependencies = [
    ('binutils', '2.45'),
    ('M4', '1.4.20'),
    ('Perl', '5.42.0'),
]

configopts = '--with-gs=no --without-urw-fonts'

sanity_check_paths = {
    'files': ['bin/groff', 'bin/nroff', 'bin/troff'],
    'dirs': ['lib/groff', 'share'],
}

sanity_check_commands = ["groff --help"]

moduleclass = 'tools'
