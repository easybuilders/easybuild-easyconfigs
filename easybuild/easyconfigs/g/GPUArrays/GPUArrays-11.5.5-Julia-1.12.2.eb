easyblock = 'JuliaBundle'

name = 'GPUArrays'
version = '11.5.5'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/JuliaGPU/GPUArrays.jl'
description = """This package is the counterpart of Julia's AbstractArray interface, but for GPU array types:
It provides functionality and tooling to speed-up development of new GPU array types."""

toolchain = SYSTEM

builddependencies = [
    ('Aqua', '0.8.14', versionsuffix),
    ('ParallelTestRunner', '2.6.2', versionsuffix),
]

dependencies = [
    ('Julia', _julia_ver),
    ('Statistics', '1.11.1', versionsuffix),
    ('JLD2', '0.6.4', versionsuffix),
]

exts_list = [
    ('JLArrays', version, {
        'source_urls': ['https://github.com/JuliaGPU/GPUArrays.jl/archive/'],
