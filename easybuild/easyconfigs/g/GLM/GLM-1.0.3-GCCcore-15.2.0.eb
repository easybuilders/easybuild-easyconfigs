easyblock = 'CMakeMake'

name = 'GLM'
version = '1.0.3'

homepage = 'https://github.com/g-truc/glm'
description = """
OpenGL Mathematics (GLM) is a header only C++ mathematics library for graphics
software based on  the OpenGL Shading Language (GLSL) specifications."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/g-truc/glm/archive/']
sources = ['%(version)s.tar.gz']
checksums = ['6775e47231a446fd086d660ecc18bcd076531cfedd912fbd66e576b118607001']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

sanity_check_paths = {
    'files': [],
    'dirs': ['include/glm/gtc', 'include/glm/gtx'],
}

moduleclass = 'lib'
