# This easyconfig was created by Simon Branford of the BEAR Software team at the University of Birmingham.
easyblock = 'PythonBundle'

name = 'Globus-CLI'
version = '3.42.0'

homepage = "https://docs.globus.org/cli/"
description = """A Command Line Wrapper over the Globus SDK for Python, which provides an interface to Globus services
 from the shell, and is suited to both interactive and simple scripting use cases."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

builddependencies = [
    ('binutils', '2.44'),
]

dependencies = [
    ('Python', '3.13.5'),
    ('Python-bundle-PyPI', '2025.07'),
    ('cryptography', '45.0.5'),
]

exts_list = [
    ('click', '8.4.1', {
        'checksums': ['918b5633eddf6b41c32d4f454bf0de810065c74e3f7dbf8ee5452f8be88d3e96'],
    }),
    ('jmespath', '1.1.0', {
        'checksums': ['472c87d80f36026ae83c6ddd0f1d05d4e510134ed462851fd5f754c8c3cbb88d'],
    }),
    ('PyJWT', '2.10.1', {
        'modulename': 'jwt',
        'source_tmpl': '%(namelower)s-%(version)s.tar.gz',
        'checksums': ['3cc5772eb20009233caf06e9d8a0577824723b44e6648ee0a2aedb6cf9381953'],
    }),
    ('globus_sdk', '4.8.0', {
        'checksums': ['e54ea373aae39ef25fe0652c9e0d1dc9bcefacc65b08732baa0f8c09ea2910de'],
    }),
    ('globus_cli', version, {
        'checksums': ['6a694782963b4523ce5b0324f461c14a13e58025d7bea51ff5c95866e823872e'],
    }),
]

fix_python_shebang_for = ['bin/globus', 'bin/jp.py']

sanity_check_commands = ['globus --help']

moduleclass = 'data'
