easyblock = 'CMakeMake'

name = 'graphite2'
version = '1.3.15'

homepage = 'https://scripts.sil.org/cms/scripts/page.php?site_id=projects&item_id=graphite_home'
description = """Graphite is a "smart font" system developed specifically to
 handle the complexities of lesser-known languages of the world."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/silnrsi/graphite/archive/']
sources = ['%(version)s.zip']
checksums = ['8895a372862f89b8ee5d8325166464c35468439b7a036009ce990b33ee5dd408']

configopts = ' -DCMAKE_POLICY_VERSION_MINIMUM=3.5 '

builddependencies = [
    ('CMake', '4.2.1'),
    ('binutils', '2.45'),
]

sanity_check_paths = {
    'files': ['bin/gr2fonttest'] +
             [f'lib/lib%(name)s.{x}' for x in [SHLIB_EXT, 'la']],
    'dirs': ['include/%(name)s', 'share']
}

moduleclass = 'lib'
