easyblock = 'ConfigureMake'

name = 'gnuplot'
version = '6.0.1'

homepage = 'http://gnuplot.sourceforge.net'
description = """Portable interactive, function plotting utility"""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

source_urls = [('https://sourceforge.net/projects/%(name)s/files/%(name)s/%(version)s', 'download')]
sources = [SOURCE_TAR_GZ]
patches = ['gnuplot-6.0.x_fix-configure-iconv.patch']
checksums = [
    {'gnuplot-6.0.1.tar.gz': 'e85a660c1a2a1808ff24f7e69981ffcbac66a45c9dcf711b65610b26ea71379a'},
    {'gnuplot-6.0.x_fix-configure-iconv.patch': 'f8226bd5ad8aee7e13bc7a31c826be42c6e263eac1afe46c418ae05940728cec'},
]

builddependencies = [
    ('binutils', '2.40'),
    ('pkgconf', '2.0.3'),
    ('Autotools', '20220317'),
]

dependencies = [
    ('ncurses', '6.4'),
    ('cairo', '1.18.0'),
    ('libjpeg-turbo', '3.0.1'),
    ('libpng', '1.6.40'),
    ('libgd', '2.3.3'),
    ('Pango', '1.51.0'),
    ('libcerf', '2.4'),
    ('X11', '20231019'),
    ('Qt6', '6.6.3'),
    ('Lua', '5.4.6'),
    ('libiconv', '1.17'),
]

preconfigopts = 'autoreconf && '

# make sure that right Lua library is used (bypassing pkg-config)
preconfigopts += 'export LUA_CFLAGS="-I$EBROOTLUA/include" && export LUA_LIBS="$EBROOTLUA/lib/liblua.a" && '

# avoid that -L options get omitted that specify correct path for libraries being linked,
# setting $PKG_CONFIG_ALLOW_SYSTEM_LIBS is equivalent to making pkgconf use --keep-system-libs
preconfigopts += 'export PKG_CONFIG_ALLOW_SYSTEM_LIBS=1 && '

configopts = '--with-qt=qt6 --without-latex --disable-wxwidgets'

sanity_check_paths = {
    'files': ['bin/gnuplot'],
    'dirs': []
}
# make sure that pdf terminal type is available
sanity_check_commands = ["gnuplot -e 'set terminal pdf'"]

moduleclass = 'vis'
