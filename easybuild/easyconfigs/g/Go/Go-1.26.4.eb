easyblock = 'Tarball'

name = 'Go'
version = '1.26.4'

homepage = 'https://www.golang.org'
description = """Go is an open source programming language that makes it easy to build
 simple, reliable, and efficient software."""

toolchain = SYSTEM

source_urls = ['https://go.dev/dl/']
local_archs = {'aarch64': 'arm64', 'x86_64': 'amd64'}
sources = ['go%%(version)s.linux-%s.tar.gz' % local_archs[ARCH]]
# note: checksums can be found at https://go.dev/dl/?mode=json
checksums = [{
    'go%(version)s.linux-amd64.tar.gz': '1153d3d50e0ac764b447adfe05c2bcf08e889d42a02e0fe0259bd47f6733ad7f',
    'go%(version)s.linux-arm64.tar.gz': 'ef758ae7c6cf9267c9c0ef080b8965f453d89ab2d25d9eb22de4405925238768',
}]

sanity_check_paths = {
    'files': ['bin/go', 'bin/gofmt'],
    'dirs': ['api', 'doc', 'lib', 'pkg'],
}

sanity_check_commands = ["go help"]

modextravars = {'GOROOT': '%(installdir)s'}

moduleclass = 'compiler'
