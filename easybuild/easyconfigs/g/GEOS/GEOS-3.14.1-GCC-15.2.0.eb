easyblock = 'CMakeMake'

name = 'GEOS'
version = '3.14.1'

homepage = 'https://trac.osgeo.org/geos'
description = """GEOS (Geometry Engine - Open Source) is a C++ port of the Java Topology Suite (JTS)"""

toolchain = {'name': 'GCC', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://download.osgeo.org/geos/']
sources = [SOURCELOWER_TAR_BZ2]
checksums = ['3c20919cda9a505db07b5216baa980bacdaa0702da715b43f176fb07eff7e716']

builddependencies = [('CMake', '4.2.1')]

# Build static and shared libraries
configopts = ['', '-DBUILD_SHARED_LIBS=OFF']

sanity_check_paths = {
    'files': ['bin/geos-config', f'lib/libgeos.{SHLIB_EXT}', 'lib/libgeos.a', f'lib/libgeos_c.{SHLIB_EXT}',
              'include/geos.h'],
    'dirs': [],
}

moduleclass = 'math'
