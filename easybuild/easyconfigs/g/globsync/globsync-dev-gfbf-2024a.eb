easyblock = 'PythonPackage'

name = 'globsync'
version = 'dev'
homepage = 'https://gitlab.kuleuven.be/ees/rdm/globsync'
description = 'Python package globsync provides a lightweight tool to monitor and manage backups of directories using Globus as backend.'

