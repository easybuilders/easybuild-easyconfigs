easyblock = 'CMakeMake'

name = 'googlebenchmark'
version = '1.9.5'

homepage = 'https://github.com/google/benchmark'
description = "Google's framework for writing C++ tests on a variety of platforms"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/google/benchmark/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
checksums = ['9631341c82bac4a288bef951f8b26b41f69021794184ece969f8473977eaa340']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
    ('googletest', '1.17.0'),
]

# Disable assembly tests as highly OS and compiler dependent.
# See https://github.com/google/benchmark/issues/1326#issuecomment-1015221235
configopts = ['-DBENCHMARK_DOWNLOAD_DEPENDENCIES=OFF '
              '-DBENCHMARK_USE_BUNDLED_GTEST=OFF '
              '-DBENCHMARK_ENABLE_ASSEMBLY_TESTS=OFF ']
build_shared_libs = False  # Shared build doesn't work properly with GTest on e.g. PPC

runtest = True

sanity_check_paths = {
    'files': ['lib/libbenchmark.a'],
    'dirs': ['include/benchmark', 'lib/cmake', 'lib/pkgconfig'],
}

moduleclass = 'tools'
