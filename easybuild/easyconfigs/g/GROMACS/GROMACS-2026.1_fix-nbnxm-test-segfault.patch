Patch downloaded from https://gitlab.com/gromacs/gromacs/-/work_items/5619
and disabled the diff for the 2026.2 release notes file, since it's not part of 2026.1.

From 8d6da0ac6ea6c8fe5b24fdb8215ba40fc0b0f6e4 Mon Sep 17 00:00:00 2001
From: Andrey Alekseenko <al42and@gmail.com>
Date: Fri, 1 May 2026 22:30:45 +0200
Subject: [PATCH 1/2] Fix segfault in CpuListDiagonalExclusionsTest when
 OMP_NUM_THREADS>1

The test was calling gmx_omp_nthreads_init() which respects the
OMP_NUM_THREADS environment variable.
However, GridSet was constructed with hardcoded numThreads=1, giving
gridWork_ only 1 element.

Fixes #5619
---
 docs/release-notes/2026/2026.2.rst     |  9 +++++++++
 src/gromacs/nbnxm/tests/exclusions.cpp | 19 +++++++++++++------
 2 files changed, 22 insertions(+), 6 deletions(-)

#diff --git a/docs/release-notes/2026/2026.2.rst b/docs/release-notes/2026/2026.2.rst
#index bac378ab89..37b2a08d56 100644
#--- a/docs/release-notes/2026/2026.2.rst
#+++ b/docs/release-notes/2026/2026.2.rst
#@@ -122,3 +122,12 @@ Cray MPICH 9 with ROCm was affected.
# 
# Miscellaneous
# ^^^^^^^^^^^^^
#+
#+Fix test failure with OMP_NUM_THREADS set
#+"""""""""""""""""""""""""""""""""""""""""
#+
#+Fix test failure in NbnxmTests when ``OMP_NUM_THREADS`` was set
#+to a value larger than 1.
#+
#+:issue:`5619`
#+
diff --git a/src/gromacs/nbnxm/tests/exclusions.cpp b/src/gromacs/nbnxm/tests/exclusions.cpp
index 383a7f59b3..3e7745d7af 100644
--- a/src/gromacs/nbnxm/tests/exclusions.cpp
+++ b/src/gromacs/nbnxm/tests/exclusions.cpp
@@ -72,7 +72,6 @@
 #include "gromacs/utility/enumerationhelpers.h"
 #include "gromacs/utility/listoflists.h"
 #include "gromacs/utility/logger.h"
-#include "gromacs/utility/mpicomm.h"
 #include "gromacs/utility/range.h"
 #include "gromacs/utility/real.h"
 #include "gromacs/utility/vec.h"
@@ -101,14 +100,22 @@ diagonalPairlist(const NbnxmKernelType kernelType, const int numAtoms)
 {
     const gmx::MDLogger emptyLogger;
 
-    MpiComm mpiComm(MpiComm::SingleRank{});
-
-    gmx_omp_nthreads_init(emptyLogger, mpiComm, false, 1, 1, 1, 1, false);
+    // Force single-thread execution
+    constexpr int sc_numThreads = 1;
+    gmx_omp_nthreads_set(ModuleMultiThread::Pairsearch, sc_numThreads);
+    gmx_omp_nthreads_set(ModuleMultiThread::Nonbonded, sc_numThreads);
 
     const PairlistParams pairlistParams(kernelType, {}, false, 1, false);
 
-    GridSet gridSet(
-            PbcType::Xyz, false, nullptr, nullptr, pairlistParams.pairlistType, false, false, 1, PinningPolicy::CannotBePinned);
+    GridSet gridSet(PbcType::Xyz,
+                    false,
+                    nullptr,
+                    nullptr,
+                    pairlistParams.pairlistType,
+                    false,
+                    false,
+                    sc_numThreads,
+                    PinningPolicy::CannotBePinned);
 
     std::vector<real> nbfp{ 0.0_real, 0.0_real };
 
-- 
GitLab


From 802f4eb0534916bf6194fbb74dc170fe07d30e3d Mon Sep 17 00:00:00 2001
From: Andrey Alekseenko <al42and@gmail.com>
Date: Fri, 1 May 2026 22:55:10 +0200
Subject: [PATCH 2/2] Make sc static

---
 src/gromacs/nbnxm/tests/exclusions.cpp | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/gromacs/nbnxm/tests/exclusions.cpp b/src/gromacs/nbnxm/tests/exclusions.cpp
index 3e7745d7af..beb52447cc 100644
--- a/src/gromacs/nbnxm/tests/exclusions.cpp
+++ b/src/gromacs/nbnxm/tests/exclusions.cpp
@@ -101,7 +101,7 @@ diagonalPairlist(const NbnxmKernelType kernelType, const int numAtoms)
     const gmx::MDLogger emptyLogger;
 
     // Force single-thread execution
-    constexpr int sc_numThreads = 1;
+    static constexpr int sc_numThreads = 1;
     gmx_omp_nthreads_set(ModuleMultiThread::Pairsearch, sc_numThreads);
     gmx_omp_nthreads_set(ModuleMultiThread::Nonbonded, sc_numThreads);
 
