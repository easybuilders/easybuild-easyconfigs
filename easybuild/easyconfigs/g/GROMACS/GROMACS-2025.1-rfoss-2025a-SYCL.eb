# Author:   Aayush Joglekar <aayush.joglekar@surf.nl>

# TODO: Replace with EB_GROMACS
easyblock = 'CMakeMake'

name = 'GROMACS'
version = '2025.1'
versionsuffix = '-SYCL'
_rocm_version = '6.4.1'

homepage = 'https://www.gromacs.org'
description = """GROMACS is a versatile package to perform molecular dynamics, i.e. simulate the
Newtonian equations of motion for systems with hundreds to millions of particles."""

toolchain = {'name': 'rfoss', 'version': '2025a'}
toolchainopts = {'openmp': True, 'usempi': True}

source_urls = ['https://ftp.gromacs.org/pub/gromacs/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['0adf621a80fd8043f8defec84ce02811c0cdf42a052232890932d81f25c4d28a']

builddependencies = [
    ('CMake', '3.31.3'),
]

dependencies = [
    ('AdaptiveCpp', '25.10.0'),
    ('HIP', _rocm_version),
    ('hwloc', '2.11.2'),
]

# 1. Compilers explicitly set to your custom LLVM
configopts = "-DCMAKE_C_COMPILER=$EBROOTROCMMINLLVM/bin/clang "
configopts += "-DCMAKE_CXX_COMPILER=$EBROOTROCMMINLLVM/bin/clang++ "

# 2. The Golden Ticket: Paths + Header overrides (This is what made your standalone test work!)
configopts += "-DCMAKE_CXX_FLAGS='--rocm-path=$EBROOTROCMMINLLVM --rocm-device-lib-path=$EBROOTROCMMINLLVM/amdgcn/bitcode -D__HIP_PLATFORM_AMD__=1 -I$EBROOTHIP/include -include hip/hip_runtime.h' "

# 3. SYCL and Target Architecture
configopts += "-DGMX_GPU=SYCL "
configopts += "-DGMX_SYCL=ACPP "
configopts += "-DACPP_TARGETS='hip:%(amdgcn_cc_semicolon_sep)s' "

# 4. HPC Paths and Features
configopts += "-DAdaptiveCpp_DIR=$EBROOTADAPTIVECPP/lib/cmake/AdaptiveCpp "
configopts += "-DGMX_MPI=ON "
configopts += "-DGMX_THREAD_MPI=OFF "
configopts += "-DGMX_OPENMP=ON "
configopts += "-DGMX_HWLOC=ON "

sanity_check_paths = {
    'dirs': ['bin', 'share/gromacs'],
    'files': ['bin/gmx_mpi'],
}

moduleclass = 'bio'
