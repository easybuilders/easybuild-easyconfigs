easyblock = 'PythonPackage'

name = 'gmpy2'
version = '2.3.0'

homepage = 'https://github.com/aleaxit/gmpy'
description = "GMP/MPIR, MPFR, and MPC interface to Python 2.6+ and 3.x"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['2d943cc9051fcd6b15b2a09369e2f7e18c526bc04c210782e4da61b62495eb4a']

builddependencies = [
    ('binutils', '2.45')
]

dependencies = [
    ('Python', '3.14.2'),
    ('GMP', '6.3.0'),
    ('MPFR', '4.2.2'),
    ('MPC', '1.4.1'),
]

moduleclass = 'math'
