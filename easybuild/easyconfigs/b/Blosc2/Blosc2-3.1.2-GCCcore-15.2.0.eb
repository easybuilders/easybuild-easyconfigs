easyblock = 'CMakeMake'

name = 'Blosc2'
version = '3.1.2'

homepage = 'https://www.blosc.org/'

description = "Blosc, an extremely fast, multi-threaded, meta-compressor library"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/Blosc/c-blosc2/archive/']
sources = [{'download_filename': 'v%(version)s.tar.gz', 'filename': SOURCE_TAR_GZ}]
checksums = ['b4fbad51de56abf2f4660bd1cb9801bc044662db3ea009ede454b4fd36fd98eb']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

sanity_check_paths = {
    'files': ['include/blosc2/blosc2-export.h', 'include/blosc2.h', 'lib/libblosc2.a',
              'lib/libblosc2.%s' % SHLIB_EXT],
    'dirs': [],
}

moduleclass = 'lib'
