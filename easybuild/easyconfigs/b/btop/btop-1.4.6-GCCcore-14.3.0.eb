easyblock = 'CMakeMake'

name = 'btop'
version = "1.4.6"

homepage = 'https://github.com/aristocratos/btop'

description = """Resource monitor that shows usage and stats for processor, memory, disks, network and processes."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

github_account = 'aristocratos'
source_urls = [GITHUB_SOURCE]
sources = ['v%(version)s.tar.gz']
patches = ['%(name)s-%(version)s_fix-intel-gpu-missing-def.patch']
checksums = [
    {'v1.4.6.tar.gz': '4beb90172c6acaac08c1b4a5112fb616772e214a7ef992bcbd461453295a58be'},
    {'btop-1.4.6_fix-intel-gpu-missing-def.patch': '9f9e26c9151d90606115ee8f741c39ac9050ef319c9f48fac71ddb37e21f2a75'},
]

preconfigopts = 'LDFLAGS="$LDFLAGS -ldl" '

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
]

sanity_check_paths = {
    'files': ['bin/btop'],
    'dirs': ['share'],
}

sanity_check_commands = ["btop --help"]

moduleclass = 'tools'
