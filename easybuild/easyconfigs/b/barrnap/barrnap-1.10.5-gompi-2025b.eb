easyblock = 'Tarball'

name = 'barrnap'
version = '1.10.5'

homepage = 'https://github.com/tseemann/barrnap'
description = "Barrnap (BAsic Rapid Ribosomal RNA Predictor) predicts the location of ribosomal RNA genes in genomes."

toolchain = {'name': 'gompi', 'version': '2025b'}

source_urls = ['https://github.com/tseemann/barrnap/archive/']
sources = [V_VERSION_TAR_GZ]
checksums = ['37f1451b1c3521f3495fde0d6483e97600bd6f4a7ce625db11a78cbd06a68b19']

dependencies = [
    ('Perl', '5.40.2'),
    ('HMMER', '3.4'),
    ('BEDTools', '2.31.1'),
]

sanity_check_paths = {
    'files': ['bin/barrnap'],
    'dirs': [],
}

sanity_check_commands = ["barrnap --help"]

moduleclass = 'bio'
