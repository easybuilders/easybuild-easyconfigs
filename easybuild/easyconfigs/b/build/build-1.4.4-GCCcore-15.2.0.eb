easyblock = 'PythonBundle'

name = 'build'
version = '1.4.4'

homepage = 'https://github.com/pypa/build'
description = """A simple, correct Python build frontend."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [('binutils', '2.45')]
dependencies = [('Python', '3.14.2')]

exts_list = [
    ('pyproject_hooks', '1.2.0', {
        'checksums': ['1e859bd5c40fae9448642dd871adf459e5e2084186e8d2c2a79a824c970da1f8'],
    }),
    (name, version, {
        'checksums': ['f832ae053061f3fb524af812dc94b8b84bac6880cd587630e3b5d91a6a9c1703'],
    }),
]

sanity_check_commands = ["python3 -m build -V"]

moduleclass = 'devel'
