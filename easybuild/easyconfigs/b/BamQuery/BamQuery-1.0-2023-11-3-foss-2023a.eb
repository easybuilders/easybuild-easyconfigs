easyblock = 'PythonBundle'

name = 'BamQuery'
version = '1.0-2023-11-3'
local_commit = '430414f'

homepage = 'https://github.com/lemieux-lab/BamQuery'
description = """BamQuery provides RNA-seq quantification for a given peptide (from 8 to 11 residues)
in chosen RNA-seq samples (single or bulk)."""

toolchain = {'name': 'foss', 'version': '2023a'}

dependencies = [
    ('Python', '3.11.3'),
    ('SciPy-bundle', '2023.07'),
    ('R', '4.3.2'),
    ('R-bundle-CRAN', '2023.12'),
    ('BEDTools', '2.31.0'),
    ('STAR', '2.7.11a'),
    ('Pysam', '0.22.0'),
    ('matplotlib', '3.7.2'),
    ('Seaborn', '0.13.2'),
    ('XlsxWriter', '3.1.3'),
    ('Biopython', '1.83'),
    ('dill', '0.3.7'),
    ('multiprocess', '0.70.15'),
    ('openpyxl', '3.1.2'),
]

components = [
    (name, version, {
        'easyblock': 'Tarball',
        'sources': [{
            'source_urls': ['https://github.com/lemieux-lab/BamQuery/archive'],
            'download_filename': f'{local_commit}.tar.gz',
            'filename': f'%(name)s-%(version)s-{local_commit}.tar.gz',
            'extract_cmd': (
                'mkdir -p %(builddir)s/%(name)s && tar -xzf %s --strip-components=1 -C %(builddir)s/%(name)s'
            )
        }],
        'patches': ['BamQuery-1.0_fix-lib-path.patch'],
        'checksums': [
            {'BamQuery-1.0-2023-11-3-430414f.tar.gz':
             '02eff4c8a6ba80316282724f6f1658db331a5eeb24e527e7fe82d4ba16fbd240'},
            {'BamQuery-1.0_fix-lib-path.patch': '035cb5c7357bba1330f8c9189c970ea428b2f6ffc5df0c5e82ce92edf9433b2b'},
        ],
    }),
]

exts_list = [
    ('ppft', '1.7.6.9', {
        'checksums': ['73161c67474ea9d81d04bcdad166d399cff3f084d5d2dc21ebdd46c075bbc265'],
    }),
    ('pox', '0.3.5', {
        'checksums': ['8120ee4c94e950e6e0483e050a4f0e56076e590ba0a9add19524c254bd23c2d1'],
    }),
    ('billiard', '4.2.0', {
        'checksums': ['9a3c3184cb275aa17a732f93f65b20c525d3d9f253722d26a82194803ade5a2c'],
    }),
    ('pathos', '0.3.1', {
        'checksums': ['c9a088021493c5cb627d4459bba6c0533c684199e271a5dc297d62be23d74019'],
    }),
]

postinstallcmds = [
    # create bamquery executable from BamQuery.py script
    'mkdir -p %(installdir)s/bin',
    'echo "#!/usr/bin/env bash" > %(installdir)s/bin/bamquery',
    """echo 'exec python "$EBROOTBAMQUERY/BamQuery/BamQuery.py" "$@"' >> %(installdir)s/bin/bamquery""",
    'chmod 755 %(installdir)s/bin/bamquery',
    # create lib dir structure in user's $HOME
    "mkdir -p $HOME/BamQuery/lib/genome_versions",
    "mkdir -p $HOME/BamQuery/lib/snps",
]

sanity_check_paths = {
    'files': ['bin/bamquery'],
    'dirs': ['lib/python%(pyshortver)s/site-packages', '%(name)s'],
}

sanity_check_commands = ['bamquery --help']

modextravars = {'BAMQUERY_LIB': '$HOME/BamQuery/lib'}

modloadmsg = """
Run BamQuery via:
  bamquery
rather than:
  python BamQuery.py
Launch the analysis:
  bamquery path_to_input_folder name_exp genome_version

BamQuery needs external library data after module load.

Default location:
  $HOME/BamQuery/lib
This module sets:
  BAMQUERY_LIB=$HOME/BamQuery/lib

Download and extract the main library bundle:
  wget https://bamquery.iric.ca/download/lib_essentials.tar.gz
  tar -xzf lib_essentials.tar.gz --strip-components=2 -C $HOME/BamQuery/lib

Download any additional genome/dbSNP archives from:
  https://bamquery.iric.ca/download/

Place them in:
  $BAMQUERY_LIB/genome_versions/
  $BAMQUERY_LIB/snps/

You may override the location with:
  export BAMQUERY_LIB=/path/to/BamQuery/lib

The directory structure under BAMQUERY_LIB must remain compatible with the standard BamQuery lib layout.
"""

moduleclass = 'bio'
