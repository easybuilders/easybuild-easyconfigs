# This file is an EasyBuild reciPY as per https://github.com/easybuilders/easybuild
#
# Author: Jonas Demeulemeester
# The Francis Crick Insitute, London, UK
# Updated to 1.21 jpecar / EMBL
# Updated to 1.23.1 Franky Backeljauw / Universiteit Antwerpen

easyblock = 'ConfigureMake'

name = 'BCFtools'
version = '1.23.1'

homepage = 'https://www.htslib.org/'
description = """Samtools is a suite of programs for interacting with high-throughput sequencing data.
 BCFtools - Reading/writing BCF2/VCF/gVCF files and calling/filtering/summarising SNP and short indel sequence
 variants"""

toolchain = {'name': 'GCC', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/samtools/%(namelower)s/releases/download/%(version)s']
sources = [SOURCELOWER_TAR_BZ2]
checksums = ['01899a46f9420cdc1385d52fcfc84cce2806f9c996b787081a90d7dfc85eafa3']

dependencies = [
    ('zlib', '2.3.2'),
    ('HTSlib', '1.23.1'),
    ('bzip2', '1.0.8'),
    ('XZ', '5.8.2'),
    ('GSL', '2.8'),
]

configopts = "--with-htslib=$EBROOTHTSLIB --enable-libgsl"


sanity_check_paths = {
    'files': ['bin/%(namelower)s', 'bin/plot-vcfstats', 'bin/vcfutils.pl'],
    'dirs': ['libexec/%(namelower)s'],
}

moduleclass = 'bio'
