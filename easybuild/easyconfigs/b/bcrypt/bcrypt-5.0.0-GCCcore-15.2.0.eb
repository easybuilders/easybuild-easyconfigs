easyblock = 'CargoPythonPackage'

name = 'bcrypt'
version = '5.0.0'

homepage = 'https://github.com/pyca/bcrypt/'
description = """Acceptable password hashing for your software and your servers (but you should
really use argon2id or scrypt)
"""

