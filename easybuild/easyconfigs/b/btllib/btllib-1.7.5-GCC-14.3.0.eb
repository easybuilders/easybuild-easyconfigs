easyblock = 'CmdCp'

name = 'btllib'
version = '1.7.5'

homepage = 'https://github.com/bcgsc/btllib'
description = "Bioinformatics Technology Lab common code library"

toolchain = {'name': 'GCC', 'version': '14.3.0'}
toolchainopts = {'openmp': True}

source_urls = ['https://github.com/bcgsc/%(name)s/releases/download/v%(version)s']
sources = [SOURCE_TAR_GZ]
checksums = ['118a9f8d6445a618178bfbec40d121bbe03014e767261522148f642686090c76']

dependencies = [
    ('Python', '3.13.5'),
    ('Meson', '1.8.2'),
    ('Ninja', '1.13.0'),
    ('CMake', '3.31.8'),
    ('SAMtools', '1.22.1'),
]

files_to_copy = [
    (['install/bin/*'], 'bin'),
    (['install/lib/*'], 'lib'),
    (['install/include/*'], 'include'),
]
cmds_map = [('.*', './compile')]

sanity_check_paths = {
    'files': ['bin/randseq', 'bin/indexlr', 'bin/mi_bf_generate'],
    'dirs': [],
}

sanity_check_commands = [
    "randseq --help",
    "indexlr --help",
]

moduleclass = 'lang'
