easyblock = 'CMakeMake'

name = 'nghttp2'
version = '1.69.0'

homepage = 'https://github.com/nghttp2/nghttp2'
description = """
This is an implementation of the Hypertext Transfer Protocol version 2 in C.

The framing layer of HTTP/2 is implemented as a reusable C library.
On top of that, we have implemented an HTTP/2 client, server and proxy.
We have also developed load test and benchmarking tools for HTTP/2.

An HPACK encoder and decoder are available as a public API."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

github_account = 'nghttp2'
source_urls = [GITHUB_RELEASE]
sources = [SOURCE_TAR_XZ]
checksums = ['1fb324b6ec2c56f6bde0658f4139ffd8209fa9e77ce98fd7a5f63af8d0e508ad']

builddependencies = [
    ('binutils', '2.45'),
    ('pkgconf', '2.5.1'),
    ('CMake', '4.2.1'),
    ('CUnit', '2.1-3'),
    ('Boost', '1.90.0'),
]

dependencies = [
    ('OpenSSL', '3', '', SYSTEM),
    ('nghttp3', '1.16.0'),
    ('Python', '3.14.2'),
    ('libxml2', '2.15.1'),
    ('Jansson', '2.15.0'),
    ('jemalloc', '5.3.1'),
    ('ngtcp2', '1.23.0'),
    ('libevent', '2.1.12'),
    ('libev', '4.33'),
    ('c-ares', '1.34.6'),
]

runtest = 'check'

sanity_check_paths = {
    'files': [f'lib/libnghttp2.{SHLIB_EXT}'],
    'dirs': ['include/nghttp2', 'share'],
}

moduleclass = 'lib'
