# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2024

easyblock = 'PythonPackage'

name = 'nctoolkit'
version = '1.1.7'

homepage = 'https://github.com/pmlmodelling/nctoolkit'
description = """nctoolkit is a comprehensive Python (3.8 and above) package for analyzing netCDF
 data on Linux and macOS."""

toolchain = {'name': 'foss', 'version': '2023b'}

sources = [SOURCE_TAR_GZ]
checksums = ['579b1446f005a13052d0cc830db22409342c6e19765ed12203e24bf40e728c56']

builddependencies = [
    ('binutils', '2.40'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('CDO', '2.2.2'),
    ('netcdf4-python', '1.7.1.post2'),
    ('xarray', '2024.5.0'),
    ('matplotlib', '3.8.2'),
    ('dill', '0.3.8'),
    ('multiprocess', '0.70.16'),
    ('panel', '1.3.8'),
    ('hvplot', '0.9.2'),
    ('ncplot', '0.3.9'),
]

moduleclass = 'tools'
