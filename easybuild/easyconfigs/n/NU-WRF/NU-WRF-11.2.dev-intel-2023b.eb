name = 'NU-WRF'
version = '11.2.dev'

homepage = 'https://astg.pages.smce.nasa.gov/nu-wrf/nu-wrf-dev/index.html'
description = """NU-WRF has been developed at Goddard Space Flight Center (GSFC) as an observation-driven integrated modeling system representing aerosol, cloud, precipitation, and land processes at satellite-resolved scales. NU-WRF is intended as a superset of the standard NCAR Advanced Research WRF."""

# easyblock = 'ConfigureMake'

toolchain = {'name': 'intel', 'version': '2023b'}
toolchainopts = {'opt': False}  # don't use agressive optimization, stick to -O2

install_src = '.'
# sources = [{
#     'filename': '/data/leuven/314/vsc31497/software/src/RSDA/LISF/dev/lis',
#     'extract_cmd': "ln -s %s"
# }]

# builddependencies = [
#     ('Python', '3.11.5'),
#     ('Perl', '5.38.0'),
# ]

dependencies = [
    ("HDF5", "1.14.3"),
    ("netCDF", "4.9.2"),
    ("ecCodes", "2.31.0"),
    ("ESMF", "8.6.1")
]

preconfigopts = "export LIS_ARCH=linux_ifc && export LIS_FC=mpiifx && export LIS_CC=mpiicx && LIS_MODESMF=$EBROOTESMF/mod && LIS_LIBESMF=$EBROOTESMF/lib && LIS_JASPER=$EBROOTJASPER && LIS_ECCODES=$EBROOTECCODES && LIS_NETCDF=$EBROOTNETCDF && LIS_HDF5=$EBROOTHDF5 &&"

# runtest = True

# limit parallel build to 20
maxparallel = 20

moduleclass = 'geo'