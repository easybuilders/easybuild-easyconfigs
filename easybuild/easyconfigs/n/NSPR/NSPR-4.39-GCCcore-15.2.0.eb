easyblock = 'ConfigureMake'

name = 'NSPR'
version = '4.39'

homepage = 'https://developer.mozilla.org/en-US/docs/Mozilla/Projects/NSPR'
description = """Netscape Portable Runtime (NSPR) provides a platform-neutral API for system level
 and libc-like functions."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://ftp.mozilla.org/pub/%(namelower)s/releases/v%(version)s/src/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['bbd02ee87a55676063a63e5bc819e0227de2666b47307b2a0134414cdf42368e']

builddependencies = [
    ('binutils', '2.45'),
]

configopts = "--disable-debug --enable-optimize --enable-64bit"


sanity_check_paths = {
    'files': ['bin/nspr-config', 'lib/libnspr%(version_major)s.a', f'lib/libnspr%(version_major)s.{SHLIB_EXT}',
              'lib/libplc%(version_major)s.a', f'lib/libplc%(version_major)s.{SHLIB_EXT}',
              'lib/libplds%(version_major)s.a', f'lib/libplds%(version_major)s.{SHLIB_EXT}',
              'lib/pkgconfig/%(namelower)s.pc'],
    'dirs': ['include/%(namelower)s'],
}

sanity_check_commands = ['%(namelower)s-config --version']

moduleclass = 'lib'
