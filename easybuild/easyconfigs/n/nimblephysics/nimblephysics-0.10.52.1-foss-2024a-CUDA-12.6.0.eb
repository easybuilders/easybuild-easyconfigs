easyblock = 'PythonPackage'

name = 'nimblephysics'
version = '0.10.52.1'
versionsuffix = '-CUDA-12.6.0'

homepage = 'https://nimblephysics.org/'
description = """Nimble Physics is a differentiable, fully featured physics engine with PyTorch bindings."""

toolchain = {'name': 'foss', 'version': '2024a'}

sources = [
    '%(name)s-%(version)s-cp312-cp312-manylinux_2_27_%(arch)s.manylinux_2_28_%(arch)s.whl',
]
checksums = ['afeaf4741fa545dbb13b22f092cb47eb96b3ef66e4132e5819673aab19bf8e17']

dependencies = [
    ('Python', '3.12.3'),
    ('PyTorch', '2.7.1', versionsuffix),
    ('SciPy-bundle', '2024.05'),
]

moduleclass = 'phys'
