# Author: Anibal Moreno
easyblock = 'Tarball'

name = 'nf-test'
version = '0.9.4'
versionsuffix = '-Java-%(javaver)s'

homepage = 'https://github.com/askimed/nf-test'
description = "Simple test framework for Nextflow pipelines"

toolchain = SYSTEM

source_urls = ['https://github.com/askimed/%(name)s/releases/download/v%(version)s']
sources = ['%(name)s-%(version)s.tar.gz']
checksums = ['03d93c1d520fa9b7c764aa92636c2a3a182f67d6926f72b849da0b3b2a41da3f']

dependencies = [
    ('Java', '21', '', SYSTEM),
]

postinstallcmds = [
    "mkdir -p %(installdir)s/bin",
    "mv %(builddir)s/nf-test %(installdir)s/bin/",
    "mv %(builddir)s/nf-test.jar %(installdir)s/bin/",
]

sanity_check_paths = {
    'files': ['bin/%(name)s', 'bin/%(name)s.jar'],
    'dirs': [],
}

sanity_check_commands = ["%(name)s version"]

moduleclass = 'tools'
