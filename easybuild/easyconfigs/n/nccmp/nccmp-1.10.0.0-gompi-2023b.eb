# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025

easyblock = 'CMakeMake'

name = 'nccmp'
version = '1.10.0.0'

homepage = 'https://gitlab.com/remikz/nccmp'
description = """nccmp compares two NetCDF files bitwise, semantically or with a user defined
 tolerance (absolute or relative percentage). Parallel comparisons are done in local memory without
 requiring temporary files. Highly recommended for regression testing scientific models or datasets
 in a test-driven development environment."""

toolchain = {'name': 'gompi', 'version': '2023b'}

source_urls = ['https://gitlab.com/remikz/nccmp/-/archive/%(version)s']
sources = ['%(name)s-%(version)s.tar.gz']
checksums = ['4b665a5d1b77523e5eb353cc4c607794920faa5a1f31e6293f0dbcbe15d89a15']

builddependencies = [
    ('CMake', '3.27.6'),
]

dependencies = [
    ('netCDF', '4.9.2'),
    ('HDF5', '1.14.3'),
    ('HDF', '4.2.16-2'),
    ('Szip', '2.1.1'),
    ('libxml2', '2.11.5'),
    ('cURL', '8.3.0'),
]

configopts = "-DBUILD_TESTS=ON -DNETCDF_PATH=$EBROOTNETCDF"

sanity_check_paths = {
    'files': ['bin/nccmp'],
    'dirs': []
}

sanity_check_commands = ["nccmp --help"]

moduleclass = 'tools'
