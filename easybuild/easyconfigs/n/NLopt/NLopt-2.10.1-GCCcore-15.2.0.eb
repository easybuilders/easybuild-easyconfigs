easyblock = 'CMakeMake'

name = 'NLopt'
version = '2.10.1'

homepage = 'https://nlopt.readthedocs.io/en/latest/'
description = """ NLopt is a free/open-source library for nonlinear optimization,
 providing a common interface for a number of different free optimization routines
 available online as well as original implementations of various other algorithms. """

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/stevengj/nlopt/archive']
sources = ['v%(version)s.tar.gz']
checksums = ['30d13ce16da119db3e987784f7864e35a562ec62c186352fae55cd003e6c58ff']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

configopts = [
    '-DBUILD_SHARED_LIBS=ON',
    '-DBUILD_SHARED_LIBS=OFF'
]

sanity_check_paths = {
    'files': ['lib/libnlopt.a', f'lib/libnlopt.{SHLIB_EXT}', 'include/nlopt.h'],
    'dirs': ['lib/pkgconfig'],
}

moduleclass = 'numlib'
