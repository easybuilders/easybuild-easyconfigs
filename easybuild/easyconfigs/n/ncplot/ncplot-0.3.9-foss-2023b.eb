easyblock = 'PythonBundle'

name = 'ncplot'
version = '0.3.9'

homepage = 'https://github.com/pmlmodelling/ncplot'
description = """An easy to use Python (3.6 and above) package for quickly plotting the contents
 of NetCDF files or xarray datasets in Python or on the command line."""

toolchain = {'name': 'foss', 'version': '2023b'}

builddependencies = [
    ('binutils', '2.40'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('LLVM', '14.0.6', '-llvmlite'),
    ('netcdf4-python', '1.7.1.post2'),
    ('Pint', '0.24'),
    ('pyproj', '3.6.1'),
    ('xarray', '2024.5.0'),
    ('dask', '2024.5.1'),
    ('matplotlib', '3.8.2'),
    ('numba', '0.60.0'),
    ('bokeh', '3.3.4'),
    ('panel', '1.3.8'),
    ('holoviews', '1.18.3'),
    ('hvplot', '0.9.2'),
]

