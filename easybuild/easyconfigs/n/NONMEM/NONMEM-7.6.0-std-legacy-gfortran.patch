The source contains non-conforming Fortran code, so gfortran needs the -std=legacy option
Author: MaximeVdB from
https://github.com/vscentrum/vsc-software-stack/blob/site-kul/n/NONMEM/NONMEM-7.6.0-std-legacy-gfortran.patch
--- nm760CD/SETUP76_orig 2025-05-09 14:54:44.172408000 +0200
+++ nm760CD/SETUP76	 2025-05-09 14:54:01.958492000 +0200
@@ -413,7 +413,7 @@
 echo "end" >>dummyfile.f90
 gfortran -c dummyfile.f90 -ffpe-summary=none  >trash.txt 2>&1
 if [ $? == 0 ]; then fpesummary="-ffpe-summary=none"; fi
-op="-w -O3 -ffast-math  -fno-use-linker-plugin -finit-integer=0 ""$fpesummary"
+op="-w -O3 -ffast-math  -fno-use-linker-plugin -finit-integer=0 -std=legacy ""$fpesummary"
 fi
 
 if [[ $os == Darwin && $ftail == gfortran ]]; then op="$op ""$m" ; fi