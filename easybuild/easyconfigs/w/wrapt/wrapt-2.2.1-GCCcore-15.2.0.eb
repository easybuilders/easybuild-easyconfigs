easyblock = 'PythonPackage'

name = 'wrapt'
version = '2.2.1'

homepage = 'https://pypi.org/project/wrapt/'
description = """The aim of the wrapt module is to provide a transparent object
proxy for Python, which can be used as the basis for the construction of
function wrappers and decorator functions."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['6744f504375775d7609c82c8d3d94af1c9a6f05586984536905908ba905277b9']

builddependencies = [('binutils', '2.45')]
dependencies = [('Python', '3.14.2')]

moduleclass = 'tools'
