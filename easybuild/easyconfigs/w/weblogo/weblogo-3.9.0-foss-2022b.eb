easyblock = 'PythonPackage'

name = 'weblogo'
version = '3.9.0'

homepage = 'https://github.com/gecrooks/weblogo'
description = """WebLogo is a web based application designed to make the generation of
sequence logos as easy and painless as possible."""

toolchain = {'name': 'foss', 'version': '2022b'}

source_urls = [PYPI_SOURCE]
sources = [SOURCE_TAR_GZ]
checksums = ['4ea9138b56e55c9adc3b52a2ad950deafba29db96a89f9c8e2d27555f194ba76']

dependencies = [
    ('Python', '3.10.8'),
    ('SciPy-bundle', '2023.02'),
    ('Ghostscript', '10.0.0'),
]

use_pip = True
sanity_pip_check = True

sanity_check_paths = {
    'files': ['bin/weblogo'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/weblogo'],
}

sanity_check_commands = [
    'weblogo --help',
    "printf '>s1\nACGT\n>s2\nACGT\n' | weblogo > test.eps",
]

moduleclass = 'bio'
