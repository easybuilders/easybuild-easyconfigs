easyblock = 'Bundle'

name = 'wayvnc'
version = '0.10.0'

homepage = 'https://github.com/any1/wayvnc'
description = 'A VNC server for wlroots based Wayland compositors'

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

builddependencies = [
    ('binutils', '2.44'),
    ('Meson', '1.8.2'),
    ('Ninja', '1.13.0'),
]

dependencies = [
    ('libdrm', '2.4.125'),
    ('OpenGL', '2025.09'),
    ('X11', '20250608'),
    ('pixman', '0.46.4'),
    ('Jansson', '2.14.1'),
    ('GnuTLS', '3.8.10'),
    ('libjpeg-turbo', '3.1.1'),
    ('FFmpeg', '7.1.2'),
]

# Optional
osdependencies = [('pam-devel')]

default_easyblock = 'MesonNinja'

default_component_specs = {
    'sources': [{'download_filename': V_VERSION_TAR_GZ, 'filename': SOURCE_TAR_GZ}],
    'source_urls': ['https://github.com/any1/%(name)s/archive/'],
    'start_dir': '%(namelower)s-%(version)s',
}

components = [
    ('aml', '1.0.0', {
        'checksums': ['b2b8f743213af39f40e8bc611147d69e2ea9e010b9b19cb65246582338f28d96'],
    }),
    ('neatvnc', '1.0.0', {
        'checksums': ['993dedc30e72981650770c04438e9759537e4677010e2dab5e792c39afe74601'],
    }),
    (name, version, {
        'checksums': ['fcfda018d0e07ec00a80071420c8cc2a75885dc6d5e55bb50a9b12353754338f'],
    }),

]

sanity_check_paths = {
    'files': ['bin/wayvnc'],
    'dirs': [],
}

sanity_check_commands = ['wayvnc -h']

moduleclass = 'vis'
