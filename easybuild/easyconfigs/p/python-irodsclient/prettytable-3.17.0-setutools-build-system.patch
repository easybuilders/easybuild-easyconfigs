# Author: Ehsan Moravveji (VSC - KU Leuven)
# Purpose: To fix incompatibilities of hatchling, we switch to setuptools build backend

diff -ruN prettytable-3.17.0-orig/pyproject.toml prettytable-3.17.0/pyproject.toml
--- prettytable-3.17.0-orig/pyproject.toml	2026-03-13 15:51:12.947022000 +0100
+++ prettytable-3.17.0/pyproject.toml	2026-03-16 10:38:42.888521000 +0100
@@ -1,16 +1,16 @@
 [build-system]
-build-backend = "hatchling.build"
+build-backend = "setuptools.build_meta"
 requires = [
-  "hatch-vcs",
-  "hatchling>=1.27",
+    "setuptools>=69",
+    "wheel"
 ]
+license-files = [ "LICENSE" ]
 
 [project]
 name = "prettytable"
 description = "A simple Python library for easily displaying tabular data in a visually appealing ASCII table format"
 readme = "README.md"
-license = "BSD-3-Clause"
-license-files = [ "LICENSE" ]
+license = { text = "BSD-3-Clause" }
 maintainers = [ { name = "Hugo van Kemenade" } ]
 authors = [ { name = "Luke Maurits", email = "luke@maurits.id.au" } ]
 requires-python = ">=3.10"
@@ -22,13 +22,12 @@
   "Programming Language :: Python :: 3.12",
   "Programming Language :: Python :: 3.13",
   "Programming Language :: Python :: 3.14",
-  "Programming Language :: Python :: 3.15",
   "Programming Language :: Python :: Implementation :: CPython",
   "Programming Language :: Python :: Implementation :: PyPy",
   "Topic :: Text Processing",
   "Typing :: Typed",
 ]
-dynamic = [ "version" ]
+version = "3.17.0"
 dependencies = [
   "wcwidth",
 ]
