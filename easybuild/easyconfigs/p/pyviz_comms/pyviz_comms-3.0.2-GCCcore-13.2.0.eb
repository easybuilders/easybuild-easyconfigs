# Barcelona Supercomputing Center 2024

easyblock = 'PythonPackage'

name = 'pyviz_comms'
version = '3.0.2'

homepage = 'https://github.com/holoviz/pyviz_comms'
description = """Offers a simple bidirectional communication architecture between Python and
 JavaScript, with support for Jupyter comms in both the classic notebook and Jupyterlab. Available
 for use by any PyViz tool, but currently primarily used by HoloViz tools."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['3167df932656416c4bd711205dad47e986a3ebae1f316258ddc26f9e01513ef7']

builddependencies = [
    ('binutils', '2.40'),
    ('hatchling', '1.18.0'),
    ('hatch-jupyter-builder', '0.9.1'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('JupyterLab', '4.2.0'),
    ('hatch-nodejs-version', '0.3.2'),
    ('param', '2.1.0'),
]

moduleclass = 'vis'
