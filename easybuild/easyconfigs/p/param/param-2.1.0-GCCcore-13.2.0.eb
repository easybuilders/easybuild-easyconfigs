easyblock = 'PythonPackage'

name = 'param'
version = '2.1.0'

homepage = 'https://github.com/holoviz/param'
description = """Param is a library providing Parameters: Python attributes extended to have
 features such as type and range checking, dynamically generated values, documentation strings,
 default values, etc., each of which is inherited from parent classes if not specified in a
 subclass."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['a7b30b08b547e2b78b02aeba6ed34e3c6a638f8e4824a76a96ffa2d7cf57e71f']

builddependencies = [
    ('binutils', '2.40'),
    ('hatchling', '1.18.0'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
]

moduleclass = 'lib'
