easyblock = 'PythonPackage'

name = 'PyMySQL'
version = '1.1.0'

homepage = 'https://pymysql.readthedocs.io/'
description = "This package contains a pure-Python MySQL and MariaDB client library, based on PEP 249."

toolchain = {'name': 'GCC', 'version': '13.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['4f13a7df8bf36a51e81dd9f3605fede45a4878fe02f9236349fd82a3f0612f96']

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('MariaDB', '11.7.0'),
]

options = {'modulename': '%(namelower)s'}

moduleclass = 'lib'
