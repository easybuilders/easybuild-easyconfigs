easyblock = 'CmdCp'

name = 'Pirana'
version = '25.7.1'

homepage = 'https://www.certara.com/software/pirana-modeling-workbench'
description = """Pirana is a workbench for optimizing pharmacometric workflows."""

toolchain = {'name': 'foss', 'version': '2024a'}
toolchainopts = {'openmp': False, 'pic': True}

local_perlver = '5.38.2'
local_perlmajver = local_perlver.split('.')[0]
local_libdir = f'lib/perl{local_perlmajver}/site_perl/{local_perlver}'

