local_install_cmd = r"""
mkdir -p %(installdir)s/pirana %(installdir)s/bin &&
cp -a . %(installdir)s/pirana &&

cat > %(installdir)s/bin/pirana <<'EOF'
#!/usr/bin/env bash
export PIRANA_LOCALLIB="${PIRANA_LOCALLIB:-%(installdir)s}"
exec perl "%(installdir)s/pirana/pirana.pl" "$@"
EOF

cat > %(installdir)s/bin/pirana_start <<'EOF'
#!/usr/bin/env bash
export PIRANA_LOCALLIB="${PIRANA_LOCALLIB:-%(installdir)s}"
exec "%(installdir)s/pirana/pirana_start" "$@"
EOF

chmod +x %(installdir)s/bin/pirana %(installdir)s/bin/pirana_start
"""

cmds_map = [('.*', local_install_cmd)]

files_to_copy = []
skipsteps = ['install']

sanity_check_paths = {
    'files': [
        'bin/pirana',
        'bin/pirana_start',
        'pirana/pirana.pl',
        'pirana/pirana_start',
    ],
    'dirs': [
        'pirana/pirana_modules',
        'pirana/pirana_scripts',
        'pirana/templates',
        'pirana/linux',
    ],
}

sanity_check_commands = ['perl -c $EBROOTPIRANA/pirana/pirana.pl']

modextrapaths = {
    'PATH': 'bin',
    'PERL5LIB': [local_libdir],
}

modextravars = {'PIRANA_LOCALLIB': '%(installdir)s'}

modloadmsg = """
Pirana is a graphical application. Use it from an interactive desktop/X11 session.
Launch with either:
  pirana
or optionally:
  pirana_start
"""

moduleclass = 'bio'
