easyblock = 'JuliaBundle'

name = 'ParallelTestRunner'
version = '2.6.2'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/JuliaTesting/ParallelTestRunner.jl'
description = """Simple parallel test runner for Julia tests with autodiscovery."""

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
    ('Statistics', '1.11.1', versionsuffix),
]

exts_list = [
    ('IOCapture', '1.0.0', {
        'source_urls': ['https://github.com/JuliaDocs/IOCapture.jl/archive/'],
        'checksums': ['8b28fe5e06cb6f783fdb425a04abea3d53ccd7d9a23b8370e0d99c1130347b45'],
    }),
    ('Scratch', '1.3.0', {
        'source_urls': ['https://github.com/JuliaPackaging/Scratch.jl/archive/'],
        'checksums': ['acaaea133ff71ad614324129317d69a2f08810340607cb6c288d93bb10f23277'],
    }),
    ('RelocatableFolders', '1.0.1', {
        'source_urls': ['https://github.com/JuliaPackaging/RelocatableFolders.jl/archive/'],
        'checksums': ['a20882fdb81f79e3e26ca5687e9222def6ca253f8980ba919453f830882dccd6'],
    }),
    ('Statistics', '1.11.1', {
        'source_urls': ['https://github.com/JuliaStats/Statistics.jl/archive/'],
        'checksums': ['a121e8e8b7e3b0d62ff9e5e0eb1e19c1b4ab67b23d80055f3e4c8b4d46e5b2e8'],
    }),
    ('Malt', '1.4.1', {
        'source_urls': ['https://github.com/JuliaPluto/Malt.jl/archive/'],
        'checksums': ['c4cf7cdc364fe9b0d93adcec1aac67d377319fb712a814bd7260748b89377211'],
    }),
    ('ParallelTestRunner', '2.6.2', {
        'source_urls': ['https://github.com/JuliaTesting/ParallelTestRunner.jl/archive/'],
        'checksums': ['0d0685a444d07213e862ca51805e43edaf566efc5125268e876565845a064921'],
        'runtest': True,
    }),
]

moduleclass = 'tools'
