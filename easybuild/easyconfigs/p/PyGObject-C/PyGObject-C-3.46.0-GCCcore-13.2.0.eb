# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025
# Build from the GNOME source tarball to include the C extension

easyblock = 'MesonNinja'

name = 'PyGObject-C'
version = '3.46.0'

homepage = 'https://pygobject.readthedocs.io/'
description = """
 PyGObject is a Python package which provides bindings for GObject based libraries such as GTK,
 GStreamer, WebKitGTK, GLib, GIO and many more. This build is from the GNOME source tarball and
 includes the C extension and pkg-config file `pygobject-3.0.pc`.
"""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

source_urls = [FTPGNOME_SOURCE]
sources = ['pygobject-%(version)s.tar.xz']
checksums = ['426008b2dad548c9af1c7b03b59df0440fde5c33f38fb5406b103a43d653cafc']

builddependencies = [
    ('Meson', '1.2.3'),
    ('Ninja', '1.11.1'),
    ('binutils', '2.40'),
    ('pkgconf', '2.0.3'),
]

dependencies = [
    ('GLib', '2.78.1'),
    ('GObject-Introspection', '1.78.1'),
    ('Python', '3.11.5'),
    ('PyCairo', '1.25.1'),
]

build_type = 'release'

sanity_check_paths = {
    'files': ['lib/pkgconfig/pygobject-3.0.pc'],
    'dirs': ['include/pygobject-3.0'],
}

moduleclass = 'devel'
