# Author: Stamen Miroslavov, BSC 2025
# Barcelona Supercomputing Center - Spain

easyblock = 'PythonBundle'

name = 'pyslurm'
version = '23.2.3'

homepage = 'https://github.com/PySlurm/pyslurm'
description = """pyslurm is the Python client library for the Slurm Workload Manager"""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

builddependencies = [
    ('Cython', '3.0.10'),
    ('binutils', '2.40'),
]

dependencies = [
    ('Python', '3.11.5'),
]

osdependencies = [('slurm-devel', 'libslurm-dev')]

exts_list = [
    (name, version, {
        # this version is not on PyPI
        'source_urls': ['https://github.com/PySlurm/pyslurm/archive/refs/tags'],
        'source_tmpl': 'v%(version)s.tar.gz',
        'checksums': ['5c09d513d9afb869f6111e49452a5c55ae34911602294a9e85b960b2aa31e65e'],
    }),
]

moduleclass = 'data'
