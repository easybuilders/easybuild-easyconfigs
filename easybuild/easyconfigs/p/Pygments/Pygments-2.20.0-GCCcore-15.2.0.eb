easyblock = 'PythonPackage'

name = 'Pygments'
version = '2.20.0'

homepage = 'https://pygments.org/'
description = """Generic syntax highlighter suitable for use in code hosting, forums, wikis or other applications
 that need to prettify source code."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCELOWER_TAR_GZ]
checksums = ['6757cd03768053ff99f3039c1a36d6c0aa0b263438fcab17520b30a303a82b5f']

builddependencies = [
    ('binutils', '2.45'),
    ('hatchling', '1.29.0'),
]

dependencies = [
    ('Python', '3.14.2'),
]

sanity_check_paths = {
    'files': ['bin/pygmentize'],
    'dirs': [],
}

sanity_check_commands = ['pygmentize --help']

moduleclass = 'devel'
