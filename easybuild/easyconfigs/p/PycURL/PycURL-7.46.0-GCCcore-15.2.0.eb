easyblock = 'PythonPackage'

name = 'PycURL'
version = '7.46.0'

homepage = 'http://pycurl.io/'
description = """PycURL is a Python interface to libcurl. PycURL can be used to fetch objects identified by a URL
 from a Python program, similar to the urllib Python module. PycURL is mature, very fast, and supports a lot of
 features."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCELOWER_TAR_GZ]
checksums = ['422ed7005b98768fe60fe6b6cb8bb6a4e1fc18b5433402e8fbdaba91811c4604']

builddependencies = [
    ('binutils', '2.45'),
]
dependencies = [
    ('Python', '3.14.2'),
    ('cURL', '8.17.0'),
]

moduleclass = 'tools'
