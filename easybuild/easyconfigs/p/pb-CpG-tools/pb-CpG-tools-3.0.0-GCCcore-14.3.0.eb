easyblock = 'Cargo'

name = 'pb-CpG-tools'
version = '3.0.0'

homepage = 'https://github.com/PacificBiosciences/pb-CpG-tools'
description = "Collection of tools for the analysis of CpG data"

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

# Needs git repo for build.rs to function
sources = [{
    'filename': '%(name)s-%(version)s.tar.gz',
    'git_config': {
        'url': 'https://github.com/PacificBiosciences',
        'repo_name': name,
        'tag': 'v%(version)s',
        'recursive': True,
        'keep_git_dir': True,
    }
}]
