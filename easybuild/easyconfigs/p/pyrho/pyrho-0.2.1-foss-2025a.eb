easyblock = 'PythonBundle'

name = 'pyrho'
version = '0.2.1'

homepage = 'https://github.com/popgenmethods/pyrho'
description = """
Fast demography-aware inference of fine-scale recombination rates based on fused-LASSO.
"""

toolchain = {'name': 'foss', 'version': '2025a'}

github_account = 'popgenmethods'
_commit = 'd0aed27'  # Commit in which versioning was bumped

dependencies = [
    ('Python', '3.13.1'),
    ('SciPy-bundle', '2025.06'),
    ('numba', '0.62.0'),
    ('PyTables', '3.10.2'),
    ('cyvcf2', '0.32.1'),
    ('msprime', '1.4.1'),
    ('LDpop', '1.0.2'),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/%(github_account)s/%(name)s/archive'],
        'sources': ['d0aed27.tar.gz'],
        'testinstall': True,
        'runtest': "pytest tests/tests.py",
        'checksums': ['fec1fc134141ae0eda84abc28d3fadd0b19a1f704b4228ee58629d61e93037e1'],
    }),
]

moduleclass = 'ai'
