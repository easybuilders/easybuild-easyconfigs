# updated: Denis Kristak, Pavel Tománek (INUITS)
easyblock = 'PythonBundle'

name = 'pydot'
version = '4.0.1'

homepage = 'https://github.com/pydot/pydot'
description = "Python interface to Graphviz's Dot language."

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('setuptools', '80.9.0'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('Python-bundle-PyPI', '2025.04'),
]

exts_list = [
    (name, version, {
        'checksums': ['c2148f681c4a33e08bf0e26a9e5f8e4099a82e0e2a068098f32ce86577364ad5'],
    }),
]

moduleclass = 'vis'
