easyblock = 'Tarball'

name = "PGDSpider"
version = "3.0.0.0"

homepage = 'http://cmpg.unibe.ch/software/PGDSpider/'
description = """
An automated data conversion tool for connecting population genetics and genomics programs
"""

toolchain = SYSTEM

source_urls = ['https://software.bioinformatics.unibe.ch/pgdspider/']
sources = ['%(name)s_%(version)s.zip']
checksums = ['8e21665f6355d33193f410adaef0bc11f0b5b9a65e2781cb9424df55b4c23c34']

dependencies = [
    ('Java', '25'),
]

sanity_check_commands = ['java -jar $EBROOTPGDSPIDER/PGDSpider3-cli.jar -h']
sanity_check_paths = {
    'files': ['PGDSpider3-cli.jar', 'PGDSpider3.jar'],
    'dirs': [],
}

modloadmsg = """
To execute GUI run: java -jar $EBROOTPGDSPIDER/PGDSpider3.jar
To execute CLI run: java -jar $EBROOTPGDSPIDER/PGDSpider3-cli.jar
Adjust memory according to your requirements
"""

moduleclass = 'bio'
