easyblock = 'ConfigureMake'

name = 'parallel'
version = '20260522'

homepage = 'https://savannah.gnu.org/projects/parallel/'
description = """parallel: Build and execute shell commands in parallel"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = [GNU_SOURCE]
sources = [SOURCELOWER_TAR_BZ2]
checksums = ['2bab0cf913eeb60a24c6575d60e3c167cd03e63b4f7d17965915844e005dd895']

builddependencies = [('binutils', '2.45')]

dependencies = [
    ('Perl', '5.42.0'),
    ('Perl-bundle-CPAN', '5.42.0'),
]

sanity_check_paths = {
    'files': ['bin/parallel'],
    'dirs': []
}

sanity_check_commands = [
    'parallel --help',
    'time parallel --csv echo < <(echo -e "task1\ntask2\ntask3")',
]

moduleclass = 'tools'
