easyblock = 'PythonPackage'

name = 'pytest-rerunfailures'
version = '16.3'

homepage = 'https://github.com/pytest-dev/pytest-rerunfailures'
description = "pytest plugin to re-run tests to eliminate flaky failures."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/pytest-dev/pytest-rerunfailures/archive/refs/tags/']
sources = ['%(version)s.tar.gz']
checksums = ['0a8405f10cf360ba8750e804364ce1328deb6bfe754d2a7d1f88fac45b0c670d']

builddependencies = [
    ('binutils', '2.45'),
]
dependencies = [
    ('Python', '3.14.2'),
    ('Python-bundle-PyPI', '2026.04'),
]

moduleclass = 'tools'
