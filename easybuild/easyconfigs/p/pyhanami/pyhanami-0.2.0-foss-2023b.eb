# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2026

easyblock = 'PythonBundle'

name = 'pyhanami'
version = '0.2.0'

homepage = 'https://github.com/BSC-ES/pyhanami'
description = """Pyhanami: A Python tool for evaluating the replicability and scientific skill of
 Earth System Models (ESMs) through statistical testing and climate diagnostics."""

toolchain = {'name': 'foss', 'version': '2023b'}

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('matplotlib', '3.8.2'),
    ('netcdf4-python', '1.7.1.post2'),
    ('Pint', '0.24'),
    ('PyYAML', '6.0.1'),
    ('BeautifulSoup', '4.12.2'),
    ('Cartopy', '0.22.0'),
    ('xarray', '2024.5.0'),
    ('cftime', '1.6.4'),
    ('cmocean', '4.0.3'),
    ('tqdm', '4.66.2'),
    ('xeofs', '3.0.3'),
    ('xESMF', '0.8.8'),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/BSC-ES/pyhanami/archive/refs/tags'],
        'source_tmpl': 'v%(version)s.tar.gz',
        'checksums': ['79596d3d727da43afe6369c80022b2af827d85087ad677bba5a2e560e0947618'],
    }),
]

sanity_check_commands = ["python -s -c 'import pyhanami'"]

moduleclass = 'geo'
