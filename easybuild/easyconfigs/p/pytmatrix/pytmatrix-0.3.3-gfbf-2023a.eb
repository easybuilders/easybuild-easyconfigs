easyblock = 'PythonBundle'

name = 'pytmatrix'
version = '0.3.3'

homepage = 'https://github.com/jleinonen/pytmatrix'
description = "Python code for T-matrix scattering calculations."

toolchain = {'name': 'gfbf', 'version': '2023a'}

dependencies = [
    ('Python', '3.11.3'),
    ('SciPy-bundle', '2023.07'),
]

exts_list = [
    (name, version, {
        # pypi sources are broken: error: 'pytmatrix/fortran_tm/pytmatrixmodule.c' missing
        'source_urls': ['https://github.com/jleinonen/pytmatrix/archive/'],
        'sources': [{'download_filename': '%(version)s.tar.gz', 'filename': '%(name)s-%(version)s.tar.gz'}],
        'checksums': ['2c06d16ce0bb43413988f183d38bc358ffeef039c1bc44c5d92d9bc9fd875c72'],
    }),
]

moduleclass = 'lib'
