easyblock = 'PythonBundle'

name = 'PyLipID'
version = '1.5.14'

homepage = 'https://pylipid.readthedocs.io'
description = """PyLipID is a python package for analyzing lipid
interactions with membrane proteins from Molecular Dynamics
Simulations."""

