# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025

easyblock = 'PythonBundle'

name = 'pynco'
version = '1.1.2'

homepage = 'https://github.com/nco/pynco'
description = """Python bindings to NCO. This package contains the python module nco, which
 implements a python style access to the NetCDF Operators (NCO). NCO is a command line tool for
 processing netCDF data. Its main focus is climate data, but it can by used for other purposes
 too."""

toolchain = {'name': 'foss', 'version': '2023b'}

source_urls = ['https://github.com/nco/%(name)s/archive/refs/tags']
sources = ['%(version)s.tar.gz']
checksums = ['13df8d9e7f939e7502e81f0f820c142bc6013993bba0849e388aaf7f4f146a0e']

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('NCO', '5.3.2'),
]

exts_list = [
    ('nco', version, {
        'checksums': ['1c94d2bdff2937ac1610b52aef9219f446675f8cfc820c9d607cffe80daf2e57'],
    }),
]

moduleclass = 'data'
