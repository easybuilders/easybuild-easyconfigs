easyblock = "JuliaBundle"

name = 'Pluto'
version = '0.20.13'
_julia_ver = '1.11.5'
versionsuffix = '-Julia-%s' % _julia_ver

homepage = 'https://plutojl.org/'
description = """Simple, reactive programming environment for the Julia Language."""

toolchain = SYSTEM

dependencies = [
    ('Julia', '%s' % _julia_ver)
]

