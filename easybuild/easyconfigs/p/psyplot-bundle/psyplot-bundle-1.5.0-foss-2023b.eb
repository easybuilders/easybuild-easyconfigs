easyblock = 'PythonBundle'

name = 'psyplot-bundle'
version = '1.5.0'

homepage = 'https://codebase.helmholtz.cloud/psyplot/psyplot'
description = """psyplot is an open source python project that mainly combines the
plotting utilities of matplotlib and the data management of the xarray
package. The main purpose is to have a framework that allows a  fast,
attractive, flexible, easily applicable, easily reproducible and especially
an interactive visualization of your data."""

toolchain = {'name': 'foss', 'version': '2023b'}

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('xarray', '2024.5.0'),
    ('matplotlib', '3.8.2'),
    ('PyYAML', '6.0.1'),
    ('netcdf4-python', '1.7.1.post2'),
    ('Qtconsole', '5.6.0'),  # For psyplot-gui
    ('Sphinx-RTD-Theme', '2.0.0'),  # For psyplot-gui
    ('statsmodels', '0.14.1'),  # For psy-reg
    ('scikit-learn', '1.4.0'),  # For psy-transect
    ('pyinterp', '2024.11.0'),  # For psy-transect
    ('Cartopy', '0.22.0'),  # For psy-maps
]

