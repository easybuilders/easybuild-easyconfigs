easyblock = 'PythonPackage'

name = 'pyproj'
version = '3.7.2'

homepage = 'https://pyproj4.github.io/pyproj'
description = "Python interface to PROJ4 library for cartographic transformations"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['39a0cf1ecc7e282d1d30f36594ebd55c9fae1fda8a2622cee5d100430628f88c']

builddependencies = [
    ('binutils', '2.45'),
    ('Cython', '3.2.4'),
]
dependencies = [
    ('Python', '3.14.2'),
    ('Python-bundle-PyPI', '2026.04'),
    ('PROJ', '9.8.1'),
]

preinstallopts = "export PROJ_DIR=$EBROOTPROJ && "

sanity_check_paths = {
    'files': [f'bin/{name}'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = [f'{name} --help']

moduleclass = 'data'
