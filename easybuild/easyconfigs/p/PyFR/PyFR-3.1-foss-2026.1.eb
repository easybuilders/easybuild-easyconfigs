easyblock = 'PythonBundle'

name = 'PyFR'
version = '3.1'

homepage = 'https://www.pyfr.org'
description = """An open-source platform for fast, robust and accurate Scale-Resolving Simulations of industrial flow
problems."""

toolchain = {'name': 'foss', 'version': '2026.1'}

builddependencies = [
    ('hatchling', '1.29.0'),
    ('meson-python', '0.19.0'),
    ('Cython', '3.2.4'),
]

dependencies = [
    ('Python', '3.14.2'),
    ('SciPy-bundle', '2026.05'),
    ('h5py', '3.16.0'),
    ('Mako', '1.3.12'),
    ('mpi4py', '4.1.2'),
    ('Rtree', '1.4.1'),
]

exts_list = [
    ('gimmik', '3.2.1', {
        'checksums': ['048644bd71497eb07e144f2c22fdee49ba23e1cde5fb954c3c30c4e3ea23687a'],
    }),
    ('siphash24', '1.8', {
        'checksums': ['aa932f0af4a7335caef772fdaf73a433a32580405c41eb17ff24077944b0aa97'],
    }),
    ('pytools', '2026.1.1', {
        'checksums': ['260e0d88c9a903c65cfe34fbe818764f44a3f96e722e1a3645ce4d596add22b1'],
    }),
    ('pyfr', version, {
        'checksums': ['a41d183f6d1499a2e0f65ca8b231032b23ae3166acb278201b9dadfeb6ec63ef'],
    }),
]

sanity_check_paths = {
    'files': ['bin/pyfr'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = ["pyfr --help"]

moduleclass = 'math'
