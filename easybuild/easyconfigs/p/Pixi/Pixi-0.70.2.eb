easyblock = 'Cargo'

name = 'Pixi'
version = '0.70.2'

homepage = 'https://pixi.sh'
description = """
Pixi is a cross-platform, multi-language package manager and workflow tool built on the
foundation of the conda ecosystem. It provides developers with an exceptional
experience similar to popular package managers like cargo or npm, but for any language.
"""

toolchain = SYSTEM

github_account = 'prefix-dev'
source_urls = [GITHUB_SOURCE]
sources = ['v%(version)s.tar.gz']
