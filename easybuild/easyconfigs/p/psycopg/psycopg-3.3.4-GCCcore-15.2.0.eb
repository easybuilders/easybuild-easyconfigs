easyblock = 'PythonPackage'

name = 'psycopg'
version = '3.3.4'

homepage = 'https://psycopg.org/'
description = "Psycopg is the most popular PostgreSQL adapter for the Python programming language."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['e21207764952cff81b6b8bdacad9a3939f2793367fdac2987b3aac36a651b5bc']

builddependencies = [('binutils', '2.45')]
dependencies = [
    ('Python', '3.14.2'),
    ('PostgreSQL', '18.4'),
]

moduleclass = 'lib'
