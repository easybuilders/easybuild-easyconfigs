name = 'pybind11'
version = '3.0.4'

homepage = 'https://pybind11.readthedocs.io'
description = """pybind11 is a lightweight header-only library that exposes C++ types in Python and vice versa,
 mainly to create Python bindings of existing C++ code."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/pybind/pybind11/archive/']
sources = [{'download_filename': 'v%(version)s.tar.gz', 'filename': SOURCE_TAR_GZ}]
patches = ['pybind11-2.10.3_require-catch.patch']
checksums = [
    {'pybind11-3.0.4.tar.gz': '74b6a2c2b4573a400cafb6ecbf60c98df300cd3d0041296b913d02b2cbbb2676'},
    {'pybind11-2.10.3_require-catch.patch': '4a27ba3ef1d5c535d120d6178a6e876ae678e4899a07500aab37908357b0b60b'},
]

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
    # Test dependencies
    ('Eigen', '5.0.0'),
    ('Catch2', '2.13.10'),
    ('Python-bundle-PyPI', '2026.04'),  # to provide pytest
    ('scikit-build-core', '0.12.2'),
]
dependencies = [
    ('Boost', '1.90.0'),
    ('Python', '3.14.2'),
]

moduleclass = 'lib'
