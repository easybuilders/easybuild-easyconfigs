easyblock = 'PythonPackage'

name = 'pyBigWig'
version = '0.3.25'

homepage = 'https://github.com/deeptools/pyBigWig'
description = """A python extension, written in C, for quick access to bigBed
files and access to and creation of bigWig files."""

toolchain = {'name': 'gfbf', 'version': '2025b'}

sources = [SOURCELOWER_TAR_GZ]
checksums = ['8c717b0222e6677956fd659c8a21650983679ffb3314427d7f68d2910fad202a']

dependencies = [
    ('Python', '3.13.5'),
    ('cURL', '8.14.1'),
    ('NSS', '3.114'),    # provides libfreebl3
    ('SciPy-bundle', '2025.07'),    # optional, for numpy support
]

options = {'modulename': name}

moduleclass = 'bio'
