C23 defines proper "true" and "false" keywords and these may not be redefined

author: micketeer@gmail.com

--- libyasm/bitvect.h.orig	2026-05-21 18:10:00.672205983 +0200
+++ libyasm/bitvect.h	2026-05-21 18:11:00.982165947 +0200
@@ -83,7 +83,7 @@
     #ifdef MACOS_TRADITIONAL
         #define boolean Boolean
     #else
-        typedef enum boolean { false = FALSE, true = TRUE } boolean;
+        typedef bool boolean;
     #endif
 #endif
 
