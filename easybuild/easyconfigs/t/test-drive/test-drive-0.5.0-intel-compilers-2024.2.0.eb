easyblock = 'MesonNinja'

name = 'test-drive'
version = '0.5.0'

homepage = 'https://github.com/fortran-lang/test-drive'
description = """This project offers a lightweight, procedural unit testing framework
 based on nothing but standard Fortran."""

toolchain = {'name': 'intel-compilers', 'version': '2024.2.0'}

source_urls = ['https://github.com/fortran-lang/%(name)s/archive/refs/tags/']
sources = [V_VERSION_TAR_GZ]
checksums = ['e7d99209de0d1c4faebf3be64303a3adf2940c07cf86d47858c4032c5d38dfc2']

builddependencies = [
    ('CMake', '3.29.3'),
    ('Meson', '1.4.0'),
    ('Ninja', '1.12.1'),
]


sanity_check_paths = {
    'files': [],
    'dirs': ['lib'],
}

moduleclass = 'lang'
