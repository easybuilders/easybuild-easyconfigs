easyblock = 'RPackage'

name = 'tMAE'
version = '1.0.5'
versionsuffix = '-R-%(rver)s'

homepage = 'https://github.com/gagneurlab/tMAE'
description = """
Package containing functions to:

    perform a negative binomial test on allele-specific counts
    add gnomAD minor allele frequencies
    MAplot (FC vs total counts) of allele-specific counts and results
    allelic counts (ALT vs REF)"""

toolchain = {'name': 'foss', 'version': '2023b'}

dependencies = [
    ('R', '4.4.1'),
    ('R-bundle-CRAN', '2024.06'),
    ('R-bundle-Bioconductor', '3.19', versionsuffix),
]

github_account = 'gagneurlab'
source_urls = [GITHUB_SOURCE]
sources = ['%(version)s.tar.gz']
checksums = ['c43f24bdd846ad39672d7911581cd6190af726503b1dd674d75f739cf90ed1e2']

sanity_check_paths = {
    'files': [],
    'dirs': [name],
}

moduleclass = 'bio'
