easyblock = 'JuliaBundle'

name = 'TestItemRunner'
version = '1.1.5'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/julia-vscode/TestItemRunner.jl/'
description = """This package runs @testitem tests. """

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
    ('TestItems', '1.0.0', versionsuffix),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/julia-vscode/TestItemRunner.jl/archive/'],
        'checksums': [None],
        'runtest': True,
    }),
]

moduleclass = 'tools'
