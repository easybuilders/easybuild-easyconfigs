easyblock = 'JuliaBundle'

name = 'TestItems'
version = '1.0.0'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/julia-testitems/TestItems.jl'
description = """This package provides the @testitem macro for the test runner feature in VS Code."""

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/julia-testitems/TestItems.jl/archive/'],
        'checksums': [None],
        'runtest': True,
    }),
]

moduleclass = 'tools'
