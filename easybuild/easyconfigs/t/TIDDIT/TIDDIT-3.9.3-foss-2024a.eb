# TIDDIT-3.9.3-foss-2024a.ebi
# Author: Nicolas Rapin
# Org: Danish National Genome Center
easyblock = 'PythonPackage'

name = 'TIDDIT'
version = '3.9.3'

homepage = 'https://github.com/SciLifeLab/TIDDIT'
description = 'Tool for identifying chromosomal rearrangements using Mate Pair or Paired End sequencing data.'

toolchain = {'name': 'foss', 'version': '2024a'}

source_urls = ['https://github.com/SciLifeLab/TIDDIT/archive/refs/tags/']
sources = ['TIDDIT-%(version)s.tar.gz']
checksums = ['6343a4785e81812057ede262e01a5b4fda6971de911c6a759333098010564b41']

dependencies = [
    ('Python', '3.12.3'),
    ('Cython', '3.0.10'),
    ('Pysam', '0.22.1'),
    ('SciPy-bundle', '2024.05'),
]

sanity_check_paths = {
    'files': ['bin/tiddit'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = ['tiddit --help']

moduleclass = 'bio'
