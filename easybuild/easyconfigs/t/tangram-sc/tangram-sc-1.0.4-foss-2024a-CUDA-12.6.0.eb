easyblock = 'PythonBundle'

name = 'tangram-sc'
version = '1.0.4'
versionsuffix = '-CUDA-%(cudaver)s'

homepage = 'https://github.com/broadinstitute/Tangram'
description = "Mapping single-cell (or single-nucleus) gene expression data onto spatial gene expression data."

toolchain = {'name': 'foss', 'version': '2024a'}

dependencies = [
    ('CUDA', '12.6.0', '', SYSTEM),
    ('Python', '3.12.3'),
    ('SciPy-bundle', '2024.05'),
    ('matplotlib', '3.9.2'),
    ('PyTorch', '2.7.1', versionsuffix),
    ('scanpy', '1.10.4'),
    ('Seaborn', '0.13.2'),
    ('scikit-learn', '1.5.2'),
    ('tqdm', '4.66.5'),
]

exts_list = [
    (name, version, {
        'modulename': 'tangram',
        'checksums': ['6ced24573e288fa01a8070e3c7600058de51296bac1702515db87c310da6ac13'],
    }),
]

moduleclass = 'tools'
