easyblock = 'MesonNinja'

name = 'tllist'
version = '1.1.0'

homepage = 'https://codeberg.org/dnkl/tllist'
description = 'tllist is a Typed Linked List C header file only library implemented using pre-processor macros.'

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://codeberg.org/dnkl/tllist/archive/']
sources = [VERSION_TAR_GZ]
checksums = ['0e7b7094a02550dd80b7243bcffc3671550b0f1d8ba625e4dff52517827d5d23']

builddependencies = [
    ('binutils', '2.44'),
    ('Meson', '1.8.2'),
    ('Ninja', '1.13.0'),
]

sanity_check_paths = {
    'files': ['include/tllist.h'],
    'dirs': [],
}

moduleclass = 'lib'
