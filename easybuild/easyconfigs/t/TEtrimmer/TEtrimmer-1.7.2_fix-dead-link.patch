RepeatPeps.lib got removed from the RepeatMasker repo, instead
use the version bundled with the installed RepeatMasker.
Issue: https://github.com/qjiangzhao/TEtrimmer/issues/103
Author: Jarne Renders (Vrije Universiteit Brussel)
diff -ruN TEtrimmer.orig/tetrimmer/TE-Aid-master/TE-Aid TEtrimmer/tetrimmer/TE-Aid-master/TE-Aid
--- TEtrimmer.orig/tetrimmer/TE-Aid-master/TE-Aid	2026-05-29 11:25:49.085219048 +0200
+++ TEtrimmer/tetrimmer/TE-Aid-master/TE-Aid	2026-06-16 13:52:07.564285662 +0200
@@ -283,7 +283,7 @@
     else
         echo "RepeatPeps.lib is not found, downloading..."
         mkdir -p $DBDIR
-        curl -o $DBDIR/RepeatPeps.lib https://raw.githubusercontent.com/rmhubley/RepeatMasker/master/Libraries/RepeatPeps.lib
+        ln -s $EBROOTREPEATMASKER/Libraries/RepeatPeps.lib $DBDIR/db/RepeatPeps.lib 
         echo "Formating database"
         makeblastdb -in $DBDIR/RepeatPeps.lib -out $DBDIR/RepeatPeps.lib -dbtype 'prot' &>/dev/null
         echo "Blastp-ing..."
