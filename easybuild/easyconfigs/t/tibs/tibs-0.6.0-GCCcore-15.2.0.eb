easyblock = 'CargoPythonPackage'

name = 'tibs'
version = '0.6.0'

homepage = 'https://github.com/scott-griffiths/tibs'
description = "A simple but powerful Python library for creating, interpreting and manipulating binary data."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]

builddependencies = [
    ('binutils', '2.45'),
    ('Rust', '1.94.1'),
    ('maturin', '1.13.1'),
]
dependencies = [('Python', '3.14.2')]

buildcmd = 'maturin build --release --interpreter %(python)s'
install_src = 'target/wheels/tibs-%(version)s-*.whl'

