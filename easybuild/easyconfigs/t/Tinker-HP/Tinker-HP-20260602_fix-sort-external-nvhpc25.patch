Newer NVHPC versions add conflict between sort functions. 
https://github.com/TinkerTools/tinker-hp/issues/32
Patch by louislagardere from the above issue.
diff --git a/source/attach.f90 b/source/attach.f90
index 749c9239..eaed0955 100644
--- a/source/attach.f90
+++ b/source/attach.f90
@@ -69,7 +69,7 @@ subroutine attach
             &' Attached to Atom',i6)
          call fatal
       end if
-      call sort (n13(i),i13(1,i))
+      call tsort(n13(i),i13(1,i))
    end do
 !
 !     loop over all atoms finding all the 1-4 relationships
@@ -98,7 +98,7 @@ subroutine attach
             &' Attached to Atom',i6)
          call fatal
       end if
-      call sort (n14(i),i14(1,i))
+      call tsort(n14(i),i14(1,i))
    end do
 !
 !     loop over all atoms finding all the 1-5 relationships
@@ -130,7 +130,7 @@ subroutine attach
             &' Attached to Atom',i6)
          call fatal
       end if
-      call sort (n15(i),i15(1,i))
+      call tsort(n15(i),i15(1,i))
    end do
 70 continue
 
