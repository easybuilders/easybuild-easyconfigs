easyblock = 'PythonPackage'

name = 'tar2zip'
version = '0.1.0'

homepage = 'https://github.com/c3se/tar2zip'
description = "Simple Python-based CLI tool to convert tar archive to uncompressed zip archives."

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

dependencies = [
    ('binutils', '2.44'),
    ('Python', '3.13.5'),
]

github_account = "c3se"
source_urls = [GITHUB_SOURCE]
sources = [V_VERSION_TAR_GZ]
checksums = ['cd798112300b72298063d18463538a5a3ee12603cd9fc3f21fb81d033ba3e288']

moduleclass = 'data'
