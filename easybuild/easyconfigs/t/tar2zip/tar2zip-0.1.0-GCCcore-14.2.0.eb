easyblock = 'PythonPackage'

name = 'tar2zip'
version = '0.1.0'

homepage = 'https://github.com/c3se/tar2zip'
description = "Simple Python-based CLI tool to convert tar archive to uncompressed zip archives."

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

dependencies = [
    ('Python', '3.13.1'),
]

github_account = "c3se"
source_urls = ["https://github.com/%(github_account)s/%(name)s/archive/"]
sources = [V_VERSION_TAR_GZ]
checksums = []

moduleclass = 'data'
