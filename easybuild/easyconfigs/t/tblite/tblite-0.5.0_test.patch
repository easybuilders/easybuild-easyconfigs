This patch addresses the issue here:
https://github.com/tblite/tblite/issues/288
Author: J. Saßmannshausen (Imperial College London/UK)
diff --git a/tblite-0.5.0.orig/src/tblite/api/table.f90 b/tblite-0.5.0/src/tblite/api/table.f90
index 0c3741e..1509ee9 100644
--- a/tblite-0.5.0.orig/src/tblite/api/table.f90
+++ b/tblite-0.5.0/src/tblite/api/table.f90
@@ -244,7 +244,7 @@ subroutine table_set_char_api(verror, vtable, ckey, cval, n) &
 
    call c_f_pointer(vtable, table)
    call c_f_character(ckey, key)
-   call c_f_pointer(cval, carr, [strlen(cval)+1, min(n, 1)])
+   call c_f_pointer(cval, carr, [strlen(cval)+1, max(n, 1)])
 
    if (table%ptr%has_key(key)) call table%ptr%delete(key)
 
