easyblock = 'ConfigureMake'

name = 'tig'
version = '2.5.4'

homepage = 'https://jonas.github.io/tig/'
description = """Tig is an ncurses-based text-mode interface for git."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/jonas/tig/releases/download/tig-%(version)s/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['c48284d30287a6365f8a4750eb0b122e78689a1aef8ce1d2961b6843ac246aa7']

builddependencies = [
    ('binutils', '2.44'),
]

dependencies = [
    ('git', '2.50.1'),
    ('ncurses', '6.5'),
    ('libreadline', '8.2'),
]

sanity_check_paths = {
    'files': ['bin/tig', 'etc/tigrc'],
    'dirs': [],
}

moduleclass = 'tools'
