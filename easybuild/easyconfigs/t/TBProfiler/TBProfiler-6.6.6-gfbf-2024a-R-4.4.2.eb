easyblock = 'PythonBundle'

name = 'TBProfiler'
version = '6.6.6'
versionsuffix = '-R-%(rver)s'

homepage = 'https://github.com/jodyphelan/TBProfiler'
description = """
 Profiling tool for Mycobacterium tuberculosis to detect resistance and strain
 type from WGS data
"""

toolchain = {'name': 'gfbf', 'version': '2024a'}

builddependencies = [
    ('hatchling', '1.24.2'),
    ('poetry', '1.8.3'),
]

dependencies = [
    ('Python', '3.12.3'),
    ('Python-bundle-PyPI', '2024.06'),
    ('R', '4.4.2'),
    ('Trimmomatic', '0.40', '-Java-17', SYSTEM),
    ('BWA', '0.7.18'),
    ('minimap2', '2.29'),
    ('SAMtools', '1.21'),
    ('BCFtools', '1.21'),
    ('freebayes', '1.3.7', versionsuffix),
    ('tqdm', '4.66.5'),
    ('parallel', '20240722'),
    ('samclip', '0.4.0'),
    ('snpEff', '5.4c', '-Java-21'),
    ('Pysam', '0.22.1'),
    ('pydantic', '2.9.1'),
    ('SciPy-bundle', '2024.05'),
    ('python-docx', '1.2.0'),
    ('black', '25.9.0'),
