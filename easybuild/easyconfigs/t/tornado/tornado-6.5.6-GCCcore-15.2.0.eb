easyblock = "PythonPackage"

name = "tornado"
version = "6.5.6"

homepage = "https://github.com/tornadoweb/tornado"
description = "Tornado is a Python web framework and asynchronous networking library."

toolchain = {"name": "GCCcore", "version": "15.2.0"}

sources = [SOURCE_TAR_GZ]
patches = ['tornado-6.1_increase-default-timeouts.patch']
checksums = [
    {'tornado-6.5.6.tar.gz': '9a365179fe8ff6b8766f602c0f67c185d778193e9bdd828b19f0b6ed7764177d'},
    {'tornado-6.1_increase-default-timeouts.patch': '32e09dd8243acb8c55162f361880dc294d76770a7ff083c05aef6b8660e3bfb9'},
]

builddependencies = [
    ("binutils", "2.45"),
]
dependencies = [
    ("Python", "3.14.2"),
]

moduleclass = "lib"
