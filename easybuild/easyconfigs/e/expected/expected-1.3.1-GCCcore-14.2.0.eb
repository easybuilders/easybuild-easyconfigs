easyblock = 'CMakeMake'

name = 'expected'
version = '1.3.1'

homepage = 'https://github.com/TartanLlama/expected'
description = """Single header implementation of std::expected with functional-style extensions."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

source_urls = ['%s/archive/refs/tags/' % homepage]
sources = [V_VERSION_TAR_GZ]
checksums = ['9a04f4f472fbb5c30bf60402f1ca626c4a76987f867978d0b8a35d7ab3fb8fe7']

builddependencies = [
    ('make', '4.4.1'),
    ('CMake', '3.31.3'),
    ('Catch2', '3.8.1'),
    ('binutils', '2.42'),
]

sanity_check_paths = {
    'files': ['include/tl/expected.hpp'],
    'dirs': [],
}

moduleclass = 'lib'
