# Written by Tom Strempel <tom.strempel@ufz.de>, updated by Ben Langenberg <ben.langenberg@ufz.de>
# Updated by Stamen Miroslavov <stamen.miroslavov@bsc.es>, BSC 2025

easyblock = 'CMakeMake'

name = 'ecFlow'
version = '5.15.8'

homepage = 'https://confluence.ecmwf.int/display/ECFLOW/ecflow+home'
description = """ecFlow is a work flow package that enables users to run a large number of programs
 (with dependencies on each other and on time) in a controlled environment. It provides tolerance
 for hardware and software failures, combined with good restart capabilities. It is used at ECMWF
 to run all our operational suites across a range of platforms."""

toolchain = {'name': 'foss', 'version': '2023b'}

source_urls = ['https://confluence.ecmwf.int/download/attachments/8650755/']
sources = ['%(name)s-%(version)s-Source.tar.gz']
checksums = ['11e1b693fc8f6aa834fc5a9c34503573f6391464b1c21d5023e4726c79aa9df1']

builddependencies = [
    ('CMake', '3.27.6'),
    ('Doxygen', '1.9.8'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Boost', '1.83.0'),
    ('Boost.Python', '1.83.0'),
    ('Qt5', '5.15.13'),
]

configopts = '-DENABLE_GUI=False -DENABLE_SERVER=True -DENABLE_STATIC_BOOST_LIBS=True '
configopts += '-DBOOST_ROOT=$EBROOTBOOST '
configopts += '-DBoost_PYTHON311_LIBRARY_RELEASE=$EBROOTBOOSTPYTHON/lib/libboost_python311.so '
prebuildopts = 'export LDFLAGS="$LDFLAGS -lssl" && '

sanity_check_paths = {
    'files': ['bin/ecflow_client', 'bin/ecflow_server'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/ecflow', 'share/ecflow/etc'],
}

sanity_check_commands = [
    "ecflow_client --help",
    "python -c 'import ecflow'",
]

moduleclass = 'vis'
