easyblock = 'PythonBundle'

name = 'eccodes-python'
version = '2.40.0'

homepage = 'https://github.com/ecmwf/eccodes-python'
description = "Python 3 interface to decode and encode GRIB and BUFR files via the ECMWF ecCodes library."

toolchain = {'name': 'foss', 'version': '2023b'}

dependencies = [
    ('Python', '3.11.5'),
    ('SciPy-bundle', '2023.11'),
    ('ecCodes', '2.40.0'),
]

exts_list = [
    ('findlibs', '0.1.0', {
        'checksums': ['2d458b844c7044a75f68d909a0f6ca5a598fdec895a0e009a7f6cde0905de659'],
    }),
    (name, version, {
        'modulename': 'eccodes',
        'github_account': 'ecmwf',
        'source_urls': ['https://github.com/ecmwf/eccodes-python/archive/refs/tags'],
        'source_tmpl': '%(version)s.tar.gz',
        'checksums': ['d983e06bd6607b8d8b7d633879917854196cd584a46fcec1fd1d1577b88159ed'],
    }),
]

moduleclass = 'tools'
