easyblock = 'ConfigureMake'

name = 'elfutils'
version = '0.195'

homepage = 'https://elfutils.org/'

description = """
 The elfutils project provides libraries and tools for ELF files
 and DWARF data.
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://sourceware.org/elfutils/ftp/%(version)s/']
sources = [SOURCE_TAR_BZ2]
checksums = ['37629fdf7f1f3dc2818e138fca2b8094177d6c2d0f701d3bb650a561218dc026']

builddependencies = [
    ('M4', '1.4.20'),
    ('pkgconf', '2.5.1'),
]

dependencies = [
    ('binutils', '2.45'),
    ('bzip2', '1.0.8'),
    ('libarchive', '3.8.5'),
    ('XZ', '5.8.2'),
    ('zstd', '1.5.7'),
]

configopts = "--disable-debuginfod --disable-libdebuginfod"

local_libs = ['libelf', 'libdw']
sanity_check_paths = {
    'files': ['bin/eu-elfcmp', 'include/dwarf.h'] + [f'lib/{lib}.{ext}'
                                                     for lib in local_libs for ext in ('a', SHLIB_EXT)],
    'dirs': []
}

sanity_check_commands = ["eu-elfcmp --help"]

moduleclass = 'lib'
