easyblock = 'PythonBundle'

name = 'EES-bundle'
version = '2024a'

homepage = 'https://ees.kuleuven.be'
description = "Bundle of Python packages commonly used by department of Earth and Environmental Sciences"

toolchain = {'name': 'gfbf', 'version': '2024a'}

builddependencies = [
    ('poetry', '1.8.3'),
]

dependencies = [
    ('Python', '3.12.3'),
    ('Python-bundle-PyPI', '2024.06'),
    ('SciPy-bundle', '2024.05'),
    ('PyYAML', '6.0.2'),
    ('SQLAlchemy', '2.0.36'),
    ('BeautifulSoup', '4.12.3'),
]

