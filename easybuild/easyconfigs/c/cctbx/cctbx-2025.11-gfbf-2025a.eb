# Author: J. Saßmannshausen (Imperial College London/UK)
# We are using the whl here as building the source seems
# not straight forward. 

easyblock = 'PythonBundle'

name = 'cctbx'
version = '2025.11'

homepage = 'https://github.com/cctbx/cctbx_project'
description = """
The Computational Crystallography Toolbox (cctbx) is being developed as the
open source component of the Phenix project. The goal of the Phenix project
is to advance automation of macromolecular structure determination.
Phenix depends on the cctbx, but not vice versa.
This hierarchical approach enforces a clean design as a reusable library.
The cctbx is therefore also useful for small-molecule crystallography and
even general scientific applications.
"""

toolchain = {'name': 'gfbf', 'version': '2025a'}

builddependencies = [
    ('binutils', '2.42'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('IPython', '9.3.0'),
    ('wxPython', '4.2.5'),
    ('matplotlib', '3.10.3'),
    ('mrcfile', '1.5.4'),
]

exts_list = [
    ('cctbx_base', version, {
        'modulename': 'libtbx',
        'source_tmpl': '%(name)s-%(version)s-cp313-cp313-manylinux_2_28_x86_64.whl',
        'checksums': ['728e1f9cb83eb55672440f1d58c8d63a68b2543893f417a743c75051cac86ac3'],
    }),
    (name, version, {
        'source_tmpl': '%(name)s-%(version)s-py3-none-any.whl',
        'checksums': ['645dd9a648336da907e4c4d604e433c9d6112fe5adcf8657d4a93eb06c9fb515'],
    }),
]

modextrapaths = {'LIBTBX_BUILD': ['lib/python%(pyshortver)s/site-packages/libtbx/core/share/cctbx']}

moduleclass = 'chem'
