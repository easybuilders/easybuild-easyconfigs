easyblock = 'CMakeMake'

name = 'CP2K'
version = '2026.1'

homepage = 'https://www.cp2k.org/'
description = """CP2K is a freely available (GPL) program, written in Fortran 95, to perform atomistic and molecular
 simulations of solid state, liquid, molecular and biological systems. It provides a general framework for different
 methods such as e.g. density functional theory (DFT) using a mixed Gaussian and plane waves approach (GPW), and
 classical pair and many-body potentials. """

toolchain = {'name': 'foss', 'version': '2024a'}
toolchainopts = {'pic': True, 'openmp': True}

source_urls = ['https://github.com/%(namelower)s/%(namelower)s/releases/download/v%(version)s']
sources = [SOURCELOWER_TAR_BZ2]
checksums = ['4364c74bcffaa474bc234e11686b09550e4d06932acf2147a341e4f7679dd88e']

builddependencies = [
    ('CMake', '3.31.8'),
    ('pkgconf', '2.2.0'),
]

dependencies = [
    ('DBCSR', '2.9.1'),
    ('ELPA', '2024.05.001'),
    ('HDF5', '1.14.5'),
    ('Libint', '2.11.1', '-lmax-6-cp2k'),
    ('libxc', '7.0.0'),
    ('libxsmm', '1.17'),
    ('libvori', '220621'),
    ('PLUMED', '2.9.3'),
    ('SIRIUS', '7.8.0'),
    ('spglib', '2.6.0'),
]

configopts = ' '.join([
    '-DCP2K_BLAS_VENDOR=FlexiBLAS',
    '-DCP2K_USE_MPI=ON',
    '-DCP2K_USE_MPI_F08=ON',
    '-DCP2K_USE_ELPA=ON',
    '-DCP2K_USE_FFTW3=ON',
    '-DCP2K_USE_HDF5=ON',
    '-DCP2K_USE_LIBINT2=ON',
    '-DCP2K_USE_LIBXC=ON',
    '-DCP2K_USE_LIBXSMM=ON',
    '-DCP2K_USE_VORI=ON',
    '-DCP2K_USE_PLUMED=ON',
    '-DCP2K_USE_SIRIUS=ON',
    '-DCP2K_USE_SPGLIB=ON',
    '-DCP2K_USE_SPLA=ON',
])

# libxsmm library not propagating correctly to these
prebuildopts = ' && '.join([
    "sed -i 's/$/ -lxsmm/' src/CMakeFiles/dbm_miniapp.dir/link.txt",
    "sed -i 's/$/ -lxsmm/' src/CMakeFiles/grid_miniapp.dir/link.txt",
    "sed -i 's/$/ -lxsmm/' src/CMakeFiles/grid_unittest.dir/link.txt",
    ""
])

# tar xf cp2k-2026.1.tar.bz2
# cd cp2k-2026.1/tests
# ./do_regtest.py --mpiranks 4 --ompthreads 4 --maxtasks 16 --num_gpus 0 --mpiexec="mpirun -n {N} " --cp2kdatadir $EBROOTCP2K/share/cp2k/data --workbasedir work $EBROOTCP2K/bin psmp

sanity_check_paths = {
    'files': ['bin/%(namelower)s.psmp'],
    'dirs': ['share/cp2k/data'],
}

moduleclass = 'chem'
