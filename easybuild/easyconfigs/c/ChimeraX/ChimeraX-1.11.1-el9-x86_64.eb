easyblock = 'Rpm'

name = 'ChimeraX'
version = '1.11.1'
versionsuffix = '-el9-x86_64'

homepage = 'https://www.rbvi.ucsf.edu/chimerax/'
description = """
UCSF ChimeraX is a molecular visualization and analysis program for interactive
display and analysis of molecular structures and related data.
"""

toolchain = SYSTEM

builddependencies = [
    ('rpmrebuild', '2.18', '', SYSTEM),
]

source_urls = ['https://www.rbvi.ucsf.edu/chimerax/cgi-bin/secure/chimerax-get.py?file=current/centos-9']
sources = ['chimerax-techpreview-el9.rpm']
checksums = ['46c4716f622eda82bb3367da1a07856f405fe1bb3e3115913672036552d97780']

download_instructions = """Automatic download may fail because UCSF uses a click-through agreement page
that requires interactive browser acceptance.

Manual download workflow:
1) Open https://www.rbvi.ucsf.edu/chimerax/download.html in a browser.
2) Choose "Technology Preview Build" -> "Red Hat 9 and derivatives (Linux x86-64)".
3) Click Accept/Download and save:
    chimerax-techpreview.rpm    --> rename chimerax-techpreview-el9.rpm
4) Verify checksum:
    sha256sum chimerax-techpreview.rpm
    expected: 46c4716f622eda82bb3367da1a07856f405fe1bb3e3115913672036552d97780
5) Place file in EasyBuild source path, e.g.:
    /apps/easybuild/sources/c/ChimeraX/

Then rerun EasyBuild.
"""

sanity_check_paths = {
    'files': ['usr/bin/chimerax'],
    'dirs': [],
}

moduleclass = 'bio'

