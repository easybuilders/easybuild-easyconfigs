easyblock = 'PythonBundle'

name = 'cython-cmake'
version = '0.2.2'

homepage = 'https://github.com/scikit-build/cython-cmake'
description = """
Custom CMake rules to generate the source code
for a Python extension module using cython
"""
docurls = ['https://github.com/scikit-build/cython-cmake']

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

builddependencies = [
    ('CMake', '4.0.3'),
    ('binutils', '2.44'),
    ('hatchling', '1.27.0'),
]

dependencies = [
    ('Python', '3.13.5'),
    ('Cython', '3.1.2'),
    ('flit', '3.12.0'),
]

exts_list = [
    (name, version, {
        'sources': ['cython_cmake-%(version)s.tar.gz'],
        'checksums': ['f3a101409d431b6138b936c26d16fe213b241626063efa2e4968471cd7f0adec'],
    }),
]

moduleclass = 'devel'
