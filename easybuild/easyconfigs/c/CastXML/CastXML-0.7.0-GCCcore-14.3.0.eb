easyblock = 'CMakeMake'

name = 'CastXML'
version = '0.7.0'

homepage = 'https://github.com/CastXML/CastXML'
description = """CastXML is a C-family abstract syntax tree XML output tool."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

github_account = 'CastXML'
source_urls = [GITHUB_SOURCE]
sources = ['v%(version)s.tar.gz']
checksums = ['e70728229db5444384befcba9681a01497e9a19e35166ce1ffef3b5cbc8eeefe']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
]

dependencies = [
    ('LLVM', '20.1.8'),
    ('ncurses', '6.5'),
    ('zlib', '1.3.1'),
]

sanity_check_paths = {
    'files': ['bin/castxml'],
    'dirs': ['share/castxml'],
}

moduleclass = 'tools'
