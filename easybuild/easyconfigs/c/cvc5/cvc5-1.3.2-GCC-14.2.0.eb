easyblock = 'CMakeMake'

name = 'cvc5'
version = '1.3.2'

homepage = 'https://cvc5.github.io/'

description = """
cvc5 is an efficient open-source automatic theorem prover for Satisfiability Modulo Theories
(SMT) problems. It can be used to prove the satisfiability (or, dually, the validity) of
first-order formulas with respect to (combinations of) a variety of useful background
theories.It further provides a Syntax-Guided Synthesis (SyGuS) engine to synthesize functions
with respect to background theories and their combinations.
cvc5 is the successor of CVC4 and is intended to be an open and extensible SMT engine.
"""

toolchain = {'name': 'GCC', 'version': '14.2.0'}

github_account = 'cvc5'
source_urls = [GITHUB_SOURCE]
sources = [SOURCE_TAR_GZ]
checksums = ['85a9cc4e1f80efcdb235e89c9f361c74b1089023ceb43f38c2d5e73a4e2db47e']

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.31.3'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('Python-bundle-PyPI', '2025.04'),
    ('GMP', '6.3.0'),
    ('CaDiCaL', '2.1.3'),
    ('SymFPU', '20190518'),
]

build_type = 'Production'

sanity_check_paths = {
    "files": ['bin/cvc5'],
    "dirs": ['bin', 'include', 'lib'],
}

sanity_check_commands = ["cvc5 --help 2>&1 | grep 'cvc5 options'"]

moduleclass = 'math'
