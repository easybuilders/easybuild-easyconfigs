This patch fixes the pyproject file to allow a proper build via poetry
Author: Stamen Miroslavov Minkov <stamen.miroslavov@bsc.es>
Barcelona Supercomputing Center 2025
diff -ruBbw a/pyproject.toml b/pyproject.toml
--- a/pyproject.toml	1970-01-01 01:00:00.000000000 +0100
+++ b/pyproject.toml	2025-05-13 13:07:50.723985964 +0200
@@ -1,8 +1,8 @@
-[project]
+[tool.poetry]
 name = "copernicusmarine"
 version = "2.0.1"
 description = "Command line interface and Python API for accessing Copernicus Marine data and related services."
-authors = [{ name = "Copernicus Marine User Support", email = "servicedesk.cmems@mercator-ocean.eu" }]
+authors = ["Copernicus Marine User Support <servicedesk.cmems@mercator-ocean.eu>"]
 readme = "README.md"
 packages = [{include = "copernicusmarine"}]
 license = "EUPL-1.2"
@@ -26,7 +26,7 @@
 pydantic = "^2.9.1"
 h5netcdf = "^1.4.0"
 
-[project.scripts]
+[tool.poetry.scripts]
 copernicusmarine = 'copernicusmarine.command_line_interface.copernicus_marine:command_line_interface'
 
 [tool.poetry.group.dev.dependencies]
