easyblock = 'PythonBundle'

name = 'copernicusmarine'
version = '2.0.1'

homepage = 'https://help.marine.copernicus.eu/en/articles/7949409-copernicus-marine-toolbox-introduction'
description = """The Copernicus Marine Toolbox is a free and easy-to-use tool that interoperates
 with the Copernicus Marine Data Store intending to cover any use case, from retrieval of metadata
 to a complete dataset, or just a subset, for any type of product: numerical models, satellite
 and/or in situ observations."""

toolchain = {'name': 'foss', 'version': '2023b'}
toolchainopts = {'pic': True}

builddependencies = [
    ('binutils', '2.40'),
    ('hatchling', '1.18.0'),
    ('poetry', '1.7.1'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('tqdm', '4.66.2'),
    ('lxml', '4.9.3'),
    ('aiohttp', '3.9.5'),
    ('pydantic', '2.7.4'),
    ('zarr', '2.18.3'),
    ('netcdf4-python', '1.7.1.post2'),
    ('h5netcdf', '1.5.0'),
    ('xarray', '2024.5.0'),
    ('dask', '2024.5.1'),
    ('boto3', '1.36.16'),
    ('GLib', '2.78.1'),  # fixes libmount
]

exts_list = [
    ('portalocker', '3.1.1', {
        'checksums': ['ec20f6dda2ad9ce89fa399a5f31f4f1495f515958f0cb7ca6543cef7bb5a749e'],
    }),
    ('watchdog', '6.0.0', {
        'checksums': ['9ddf7c82fda3ae8e24decda1338ede66e1c99883db93711d8fb941eaa2d8c282'],
    }),
    ('cachier', '3.1.2', {
        'checksums': ['8ef53b6ae83ba04d8864d2e1f45eb8b46eecb611d0f6a24c006e8fda074c6557'],
    }),
    ('semver', '3.0.2', {
        'checksums': ['6253adb39c70f6e51afed2fa7152bcd414c411286088fb4b9effb133885ab4cc'],
    }),
    ('nest_asyncio', '1.6.0', {
        'checksums': ['6f172d5449aca15afd6c646851f4e31e02c598d553a667e38cafa997cfec55fe'],
    }),
    ('pystac', '1.12.2', {
        'checksums': ['13a9926fdc6f5a0c81a6bcf5748d3e46fd8814b888936b94fd6d8ca6caf0c20d'],
    }),
    (name, version, {
        'patches': ['copernicusmarine-2.0.1_poetry-build.patch'],
        'checksums': [
            # copernicusmarine-2.0.1.tar.gz
            'badbc5a9aa3d2c7d5952762447fda7b577467e186fd8607b29bbc6ce850f30e4',
            # copernicusmarine-2.0.1_poetry-build.patch
            '83f3ac849057c94baf8676ee75eaede0984bbd102888eabecde62500a50157f2',
        ],
    }),
]

sanity_check_paths = {
    'files': ['bin/copernicusmarine'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

moduleclass = 'geo'
