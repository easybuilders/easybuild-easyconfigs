easyblock = 'CMakeNinja'

name = 'CLI11'
version = '2.6.2'

homepage = 'https://github.com/CLIUtils/CLI11'
description = """CLI11 is a command line parser for C++11 and beyond that provides a rich feature set with a simple and
intuitive interface."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/CLIUtils/CLI11/archive/refs/tags/']
sources = [V_VERSION_TAR_GZ]
checksums = ['c6ea6b2e5608b3ea8617999bd5f47420c71b2ebdb8dc4767c1034d1da5785711']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
    ('Ninja', '1.13.0'),
]

sanity_check_paths = {
    'files': ['include/CLI/CLI.hpp'],
    'dirs': [],
}

moduleclass = 'lib'
