easyblock = 'PythonBundle'

name = 'coremltools'
version = '8.3.0'

homepage = 'https://apple.github.io/coremltools/'
description = """Convert models from TensorFlow, PyTorch, and other libraries to Core ML."""

toolchain = {'name': 'foss', 'version': '2023a'}

builddependencies = [
    ('hatchling', '1.18.0'),
]


dependencies = [
    ('Python', '3.11.3'),
    ('protobuf-python', '4.24.0'),
    ('Python-bundle-PyPI', '2023.06'),
    ('SciPy-bundle', '2023.07'),
    ('sympy', '1.12'),
    ('tqdm', '4.66.1'),
    ('pretty-yaml', '24.7.0'),
]

exts_list = [
    ('cattrs', '24.1.3', {
        'checksums': ['981a6ef05875b5bb0c7fb68885546186d306f10f0f6718fe9b96c226e68821ff'],
    }),
    (name, version, {
        'checksums': ['c95a6051606b71273d669b107b5f32d3191f595e6821b8db04baf49d52d0704f'],
    }),
]

moduleclass = 'ai'
