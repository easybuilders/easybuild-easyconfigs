easyblock = 'CMakeMake'
name = 'CGAL'
version = '6.2'

homepage = 'https://www.cgal.org/'
description = """The goal of the CGAL Open Source Project is to provide easy access to efficient
 and reliable geometric algorithms in the form of a C++ library."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'strict': True}

source_urls = ['https://github.com/CGAL/cgal/releases/download/v%(version)s/']
sources = [SOURCE_TAR_XZ]
checksums = ['fbc32816745e871a5cbdeb6245317e9dbf10ae1a957b0ab1edb00b4fde00ba8d']

builddependencies = [
    ('CMake', '4.2.1'),
    ('binutils', '2.45'),
]

sanity_check_paths = {
    'files': ['include/CGAL/Simple_cartesian.h'],
    'dirs': ['include/CGAL', 'lib/cmake/CGAL'],
}

moduleclass = 'numlib'
