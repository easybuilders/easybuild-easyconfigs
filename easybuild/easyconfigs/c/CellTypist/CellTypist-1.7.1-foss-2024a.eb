easyblock = 'PythonBundle'

name = 'CellTypist'
version = '1.7.1'

homepage = 'https://www.celltypist.org/'
description = "A tool for semi-automatic cell type annotation"

toolchain = {'name': 'foss', 'version': '2024a'}

dependencies = [
    ('Python', '3.12.3'),
    ('SciPy-bundle', '2024.05'),
    ('scikit-learn', '1.5.2'),
    ('openpyxl', '3.1.5'),
    ('scanpy', '1.10.4'),
    ('leidenalg', '0.10.2'),
]

exts_list = [
    ('%(namelower)s', version, {
        'checksums': ['6ffaebc0f296d24785ffce25951ad70a00553bd8d06aff2f55f98251b739ce00'],
    }),
]

sanity_check_paths = {
    'files': ['bin/celltypist'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = ["celltypist --help"]

moduleclass = 'bio'
