easyblock = 'PythonBundle'

name = 'Cartopy'
version = '0.25.0'

homepage = 'https://scitools.org.uk/cartopy/docs/latest/'
description = """Cartopy is a Python package designed to make drawing maps for data analysis and visualisation easy."""

