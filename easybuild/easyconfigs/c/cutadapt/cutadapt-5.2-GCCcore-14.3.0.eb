easyblock = 'PythonBundle'

name = 'cutadapt'
version = '5.2'

homepage = 'https://opensource.scilifelab.se/projects/cutadapt/'
description = """Cutadapt finds and removes adapter sequences, primers, poly-A tails and
 other types of unwanted sequence from your high-throughput sequencing reads."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

builddependencies = [
    ('binutils', '2.44'),
    ('Cython', '3.2.4'),  # required for dnaio
]

dependencies = [
    ('Python', '3.13.5'),
    ('xopen', '2.1.0'),
]

exts_list = [
    ('dnaio', '1.2.4', {
        'checksums': ['a7570311f29e8b3c1ea39a60f57b7baf8dad8f2508595c58d4278c5571463166'],
    }),
    (name, version, {
        'checksums': ['2394deead42ecae5fe0fdf369e35f3e2afed770e14059582272779c2e8295d3c'],
    }),
]

sanity_check_paths = {
    'files': ['bin/cutadapt'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = [
    "cutadapt --help",
    "cutadapt --version",
]

moduleclass = 'bio'
