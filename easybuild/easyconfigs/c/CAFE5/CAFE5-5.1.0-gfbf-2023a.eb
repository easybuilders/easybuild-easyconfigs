easyblock = 'ConfigureMake'

name = 'CAFE5'
version = '5.1.0'

homepage = 'https://www.domain.org'
description = """
The purpose of CAFE is to analyze changes in gene family size in a way that accounts for phylogenetic history and
provides a statistical foundation for evolutionary inferences. The program uses a birth and death process to model
gene gain and loss across a user-specified phylogenetic tree. The distribution of family sizes generated under this
model can provide a basis for assessing the significance of the observed family size differences among taxa.
"""

toolchain = {'name': 'gfbf', 'version': '2023a'}

source_urls = ['https://github.com/hahnlab/CAFE5/releases/download/v5.1']
sources = [SOURCE_TAR_GZ]
checksums = ['71871bdc74c2ffc7c1c0f4500f4742f2ff46a15cfaba78dc179d21bb1ba67ba8']

builddependencies = [
    ('binutils', '2.40'),
    ('make', '4.4.1'),
]

preconfigopts = "sed -i 's/openblas/flexiblas/' configure &&"

install_cmd = 'cp'
installopts = '-r bin %(installdir)s'

sanity_check_paths = {
    'files': ['bin/%(namelower)s'],
    'dirs': [],
}

sanity_check_commands = [
    "%(namelower)s -v",
    "%(namelower)s -h",
]

moduleclass = 'bio'
