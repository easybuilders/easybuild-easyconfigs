easyblock = 'Bundle'

name = 'cage'
version = '0.2.1'

homepage = 'https://www.hjdskes.nl/projects/cage/'
description = 'This is Cage, a Wayland kiosk. A kiosk runs a single, maximized application.'

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}
toolchainopts = {'extra_cflags': '-Wno-error=unused-variable -Wno-error=unused-but-set-variable -Wno-error=return-type'}

builddependencies = [
    ('binutils', '2.44'),
    ('Meson', '1.8.2'),
    ('Ninja', '1.13.0'),
    ('hwdata', '0.403'),
]

dependencies = [
    ('Wayland', '1.24.0'),
    ('Xwayland', '24.1.9'),
    ('libinput', '1.30.1'),
    ('libsfdo', '0.1.4'),
    # wlroots part
    ('OpenGL', '2025.09'),
    ('Vulkan', '1.4.328'),
    ('glslang-SPIRV', '15.4.0'),
    ('cairo', '1.18.4'),
    ('pixman', '0.46.4'),
    ('LittleCMS', '2.17'),
    # for DRM, session, input support
    ('libdrm', '2.4.125'),
    ('libdisplay-info', '0.3.0'),
    ('libliftoff', '0.5.0'),
    ('seatd', '0.9.2'),
]

default_easyblock = 'MesonNinja'

default_component_specs = {
    'sources': [SOURCELOWER_TAR_GZ],
    'start_dir': '%(name)s-%(version)s',
}

components = [
    ('wlroots', '0.19.2', {
        'source_urls': ['https://gitlab.freedesktop.org/wlroots/wlroots/-/releases/%(version)s/downloads/'],
        'sources': [SOURCE_TAR_GZ],
        'checksums': ['09a0a8d60104c8b0772fee4f60ba76a89aed7e59dff7659d00960fba06bdf267'],
    }),
    (name, version, {
        'source_urls': ['https://github.com/cage-kiosk/cage/releases/download/v%(version)s/'],
        'sources': [SOURCE_TAR_GZ],
        'checksums': ['fc1238e3aa5b82787a95d49cb3e1bac0671e4d3a40090087848f43f3e1f63a98'],
    }),
]

sanity_check_paths = {
    'files': ['bin/cage'],
    'dirs': [],
}

sanity_check_commands = ['cage -v']

moduleclass = 'vis'
