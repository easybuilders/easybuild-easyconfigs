easyblock = 'JuliaBundle'

name = 'ChunkCodec'
version = '1.0.1'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/JuliaIO/ChunkCodecs.jl'
description = "A consistent Julia interface for lossless encoding and decoding of bytes in memory."

toolchain = SYSTEM

