easyblock = 'PythonBundle'

name = 'cffi'
version = '2.0.0'

homepage = 'https://cffi.readthedocs.io/en/latest/'
description = """C Foreign Function Interface for Python. Interact with almost any C code from
Python, based on C-like declarations that you can often copy-paste from header
files or documentation.
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

builddependencies = [('binutils', '2.45')]
dependencies = [('Python', '3.14.2')]

exts_list = [
    ('pycparser', '3.0', {
        'checksums': ['600f49d217304a5902ac3c37e1281c9fe94e4d0489de643a9504c5cdfdfc6b29'],
    }),
    (name, version, {
        'checksums': ['44d1b5909021139fe36001ae048dbdde8214afa20200eda0f64c068cac5d5529'],
    }),
]

moduleclass = 'tools'
