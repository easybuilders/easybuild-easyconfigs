easyblock = 'PythonPackage'

name = 'CheckM'
version = '1.2.5'

homepage = 'https://github.com/Ecogenomics/CheckM'
description = """CheckM provides a set of tools for assessing the quality of genomes recovered from isolates,
 single cells, or metagenomes."""

toolchain = {'name': 'foss', 'version': '2025b'}

source_urls = ['https://github.com/Ecogenomics/CheckM/archive']
sources = ['v%(version)s.tar.gz']
patches = ['CheckM-%(version)s_drop_setuptools_requirement.patch']
checksums = [
    {'v1.2.5.tar.gz': '95e7245642fd5fe1ae647066486e3be66d0112d9bd3b66b668c33f93c505d4b1'},
    {'CheckM-1.2.5_drop_setuptools_requirement.patch':
     '9d3da3c368b85fae3a2ce85079c1444caee96dc0b330c3c77944ce9aaf0d268a'},
]

# Dependencies:
# https://github.com/Ecogenomics/CheckM/blob/master/setup.py
dependencies = [
    ('Python', '3.13.5'),
    ('SciPy-bundle', '2025.07'),  # numpy
    ('pplacer', '1.1.alpha19', '', SYSTEM),
    ('prodigal', '2.6.3'),
    ('HMMER', '3.4'),
    ('matplotlib', '3.10.5'),
    ('Pysam', '0.23.3'),
    ('DendroPy', '5.0.8'),
    ('CheckM-Database', '2015_01_16', '', SYSTEM),
]

sanity_check_paths = {
    'files': ['bin/checkm'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

sanity_check_commands = ["checkm test %(builddir)s/checkm_test_results"]

moduleclass = 'bio'
