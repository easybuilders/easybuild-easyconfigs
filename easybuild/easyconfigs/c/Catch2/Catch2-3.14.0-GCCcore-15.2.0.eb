easyblock = 'CMakeMake'

name = 'Catch2'
version = '3.14.0'

homepage = 'https://github.com/catchorg/Catch2'
description = """A modern, C++-native, header-only,
 test framework for unit-tests, TDD and BDD
 - using C++11, C++14, C++17 and later
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/catchorg/Catch2/archive/']
sources = ['v%(version)s.tar.gz']
checksums = ['ba2a939efead3c833c499cf487e185762f419a71d30158cd1b43c6079c586490']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

sanity_check_paths = {
    'files': ['include/catch2/catch_all.hpp'],
    'dirs':  ['lib/cmake'],
}

moduleclass = 'lib'
