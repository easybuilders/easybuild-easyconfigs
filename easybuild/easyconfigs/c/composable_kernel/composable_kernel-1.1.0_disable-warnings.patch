This patch comments out `EnableCompilerWarnings` and explicitly adds `-Wno-error` and `-Wno-unused-parameter`
to allow the build to complete. It should be re-evaluated for future `composable_kernel` releases once upstream
resolves the underlying warnings or relaxes their default compiler flags.

Author: Aayush Joglekar (aayush.joglekar@surf.nl)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1fe1bc91d..c41322e02 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -381,7 +381,7 @@ else()
 endif()
 
 ## tidy
-include(EnableCompilerWarnings)
+# include(EnableCompilerWarnings)
 set(CK_TIDY_ERRORS ERRORS * -readability-inconsistent-declaration-parameter-name)
 if(CMAKE_CXX_COMPILER MATCHES ".*hcc" OR CMAKE_CXX_COMPILER MATCHES ".*clang\\+\\+")
     set(CK_TIDY_CHECKS -modernize-use-override -readability-non-const-parameter)
@@ -534,6 +534,7 @@ include_directories(BEFORE
 )
 
 SET(BUILD_DEV ON CACHE BOOL "BUILD_DEV")
+add_compile_options(-Wno-error -Wno-unused-parameter)
 if(BUILD_DEV)
     add_compile_options(-Werror)
     add_compile_options(-Weverything)