# Barcelona Supercomputing Center 2024

easyblock = 'PythonPackage'

name = 'colorcet'
version = '3.1.0'

homepage = 'https://github.com/holoviz/colorcet'
description = """Colorcet is a collection of perceptually uniform colormaps for use with Python
 plotting programs like bokeh, matplotlib, holoviews, and datashader based on the set of
 perceptually uniform colormaps created by Peter Kovesi at the Center for Exploration Targeting."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['2921b3cd81a2288aaf2d63dbc0ce3c26dcd882e8c389cc505d6886bf7aa9a4eb']

builddependencies = [
    ('binutils', '2.40'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
]

moduleclass = 'lib'
