# ll4strw Lorentz Institute
easyblock = 'CMakeMake'

name = 'cppzmq'
version = '4.11.0'

homepage = 'https://github.com/zeromq/cppzmq'
description = "cppzmq is a C++ binding for libzmq."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/zeromq/%(name)s/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
checksums = ['0fff4ff311a7c88fdb76fceefba0e180232d56984f577db371d505e4d4c91afd']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
    ('ZeroMQ', '4.3.5'),
]

sanity_check_paths = {
    'files': ['include/zmq.hpp'],
    'dirs': ['include', 'lib'],
}

moduleclass = 'lib'
