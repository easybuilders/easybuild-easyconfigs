easyblock = 'PythonBundle'

name = 'csvkit'
version = '2.2.0'

homepage = 'https://github.com/wireservice/csvkit'
description = """csvkit is a suite of command-line tools for converting to and working with CSV,
 the king of tabular file formats."""

toolchain = {'name': 'GCCcore', 'version': '13.3.0'}

builddependencies = [
    ('binutils', '2.42')
]

dependencies = [
    ('Python', '3.12.3'),
    ('Python-bundle-PyPI', '2024.06'),
    ('python-slugify', '8.0.4'),
    ('openpyxl', '3.1.5'),
    ('SQLAlchemy', '2.0.36'),
]

fix_python_shebang_for = ['bin/*']

exts_list = [
    ('pytimeparse', '1.1.8', {
        'checksums': ['e86136477be924d7e670646a98561957e8ca7308d44841e21f5ddea757556a0a'],
    }),
    ('parsedatetime', '2.6', {
        'checksums': ['4cb368fbb18a0b7231f4d76119165451c8d2e35951455dfee97c62a87b04d455'],
    }),
    ('isodate', '0.7.2', {
        'checksums': ['4cd1aa0f43ca76f4a6c6c0292a85f40b35ec2e43e315b59f06e6d32171a953e6'],
    }),
    ('leather', '0.4.1', {
        'checksums': ['67119c2aee93be821f077193bd8534e296c05b38bd174d9c5a80c4aa31d1a4d3'],
    }),
    ('agate', '1.14.2', {
        'checksums': ['7f29841c39d84b1de7fde762b8d792085371515324f3a01413b20f810398225b'],
    }),
    ('olefile', '0.47', {
        'source_tmpl': '%(name)s-%(version)s.zip',
        'checksums': ['599383381a0bf3dfbd932ca0ca6515acd174ed48870cbf7fee123d698c192c1c'],
    }),
    ('agate-excel', '0.4.2', {
        'modulename': 'agateexcel',
        'checksums': ['eed1dc6239f0e96720d962dc1bdfb4496e19687332c827fd8b1e587a917ea202'],
    }),
    ('dbfread', '2.0.7', {
        'checksums': ['07c8a9af06ffad3f6f03e8fe91ad7d2733e31a26d2b72c4dd4cfbae07ee3b73d'],
    }),
    ('agate-dbf', '0.2.4', {
        'modulename': 'agatedbf',
        'checksums': ['6554828b10048a76dbb5bc4eff8911e059ea2b47155b7a89351e382915ca16fc'],
    }),
    ('agate-sql', '0.7.3', {
        'modulename': 'agatesql',
        'checksums': ['4c588a28e80bc625c7d5f915e8f8dff4900140a8a6d8a350a098a2ba9adf9d33'],
    }),
    (name, version, {
        'checksums': ['147318a8dbaec07c0bbb9291c14b78de5fa32ed3d4a5c2396e52a83c0a30df6b'],
    }),
]

local_binaries = ['in2csv', 'sql2csv', 'csvclean', 'csvcut', 'csvgrep', 'csvjoin', 'csvsort', 'csvstack', 'csvformat',
                  'csvjson', 'csvlook', 'csvpy', 'csvsql', 'csvstat']

sanity_check_paths = {
    'files': ['bin/%s' % x for x in local_binaries],
    'dirs': ['lib/python%(pyshortver)s/site-packages/'],
}

sanity_check_commands = [('csvlook', '-h')]

moduleclass = 'tools'
