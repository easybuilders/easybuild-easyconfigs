# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025

easyblock = 'PythonPackage'

name = 'chromedriver-py'
version = '133.0.6943.53'
versionsuffix = '-Python-%(pyver)s'

homepage = 'https://github.com/breuerfelix/chromedriver-py'
description = """Chromedriver-py downloads and installs the latest chromedriver binary version for
 automated testing of webapps.The installer supports linux, mac and windows operating systems."""

toolchain = {'name': 'foss', 'version': '2023b'}

source_urls = [PYPI_SOURCE]
sources = ['chromedriver_py-%(version)s.tar.gz']
checksums = ['dec28aa48615799706e40ac61ee22e9a615548dc41133e79dcc00681a48a104e']

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('selenium', '4.32.0'),
]

options = {'modulename': 'chromedriver_py'}

moduleclass = 'lib'
