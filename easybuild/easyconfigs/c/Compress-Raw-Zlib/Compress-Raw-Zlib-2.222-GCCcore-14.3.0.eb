easyblock = 'PerlModule'

name = 'Compress-Raw-Zlib'
version = '2.222'

homepage = 'https://metacpan.org/pod/Compress::Raw::Zlib'
description = "Low-Level Interface to zlib or zlib-ng compression library"

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://cpan.metacpan.org/authors/id/P/PM/PMQS/']
sources = ['%(name)s-%(version)s.tar.gz']
checksums = ['1dfd7d511a655627c81815d30d3babc28fa5b88455ff03f8b04099dcb51286b8']

builddependencies = [
    ('binutils', '2.44'),
]

dependencies = [
    ('Perl', '5.40.2'),
    ('zlib-ng', '2.2.5'),
]

preconfigopts = 'sed -i -e "s/BUILD_ZLIB.*/BUILD_ZLIB = False/" config.in && '
preconfigopts += 'sed -i -e "s/USE_ZLIB_NG.*/USE_ZLIB_NG = True/" config.in && '

options = {'modulename': 'Compress::Raw::Zlib'}

sanity_check_paths = {
    'files': ['lib/perl5/site_perl/%(perlver)s/%(arch)s-linux-thread-multi/Compress/Raw/Zlib.pm'],
    'dirs': [],
}

moduleclass = 'lib'
