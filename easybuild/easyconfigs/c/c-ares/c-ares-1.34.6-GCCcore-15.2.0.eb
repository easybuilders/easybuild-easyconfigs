easyblock = 'ConfigureMake'

name = 'c-ares'
version = '1.34.6'

homepage = 'https://c-ares.org/'
description = "c-ares is a C library for asynchronous DNS requests (including name resolves)"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/c-ares/c-ares/releases/download/v%(version)s']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['912dd7cc3b3e8a79c52fd7fb9c0f4ecf0aaa73e45efda880266a2d6e26b84ef5']

builddependencies = [
    ('binutils', '2.45'),
    ('Autotools', '20250626'),
    ('googletest', '1.17.0'),
]

preconfigopts = "autoreconf -i -f &&"
# googletest requires building tests with C++17 or newer
configopts = ' '.join([
    'CXXFLAGS="$CXXFLAGS -std=c++17"',
    '--enable-tests',
])

test_cmd = './test/arestest'
# Skip tests relying on an internet connection
runtest = '--gtest_filter="-*.Live*"'

sanity_check_paths = {
    'files': ['lib/libcares.a', f'lib/libcares.{SHLIB_EXT}', 'lib/pkgconfig/libcares.pc'],
    'dirs': ['include', 'share/man'],
}

moduleclass = 'lib'
