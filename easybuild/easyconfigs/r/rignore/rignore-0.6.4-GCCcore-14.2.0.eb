    ('pyo3-macros-backend', '0.25.1'),
    ('quote', '1.0.36'),
    ('regex-automata', '0.4.7'),
    ('regex-syntax', '0.8.4'),
    ('same-file', '1.0.6'),
    ('serde', '1.0.204'),
    ('serde_derive', '1.0.204'),
    ('syn', '2.0.71'),
    ('target-lexicon', '0.13.2'),
    ('unicode-ident', '1.0.12'),
    ('unindent', '0.2.3'),
