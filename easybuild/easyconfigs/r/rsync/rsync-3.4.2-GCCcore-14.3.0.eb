easyblock = 'ConfigureMake'

name = 'rsync'
version = '3.4.2'

homepage = 'https://rsync.samba.org'
description = """An open source utility that provides fast incremental file transfer.
It also has useful features for backup and restore operations among many other use cases.

This build includes xxhash, zstd, and lz4 support.
"""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://download.samba.org/pub/rsync/src/']
sources = [SOURCE_TAR_GZ]
checksums = ['ff10aa2c151cd4b2dbbe6135126dbc854046113d2dfb49572a348233267eb315']

builddependencies = [
    ('binutils', '2.44'),
]

dependencies = [
    ('acl', '2.3.2'),
    ('attr', '2.5.2'),
    ('zstd', '1.5.7'),
    ('xxHash', '0.8.3'),
    ('lz4', '1.10.0'),
    ('OpenSSL', '3', '', SYSTEM),
]

sanity_check_paths = {
    'files': ['bin/rsync'],
    'dirs': [],
}

sanity_check_commands = ['rsync -h']

moduleclass = 'tools'
