easyblock = 'MakeCp'

name = 'RECON'
version = '2.0.9'

homepage = 'https://github.com/Dfam-consortium/RepeatModeler'
description = """Patched version of RECON to be used with RepeatModeler."""

toolchain = {'name': 'GCC', 'version': '14.3.0'}
source_urls = ['https://github.com/Dfam-consortium/RepeatModeler/archive/refs/tags/']
sources = [VERSION_TAR_GZ]
checksums = ['da7d16c97458059fd12e4d7054ee7695ea3855b8660c450452875685086c5e2f']

dependencies = [('Perl', '5.40.2')]

buildopts = 'CC="$CC"'

files_to_copy = [
    'bin', 'scripts', 'COPYRIGHT', 'examples', 'LICENSE', 'README.md',
]

_bins = ['edgeredef', 'eledef', 'eleredef', 'famdef']
_scripts = ['MSPCollect.pl', 'batch_equiv_test.sh', 'compare_recon_runs.sh', 'equiv_test.sh',
            'graphFamilyElementRelationships.pl', 'imagespread', 'run_all_tests.sh', 'run_recon.sh']

sanity_check_paths = {
    'files': [f'bin/{x}' for x in _bins] + [f'scripts/{x}' for x in _scripts],
    'dirs': [],
}

modextrapaths = {'PATH': 'scripts'}

moduleclass = 'bio'
