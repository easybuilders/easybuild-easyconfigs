easyblock = 'PythonBundle'

name = 'ratarmount'
version = '1.2.1'

homepage = 'https://github.com/mxmlnkn/ratarmount'
description = ''

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('setuptools', '80.9.0'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('bzip2', '1.0.8'),
    ('gzip', '1.13'),
    ('XZ', '5.6.3'),
    ('Zip', '3.0'),
    ('zstd', '1.5.6'),
]

exts_defaultclass = 'PythonPackage'

exts_list = [
    ('mfusepy', '3.0.0', {
        'osdependencies': ['fuse'],
        'sources': ['https://github.com/mxmlnkn/mfusepy/archive/refs/tags/v3.0.0.tar.gz'],
        'checksums': ['1a04a22b9c7790a8759f5ca7da52b9e4e6a91898079c41714aa3b5a24071c81d'],
    }),
    ('ratarmountcore', version, {
        'sources': ['https://github.com/mxmlnkn/%s/archive/refs/tags/v%s.tar.gz' % (name, version)],
        'checksums': ['ccfa3fdd158b08bd94670c33f8925c57999391213799560d8963eea45e9aba6c'],
        'start_dir': 'core',
        'use_pip_extras': 'bzip2,gzip,xz,zip,zstd',
    }),
    (name, version, {
        'sources': ['https://github.com/mxmlnkn/%s/archive/refs/tags/v%s.tar.gz' % (name, version)],
        'checksums': ['ccfa3fdd158b08bd94670c33f8925c57999391213799560d8963eea45e9aba6c'],
    }),
]

moduleclass = 'tools'
