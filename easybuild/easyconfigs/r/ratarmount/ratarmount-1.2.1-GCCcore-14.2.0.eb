easyblock = 'PythonBundle'

name = 'ratarmount'
version = '1.2.1'

homepage = 'https://github.com/mxmlnkn/ratarmount'
description = """Ratarmount collects all file positions inside a TAR so that it can easily jump to and read from any
file without extracting it. It, then, mounts the TAR using mfusepy, a fork of fusepy, for read access just like
archivemount. In contrast to libarchive, on which archivemount is based, random access and true seeking is supported.
And in contrast to tarindexer, which also collects file positions for random access, ratarmount offers easy access via
FUSE and support for compressed TARs."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('setuptools', '80.9.0'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('bzip2', '1.0.8'),
    ('gzip', '1.13'),
    ('XZ', '5.6.3'),
    ('Zip', '3.0'),
    ('zstd', '1.5.6'),
]

exts_defaultclass = 'PythonPackage'

exts_list = [
    ('mfusepy', '3.0.0', {
        'osdependencies': ['fuse'],
        'sources': ['https://github.com/mxmlnkn/mfusepy/archive/refs/tags/v3.0.0.tar.gz'],
        'checksums': ['1a04a22b9c7790a8759f5ca7da52b9e4e6a91898079c41714aa3b5a24071c81d'],
    }),
    ('ratarmountcore', '0.10.2', {
        'sources': ['https://github.com/mxmlnkn/%s/archive/refs/tags/v%s.tar.gz' % (name, version)],
        'checksums': ['ccfa3fdd158b08bd94670c33f8925c57999391213799560d8963eea45e9aba6c'],
        'start_dir': 'core',
        'use_pip_extras': 'bzip2,gzip,xz,zip,zstd',
    }),
    (name, version, {
        'sources': ['https://github.com/mxmlnkn/%s/archive/refs/tags/v%s.tar.gz' % (name, version)],
        'checksums': ['ccfa3fdd158b08bd94670c33f8925c57999391213799560d8963eea45e9aba6c'],
    }),
]

sanity_check_paths = {
    'files': [
        'bin/ratarmount',
        'lib/python%(pyshortver)s/site-packages/mfusepy.py',
    ],
    'dirs': [
        'lib/python%(pyshortver)s/site-packages/ratarmountcore',
        'lib/python%(pyshortver)s/site-packages/ratarmount',
    ],
}

sanity_check_commands = [
    'ratarmount --help',
]

moduleclass = 'tools'
