easyblock = 'JuliaBundle'

name = 'Requires'
version = '1.3.1'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/JuliaPackaging/Requires.jl'
description = "Requires is a Julia package that will magically make loading packages faster, maybe."

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/JuliaPackaging/Requires.jl/archive/'],
        'sources': [{
            'download_filename': '62389eeff14780bfe55195b7204c0d8738436d64.tar.gz',
            'filename': 'Requires-1.3.1.tar.gz',
        }],
        'checksums': [None],
        # 'runtest': True,
    }),
]

moduleclass = 'lang'
