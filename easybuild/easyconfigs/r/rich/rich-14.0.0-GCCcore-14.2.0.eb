easyblock = 'PythonBundle'

name = 'rich'
version = '14.0.0'

homepage = 'https://rich.readthedocs.io/en/latest'
description = """
Rich is a Python library for writing rich text (with color and style) to the terminal, and for
 displaying advanced content such as tables, markdown, and syntax highlighted code.
 Use Rich to make your command line applications visually appealing and present data in a more
 readable way. Rich can also be a useful debugging aid by pretty printing and syntax highlighting
 data structures.
"""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('poetry', '2.1.2'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('Python-bundle-PyPI', '2025.04'),
]

exts_list = [
    (name, version, {
        'checksums': ['5cb5123b5cf9ee70584244246816e9114227e0b98ad9176eede6ad54bf5403fa'],
    }),
    ('rich_toolkit', '0.14.8', {
        'checksums': ['1f77b32e6c25d9e3644c1efbce00d8d90daf2457b3abdb4699e263c03b9ca6cf'],
    }),
]

moduleclass = 'tools'
