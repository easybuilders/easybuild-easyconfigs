easyblock = 'CMakeMake'

name = 'rocm-core'
version = '6.4.0'
_rocm_version = '6.4.1'
versionsuffix = f'-ROCm-{_rocm_version}'

homepage = 'https://github.com/ROCm/rocm-core'
description = """ROCm-core is a foundational package that provides ROCm release versioning
and installation path information via header files."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

github_account = 'ROCm'
source_urls = [GITHUB_SOURCE]
sources = [f"rocm-{_rocm_version}.tar.gz"]

builddependencies = [
    ('CMake', '3.31.3'),
]

configopts = f"-DROCM_VERSION={_rocm_version} "

sanity_check_paths = {
    'dirs': ['include/rocm-core', '.info'],
    'files': [
        'include/rocm-core/rocm_version.h',
        'include/rocm-core/rocm_getpath.h',
        'lib/librocm-core.so',
        '.info/version'
    ]
}

moduleclass = 'lib'