easyblock = 'PythonBundle'

name = 'RGI'
version = '6.0.6'

homepage = 'https://github.com/arpcard/rgi'
description = """Resistance Gene Identifier (RGI). Software to predict
resistomes from protein or nucleotide data, including metagenomics data,
based on homology and SNP models."""

toolchain = {'name': 'gfbf', 'version': '2024a'}

builddependencies = [
    ('poetry', '1.8.3'),
    ('pytest', '8.3.3'),
    ('CMake', '3.29.3'),  # needed by pyroddigal
    ('Cython', '3.0.10'),  # needed by pyroddigal
    ('scikit-build-core', '0.11.1'),  # needed by pyroddigal
]

dependencies = [
    ('zlib', '1.3.1'),
    ('lz4', '1.9.4'),
    ('zstd', '1.5.6'),
    ('Python', '3.12.3'),
    ('Python-bundle-PyPI', '2024.06'),
    ('SciPy-bundle', '2024.05'),
    ('matplotlib', '3.9.2'),
    ('Biopython', '1.84'),
    ('Seaborn', '0.13.2'),
    ('BeautifulSoup', '4.12.3'),
    ('pyfaidx', '0.8.1.2'),
    ('Pysam', '0.22.1'),
    ('lxml', '5.3.0'),
    ('dask', '2024.9.1'),
    ('ISA-L', '2.31.0'),
    ('archspec', '0.2.5'),
]

github_account = 'arpcard'

exts_list = [
    ('filetype', '1.2.0', {
        'checksums': ['66b56cd6474bf41d8c54660347d37afcc3f7d1970648de365c102ef77548aadb'],
    }),
    ('pyahocorasick', '2.1.0', {
        'modulename': 'ahocorasick',
        'checksums': ['4df4845c1149e9fa4aa33f0f0aa35f5a42957a43a3d6e447c9b44e679e2672ea'],
    }),
    ('pyrodigal', '3.7.0', {
        'checksums': ['415940f07a9e6e60ca023b99381f2d5f62f801914b9edd6da5a28dd7307b091d'],
    }),
    ('%(namelower)s', version, {
        'source_urls': [GITHUB_SOURCE],
        'sources': [{'download_filename': VERSION_TAR_GZ, 'filename': SOURCE_TAR_GZ}],
        'checksums': ['ae292c29446114705a8ffbc4ff9e24298631dc42dc6fcb52c48485c5eb50fc00'],
        'preinstallopts': "sed -i -e 's/requests==.*/requests/' requirements.txt && ",
        'modulename': False,
    }),
]

moduleclass = 'bio'
