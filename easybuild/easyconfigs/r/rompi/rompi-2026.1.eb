easyblock = 'Toolchain'

name = 'rompi'
version = '2026.1'

homepage = '(none)'
description = """ROCm-LLVM based compiler toolchain, including OpenMPI for MPI support."""

toolchain = SYSTEM

local_rocmver = '19.0.0-ROCm-6.4.1'

# compiler toolchain dependencies
dependencies = [
    ('rocm-compilers', local_rocmver),  # includes both ROCm-LLVM and binutils
    ('OpenMPI', '5.0.7', '', ('rocm-compilers', local_rocmver)),
]

moduleclass = 'toolchain'
