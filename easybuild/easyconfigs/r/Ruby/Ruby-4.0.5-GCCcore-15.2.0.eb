name = 'Ruby'
version = '4.0.5'

homepage = 'https://www.ruby-lang.org'
description = """Ruby is a dynamic, open source programming language with
 a focus on simplicity and productivity. It has an elegant syntax that is
 natural to read and easy to write."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://cache.ruby-lang.org/pub/ruby/%(version_major_minor)s']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['7d6149079a63f8ae1d326c9fa65c6019ba2dc3155eae7b39159817911c88958e']

dependencies = [
    ('binutils', '2.45'),  # needed for gem
    ('zlib', '2.3.2'),
    ('OpenSSL', '3', '', SYSTEM),
    ('libyaml', '0.2.5'),
]

moduleclass = 'lang'
