easyblock = 'PythonPackage'

name = 'regionmask'
version = '0.13.0'

homepage = 'https://regionmask.readthedocs.io'
description = """regionmask creates masks of geographical regions. It determines to which
geographic region each grid point belongs."""

toolchain = {'name': 'foss', 'version': '2023b'}

sources = [SOURCE_TAR_GZ]
checksums = ['56fd11986cd2f03bd3ac3ecb19399bff3e8cb79e151f7e33e18121735123abdf']

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('geopandas', '1.0.1'),
    ('rasterio', '1.4.3'),
    ('Shapely', '2.0.6'),
    ('xarray', '2024.5.0'),
]

moduleclass = 'geo'
