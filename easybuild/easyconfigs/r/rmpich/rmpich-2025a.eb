# Author:   Aayush Joglekar <aayush.joglekar@surf.nl>

easyblock = 'Toolchain'

name = 'rmpich'
version = '2025a'

homepage = '(none)'
description = 'ROCm-LLVM based compiler toolchain, including MPICH for MPI support.'

toolchain = SYSTEM

local_rocmver = '19.0.0-ROCm-6.4.1'

# compiler toolchain dependencies
dependencies = [
    ('rocm-compilers', local_rocmver),  # includes both ROCm-LLVM and binutils
    ('MPICH', '4.3.2', '', ('rocm-compilers', local_rocmver)),
]

moduleclass = 'toolchain'
