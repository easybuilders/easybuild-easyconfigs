# Author:   Jan André Reuter <j.reuter@fz-juelich.de>

easyblock = 'ROCmComponent'

name = 'rocPRIM'
version = '3.4.0'
_rocm_version = '6.4.1'

homepage = 'https://github.com/ROCm/rocPRIM'
description = """rocPRIM is a header-only library that provides HIP parallel primitives.
You can use this library to develop performant GPU-accelerated code on AMD ROCm platforms."""
docurls = ['https://rocm.docs.amd.com/projects/rocPRIM/en/latest/']

toolchain = {'name': 'rocm-compilers', 'version': '19.0.0-ROCm-6.4.1'}

github_account = 'ROCm'
source_urls = [GITHUB_SOURCE]
sources = [f'rocm-{_rocm_version}.tar.gz']
checksums = ['ff84b839bbe07fd2c97771c1b864dac641bfa654a652e75b0e7fed5e3ec5bb7c']

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.31.3'),
]
dependencies = [
    ('HIP', _rocm_version)
]

sanity_check_paths = {
    'files': ['lib/cmake/rocprim/rocprim-config.cmake',
              'include/rocprim/rocprim.hpp'],
    'dirs': ['lib/cmake/rocprim',
             'share/doc/rocprim',
             'include/rocprim'],
}

moduleclass = 'lib'
