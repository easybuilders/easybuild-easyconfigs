easyblock = 'ConfigureMake'

name = 'RepeatAfterMe'
version = '0.0.7'

homepage = 'https://github.com/Dfam-consortium/RepeatAfterMe'
description = """
A package for the extension of repetitive DNA cores. The RepeatAfterMe RAMExtend tool automatically
extends a multiple sequence alignment (MSA) that may represent only a fragment of a longer repetitive
sequence family.
"""

toolchain = {'name': 'GCC', 'version': '14.2.0'}

github_account = 'Dfam-consortium'
source_urls = [GITHUB_SOURCE]
sources = ['%(name)s_V%(version)s.tar.gz']
checksums = ['8a4c96be6c0fcedf24ee28796fea3bffef022c7479d8f49fbd2f83e56d697f26']

maxparallel = 1

skipsteps = ['configure']

# Fix file exists error when trying to create INSTDIR
preinstallopts = "sed -i 's/mkdir/mkdir -p/' Makefile && "
installopts = 'INSTDIR="%(installdir)s"'
postinstallcmds = ["cp util/* %(installdir)s/bin"]

test_cmd = './test_suite'

sanity_check_paths = {
    'files': [
        'bin/RAMExtend',
        'bin/calcPaths.pl',
        'bin/davidExtendConsRAM.pl',
        'bin/extend-stk.pl',
        'README.md',
    ],
    'dirs': [],
}

sanity_check_commands = ["RAMExtend -version"]

moduleclass = 'bio'
