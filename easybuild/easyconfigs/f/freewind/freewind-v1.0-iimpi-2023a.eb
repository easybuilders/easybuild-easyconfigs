easyblock = 'Bundle'

name = 'freewind'
version = 'v1.0'

homepage = 'https://gitlab.kuleuven.be/rcs/cclm/accu/-/tree/accu-%(version)s?ref_type=tags'
description = """Module bundle for loading the software needed to run accu experiments"""

toolchain = {'name': 'iimpi', 'version': '2023a'}

dependencies = [

     ('INT2LM-rcs', '%(name)s-%(version)s'),
     ('CCLM-rcs', '%(name)s-%(version)s'),
]


moduleclass = 'tools'

