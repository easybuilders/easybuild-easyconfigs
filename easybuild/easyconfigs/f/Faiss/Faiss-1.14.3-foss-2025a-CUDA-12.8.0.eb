# Author: Jasper Grimm (UoY)
# Update: Pavel Tomanek (Inuits/UGent)
easyblock = 'CMakePythonPackage'

name = 'Faiss'
version = '1.14.3'
versionsuffix = '-CUDA-%(cudaver)s'

homepage = 'https://github.com/facebookresearch/faiss'
description = """
Faiss is a library for efficient similarity search and clustering of dense
 vectors. It contains algorithms that search in sets of vectors of any size, up
 to ones that possibly do not fit in RAM. It also contains supporting code for
 evaluation and parameter tuning. Faiss is written in C++ with complete
 wrappers for Python/numpy. Some of the most useful algorithms are implemented
 on the GPU. It is developed primarily at Meta's Fundamental AI Research group.
"""

toolchain = {'name': 'foss', 'version': '2025a'}

github_account = 'facebookresearch'
source_urls = [GITHUB_LOWER_SOURCE]
sources = ['v%(version)s.tar.gz']
checksums = ['7f3c4ed9aec3bd7524382862f5fcbd4d8984e2a8979ff3bdb2c0bcea5144149e']

builddependencies = [
    ('CMake', '3.31.3'),
    ('SWIG', '4.3.1'),
]

dependencies = [
    ('CUDA', '12.8.0', '', SYSTEM),
    ('Python', '3.13.1'),
    ('SciPy-bundle', '2025.06'),
    ('PyTorch', '2.9.1', versionsuffix),
    ('gflags', '2.2.2'),
]

_copts = [
    '-DFAISS_ENABLE_GPU=ON',
    '-DFAISS_ENABLE_PYTHON=ON',
    '-DFAISS_ENABLE_C_API=ON',
    '-DBUILD_TESTING=OFF',  # ON failed on undefined references to Py* symbols
    '-DBUILD_SHARED_LIBS=ON',
    '-DPython_EXECUTABLE="${EBROOTPYTHON}/bin/python"',
    '-DCUDAToolkit_ROOT="${CUDA_ROOT}"',
    '-DCMAKE_CUDA_ARCHITECTURES="%(cuda_cc_cmake)s"',
]

configopts = ' '.join(_copts)

buildopts = 'faiss swigfaiss'

_callback_lib = 'libfaiss_python_callbacks.%s' % SHLIB_EXT

postinstallcmds = [
    ' && '.join([
        # run a pip install in the 'faiss/python' subdir
        'cd ../easybuild_obj/%(namelower)s/python',
        '${EBROOTPYTHON}/bin/python -s -m pip install --prefix=%(installdir)s --no-build-isolation .',
        # this callback library may be produced in different paths; only copy when found
        'install -d %(installdir)s/lib/python%(pyshortver)s/site-packages/faiss',
        # disable wheel-style CUDA preload logic; this stack relies on module-provided CUDA libs
        (
            'for p in '
            '%(installdir)s/faiss/_gpu_build.py '
            '%(installdir)s/lib/python%(pyshortver)s/site-packages/faiss/_gpu_build.py; do '
            'if [ -f "$p" ]; then rm -f "$p"; fi; '
            'done'
        ),
        (
            'cb_lib=$(find . -maxdepth 3 -name "' + _callback_lib + '" -print -quit) && '
            'if [ -n "$cb_lib" ]; then '
            'cp "$cb_lib" %(installdir)s/lib/python%(pyshortver)s/site-packages/faiss/; '
            'fi'
        )
    ])
]

modextrapaths = {'LD_LIBRARY_PATH': "lib/python%(pyshortver)s/site-packages/faiss"}

sanity_check_paths = {
    'files': ['lib/lib%%(namelower)s.%s' % SHLIB_EXT],
    'dirs': ['include/%(namelower)s', 'lib/python%(pyshortver)s/site-packages/%(namelower)s'],
}

moduleclass = 'tools'

