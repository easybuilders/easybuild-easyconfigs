easyblock = 'PythonPackage'

name = 'f90nml'
version = '1.5'

homepage = 'https://github.com/marshallward/f90nml'
description = """A Python module and command line tool for parsing
    Fortran namelist files"""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['d5585f0051234c742f7515c4b1f8484f8f628a71c4e31f2602357089dcc05fc1']

builddependencies = [
    ('binutils', '2.44'),
]
dependencies = [
    ('Python', '3.13.5'),
    ('PyYAML', '6.0.2')
]

moduleclass = 'tools'
