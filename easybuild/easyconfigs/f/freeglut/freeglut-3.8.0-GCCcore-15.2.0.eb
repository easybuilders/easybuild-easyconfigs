easyblock = 'CMakeMake'

name = 'freeglut'
version = '3.8.0'

homepage = 'http://freeglut.sourceforge.net/'
description = "freeglut is a completely OpenSourced alternative to the OpenGL Utility Toolkit (GLUT) library."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = [SOURCEFORGE_SOURCE]
sources = [SOURCE_TAR_GZ]
checksums = ['674dcaff25010e09e450aec458b8870d9e98c46f99538db457ab659b321d9989']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]
dependencies = [
    ('X11', '20260518'),
    ('OpenGL', '2026.05'),
]

configopts = ' '.join([
    '-DCMAKE_POLICY_VERSION_MINIMUM=3.5',
    f'-DX11_X11_LIB="$EBROOTX11/lib/libX11.{SHLIB_EXT}"',
    '-DX11_X11_INCLUDE_PATH="$EBROOTX11/include/X11"',
    f'-DX11_Xext_LIB="$EBROOTX11/lib/libXext.{SHLIB_EXT}"',
    f'-DX11_Xrandr_LIB="$EBROOTX11/lib/libXrandr.{SHLIB_EXT}"',
    '-DX11_Xrandr_INCLUDE_PATH="$EBROOTX11/include/X11/extensions/"',
    f'-DX11_Xi_LIB="$EBROOTX11/lib/libXrandr.{SHLIB_EXT}"',
    '-DX11_Xi_INCLUDE_PATH="$EBROOTX11/include/X11/extensions/"',
])


sanity_check_paths = {
    'files': ['lib/libglut.a', f'lib/libglut.{SHLIB_EXT}'],
    'dirs': ['include/GL'],
}

moduleclass = 'lib'
