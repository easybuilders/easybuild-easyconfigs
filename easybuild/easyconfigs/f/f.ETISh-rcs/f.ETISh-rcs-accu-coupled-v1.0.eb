easyblock = 'PackedBinary'

name='f.ETISh-rcs'
version='accu-coupled-v1.0'

homepage = 'https://forge.ipsl.jussieu.fr/ioserver'
description = """f.ETISh is the fast Elementary Thermomechanical Ice Sheet model.
This is a vertically integrated hybrid finite-difference ice-sheet/ice-shelf model with vertically integrated
thermomechanical coupling. The source code in this repository is based on f.ETISh v1.7.
"""

toolchain = SYSTEM

sources = [{
             'filename': 'fetish_rcs_%(version)s.tar.gz',
             'git_config': {
                 'url': 'git@gitlab.kuleuven.be:rcs/cclm/software',
                 'repo_name': 'fetish_rcs',
                 'tag': '%(version)s',
    },
}]

install_cmd = 'cp fetish_rcs/bin/ %(installdir)s/ -r'

sanity_check_paths = {
    'files': ['bin/fETISh_Coupling_PARAMOUR_V171',],
    'dirs': ['bin'],
}

modextrapaths = {
    'PATH': ['bin'],
}

postinstallcmds = [
    "chmod 750 %(installdir)s/bin/fETISh_Coupling_PARAMOUR_V171",
]

moduleclass = 'geo'
