easyblock = 'MakeCp'

name = 'FAMSA'
version = '2.5.2'

homepage = 'https://github.com/refresh-bio/FAMSA'
description = """FAMSA2 is a progressive algorithm for large-scale multiple
sequence alignments"""

toolchain = {"name": "GCCcore", "version": "13.3.0"}

sources = [{
    'filename': SOURCE_TAR_XZ,
    'git_config': {
        'url': 'https://github.com/refresh-bio',
        'repo_name': 'FAMSA',
        'commit': '2598410',
        'clone_into': 'FAMSA-2.5.2',
    },
}]
checksums = ['b00705aa660443b25421378a558defc05b2cf8a40657248348c372f469410335']

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.29.3'),
]

files_to_copy = [
    (['bin/famsa'], 'bin'),
    'LICENSE',
    'README.md',
]

sanity_check_paths = {
    'files': ['bin/famsa'],
    'dirs': [],
}

sanity_check_commands = [
    'famsa -h',
]

moduleclass = 'bio'
