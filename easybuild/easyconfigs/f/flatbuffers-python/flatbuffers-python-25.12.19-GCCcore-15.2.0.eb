easyblock = 'PythonPackage'

name = 'flatbuffers-python'
version = '25.12.19'

homepage = 'https://github.com/google/flatbuffers/'
description = """Python Flatbuffers runtime library."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/google/flatbuffers/archive/']
sources = [{'download_filename': 'v%(version)s.tar.gz', 'filename': SOURCE_TAR_GZ}]
checksums = ['f81c3162b1046fe8b84b9a0dbdd383e24fdbcf88583b9cb6028f90d04d90696a']

dependencies = [
    ('binutils', '2.45'),
    ('Python', '3.14.2'),
]

start_dir = 'python'

preinstallopts = 'VERSION=%(version)s '

options = {'modulename': 'flatbuffers'}

moduleclass = 'devel'
