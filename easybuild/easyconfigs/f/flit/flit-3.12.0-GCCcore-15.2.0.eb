easyblock = 'PythonBundle'

name = 'flit'
version = '3.12.0'

homepage = 'https://github.com/pypa/flit'
description = "A simple packaging tool for simple packages."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

builddependencies = [
    ('binutils', '2.45'),
    ('hatchling', '1.29.0'),
]

dependencies = [
    ('Python', '3.14.2'),
]

exts_list = [
    ('idna', '3.18', {
        'checksums': ['ffb385a7e039654cef1ab9ef32c6fafe283c0c0467bba1d9029738ce4a14a848'],
    }),
    ('certifi', '2026.6.17', {
        'checksums': ['024c88eeec92ca068db80f02b8b07c9cef7b9fe261d1d535abfd5abd6f6af432'],
    }),
    ('urllib3', '2.7.0', {
        'checksums': ['231e0ec3b63ceb14667c67be60f2f2c40a518cb38b03af60abc813da26505f4c'],
    }),
    ('charset-normalizer', '3.4.7', {
        'checksums': ['ae89db9e5f98a11a4bf50407d4363e7b09b31e55bc117b4f7d80aab97ba009e5'],
    }),
    ('flit-scm', '1.7.0', {
        'checksums': ['961bd6fb24f31bba75333c234145fff88e6de0a90fc0f7e5e7c79deca69f6bb2'],
    }),
    ('requests', '2.34.2', {
        'checksums': ['f288924cae4e29463698d6d60bc6a4da69c89185ad1e0bcc4104f584e960b9ed'],
    }),
    ('docutils', '0.23', {
        'checksums': ['746f5060322511280a1e50eb76846ed6bf2342984b2ac04dc42caa1a8d78799e'],
    }),
    ('tomli-w', '1.2.0', {
        'checksums': ['2dd14fac5a47c27be9cd4c976af5a12d87fb1f0b4512f81d69cce3b35ae25021'],
    }),
    (name, version, {
        'checksums': ['1c80f34dd96992e7758b40423d2809f48f640ca285d0b7821825e50745ec3740'],
    }),
]

sanity_check_paths = {
    'files': ['bin/%(namelower)s'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/%(namelower)s'],
}

moduleclass = 'tools'
