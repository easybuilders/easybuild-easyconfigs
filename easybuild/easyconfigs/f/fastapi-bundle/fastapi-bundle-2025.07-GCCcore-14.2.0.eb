easyblock = 'PythonBundle'

name = 'fastapi-bundle'
version = '2025.07'

homepage = 'https://fastapi.tiangolo.com'
description = """FastAPI is a modern, fast (high-performance), web framework for building
 APIs with Python based on standard Python type hints.
 This bundle includes FastAPI and several other related libraries."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('hatchling', '1.27.0'),
    ('poetry', '2.1.2'),
]

