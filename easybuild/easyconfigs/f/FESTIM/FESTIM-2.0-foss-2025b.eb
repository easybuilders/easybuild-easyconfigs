easyblock = 'PythonPackage'

name = 'FESTIM'
version = '2.0'

homepage = 'https://github.com/festim-dev/FESTIM'
description = "Coupled hydrogen/tritium transport and heat transfer modelling using FEniCS."

toolchain = {'name': 'foss', 'version': '2025b'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/festim-dev/%(name)s/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
checksums = ['52b0b36fb0d807660b0f5dce942984cd4db7eefac01a94136373cc110b62aeaa']

dependencies = [
    ('Python', '3.13.5'),
    ('Python-bundle-PyPI', '2025.07'),
    ('SciPy-bundle', '2025.07'),
    ('mpi4py', '4.1.0'),
    ('tqdm', '4.67.1'),
    ('scifem', '0.17.0'),
    ('adios4dolfinx', '0.10.0.post0'),
    ('FEniCS-DOLFINx-Python', '0.10.0.post5'),
]

options = {'modulename': '%(namelower)s'}

moduleclass = 'phys'
