easyblock = 'PythonBundle'

name = 'Flower'
version = '1.25.0'

homepage = 'https://flower.ai'
description = """
Flower: A Friendly Federated AI Framework. Federated learning, federated evaluation, and
federated analytics require infrastructure to move machine learning models back and forth,
train and evaluate them on local data, and then aggregate the updated models. Flower provides
the infrastructure to do exactly that in an easy, scalable, and secure way.
"""

toolchain = {'name': 'gfbf', 'version': '2025a'}

builddependencies = [
    ('poetry', '2.1.2'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('SciPy-bundle', '2025.06'),
    ('grpcio', '1.76.0'),
    ('protobuf-python', '6.31.1'),
    ('PyYAML', '6.0.2'),
    ('cryptography', '44.0.2'),
]

exts_list = [
    ('grpcio-health-checking', '1.76.0', {
        'modulename': 'grpc',
        'sources': ['grpcio_health_checking-%(version)s.tar.gz'],
        'checksums': ['b7a99d74096b3ab3a59987fc02374068e1c180a352e8d1f79f10e5a23727098d'],
    }),
    ('iterators', '0.0.2', {
        'checksums': ['4f6a5b39c3c724edd5c7231a589d463ad50357cdc35494a3c71730795b78eb50'],
    }),
    ('typer', '0.12.5', {
        'source_tmpl': SOURCE_PY3_WHL,
        'checksums': ['62fe4e471711b147e3365034133904df3e235698399bc4de2b36c8579298d52b'],
    }),
    ('rich', '13.9.4', {
        'checksums': ['439594978a49a09530cff7ebc4b5c7103ef57baf48d5ea3184f21d9a2befa098'],
    }),  # flwr 1.25.0 has requirement rich<14.0.0,>=13.5.0
    ('flwr', version, {
        'checksums': ['fe5c9efd4ade6529583deb2927cadc5a6f3b15524e4c1fdc2521c3f24c80ebb8'],
    }),
]

sanity_check_paths = {
    'files': ['bin/flwr'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/flwr'],
}

sanity_check_commands = [
    "flwr --help",
]

moduleclass = 'ai'
