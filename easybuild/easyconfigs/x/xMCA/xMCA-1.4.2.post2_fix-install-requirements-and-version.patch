This patch corrects the version and requirements definitions in the setup.py
Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
Barcelona Supercomputing Center 2026
diff -ruNBbw a/setup.py b/setup.py
--- a/setup.py	2021-08-27 12:57:21.000000000 +0200
+++ b/setup.py	2026-03-20 15:01:35.611989736 +0100
@@ -11,11 +11,12 @@
 with open('README.md', 'r') as fh:
     long_description = fh.read()
 
-with open('requirements.txt', 'r') as fh:
+with open('xmca.egg-info/requires.txt', 'r') as fh:
     install_requires = fh.read()
 
 setup(
     name='xmca',
+    version=vfile['__version__'],
     include_package_data=True,
     keywords='eof, analysis, mca, pca',
     author='Niclas Rieger',
@@ -31,11 +32,6 @@
         'Operating System :: OS Independent',
     ],
     python_requires='>=3.6',
-    version_config={
-        'version_callback' : vfile['__version__'],
-        'dev_template': '{tag}.post{ccount}',
-        'dirty_template': '{tag}.post{ccount}'
-    },
-    setup_requires=['setuptools-git-versioning', 'numpy'],
+    setup_requires=['numpy'],
     install_requires=install_requires,
 )
