easyblock = 'PythonBundle'

name = 'xopen'
version = '2.1.0'

homepage = 'https://github.com/pycompression/xopen/'
description = """This Python module provides an xopen function that works like Python’s built-in open function but
also transparently deals with compressed files. xopen selects the most efficient method for reading or writing a
compressed file."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

builddependencies = [
    ('binutils', '2.44'),
]

dependencies = [
    ('Python', '3.13.5'),
    ('pigz', '2.8'),
    ('python-isal', '1.7.0'),
    ('python-zlib-ng', '0.5.1'),
    ('zstd', '1.5.7'),
    ('XZ', '5.8.1'),
]

exts_list = [
    ('backports-zstd', '1.5.0', {
        'checksums': ['a5e622a82eb183b4fbe18032755ce0a15fa9a82f2adb9b621620b91247aaedb7'],
    }),
    ('zlib-ng', '1.0.0', {
        'checksums': ['c753cea73f9e803c246e9bf01a59eb652897ed8a19334ada0f968394c7f61650'],
    }),
    (name, version, {
        'checksums': ['06584821588f813563863b63d5e02568a4328661b7507ea38c432f24c69ea4b7'],
    }),
]

moduleclass = 'lib'
