easyblock = 'CMakeMake'

name = 'Imath'
version = '3.2.2'

homepage = 'https://imath.readthedocs.io/en/latest/'
description = """
Imath is a C++ and python library of 2D and 3D vector, matrix, and math operations for computer graphics
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/AcademySoftwareFoundation/%(namelower)s/archive/']
sources = ['v%(version)s.tar.gz']
checksums = ['b4275d83fb95521510e389b8d13af10298ed5bed1c8e13efd961d91b1105e462']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

sanity_check_paths = {
    'files': [f'lib/libImath.{SHLIB_EXT}'],
    'dirs': ['include/Imath'],
}

moduleclass = 'lib'
