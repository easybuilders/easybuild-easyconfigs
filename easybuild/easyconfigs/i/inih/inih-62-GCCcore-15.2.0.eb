easyblock = 'MesonNinja'

name = 'inih'
version = '62'

homepage = 'https://dri.freedesktop.org'
description = """Direct Rendering Manager runtime library."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/benhoyt/inih/archive/refs/tags/']
sources = ['r%(version)s.tar.gz']
checksums = ['9c15fa751bb8093d042dae1b9f125eb45198c32c6704cd5481ccde460d4f8151']

builddependencies = [
    ('binutils', '2.45'),
    ('pkgconf', '2.5.1'),
    ('Meson', '1.10.2'),
    ('Ninja', '1.13.2'),
]

configopts = '--default-library=both '
# installing manpages requires an extra build dependency (docbook xsl)
# configopts += '-Dman-pages=disabled'

sanity_check_paths = {
    'files': [f'lib/libinih.{SHLIB_EXT}', 'lib/libinih.a', 'include/ini.h'],
    'dirs': ['include', 'lib'],
}

moduleclass = 'lib'
