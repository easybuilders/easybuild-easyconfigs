# Author: Anibal Moreno
easyblock = 'Tarball'

name = 'ica'
version = '2.43.0'

homepage = 'https://help.ica.illumina.com/'
description = """Command line interface for the Illumina Connected Analytics, a genomics platform-as-a-service"""

toolchain = SYSTEM

source_urls = ['https://stratus-documentation-us-east-1-public.s3.amazonaws.com/cli/%(version)s']
sources = ['%(namelower)s-linux-amd64.zip']
checksums = ['7b5102132ea224772aaa7f6cfa8c6cbdd8cc4216095b00c678ca44f728f80a2d']

postinstallcmds = [
    "mkdir -p %(installdir)s/bin",
    "mv %(builddir)s/linux-amd64/icav2 %(installdir)s/bin/",
    "mv %(builddir)s/linux-amd64/README.txt %(installdir)s/",
]

sanity_check_paths = {
    'files': ["bin/icav2"],
    'dirs': ["bin"],
}

sanity_check_commands = ["icav2 --version"]

moduleclass = 'tools'
