easyblock = 'ConfigureMake'

name = 'INTERPOS'
version = '9.2.3'

homepage = 'https://gitlab.epfl.ch/spc/interpos'
description = """Interpolation routines"""

toolchain = {'name': 'iimkl', 'version': '2025b'}

source_urls = ['https://gitlab.epfl.ch/spc/%(namelower)s/-/archive/%(version)s/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['e7648b78002a353bba822025e68090087ddc14a7a752f6bf58ddb7edb9f9249f']

builddependencies = [
    ('Autotools', '20250527'),
]

dependencies = [
    ('X11', '20250608'),
]

preconfigopts = 'echo "%s" > .tarball-version && ./bootstrap &&' % (version)
configopts = '--enable-tests'
runtest = 'check'

sanity_check_paths = {
    'files': ['include/interpos_module.mod', 'include/interpos_source.f90', 'include/prec_rkind.mod',
              'lib/libinterpos.a', 'lib/libinterpos.%s' % SHLIB_EXT, 'lib/pkgconfig/interpos.pc'],
    'dirs':  ['include', 'lib', 'lib/pkgconfig']
}

moduleclass = 'lib'
