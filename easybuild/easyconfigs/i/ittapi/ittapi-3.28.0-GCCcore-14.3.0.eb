easyblock = 'CMakeNinja'

name = 'ittapi'
version = '3.28.0'

homepage = 'https://github.com/intel/ittapi'
description = '''
Intel® Instrumentation and Tracing Technology (ITT) and Just-In-Time (JIT) APIs
'''

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/intel/ittapi/archive/refs/tags/']
sources = [V_VERSION_TAR_GZ]
checksums = ['39d47cf33bfc4101dcca61c00f9ace9a0ee50ccd98bb7905291f2f0679f5b6df']

builddependencies = [
    ('CMake', '4.0.3'),
    ('Ninja', '1.13.0'),
]

configopts = ' '.join([
    '-DITT_API_CPP_SUPPORT=ON',
    # To keep this in GCCcore
    '-DITT_API_FORTRAN_SUPPORT=OFF',
])

sanity_check_paths = {
    'files': [
        'include/ittapi.hpp',
        'lib/cmake/ittapi/ittapiConfig.cmake',
        'lib/libittnotify.a',
    ],
    'dirs': ['']
}

moduleclass = 'lib'
