easyblock = 'PythonPackage'

name = 'IMAS-ParaView'
version = '2.3.0'

description = """ParaView plugin to convert GGD structures to VTK"""
homepage = "https://github.com/iterorganization/IMAS-ParaView"

toolchain = {'name': 'foss', 'version': '2023b'}

source_urls = [PYPI_LOWER_SOURCE]
sources = ['imas_paraview-%(version)s.tar.gz']
patches = ['%(name)s_remove_VTK_dep.patch']
checksums = [
    {'imas_paraview-2.3.0.tar.gz': '210d31c965934f86af5b0cd8f26d4e3fc73ddd6d6e76aaf892d61e4bf5fe234d'},
    {'IMAS-ParaView_remove_VTK_dep.patch': 'ff63a0d2ac889523d6a4f41a141458a5adc6ec94a2333caf036adc11dbbc2575'},
]

dependencies = [
    ('Python', '3.11.5'),
    ('SciPy-bundle', '2023.11'),
    ('ParaView', '5.12.0'),
    ('IMAS-Python', '2.1.0'),
]

modextrapaths = {
    'PV_PLUGIN_PATH': ['lib/python%(pyshortver)s/site-packages/imas_paraview/plugins'],
}

moduleclass = 'vis'

modluafooter = 'conflict("GGD-VTK")'
modtclfooter = 'conflict GGD-VTK'
