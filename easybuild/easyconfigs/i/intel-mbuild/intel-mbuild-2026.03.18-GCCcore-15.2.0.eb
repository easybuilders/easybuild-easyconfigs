easyblock = 'PythonBundle'

name = 'intel-mbuild'
version = '2026.03.18'

homepage = 'https://github.com/intelxed/mbuild'
description = """python-based build system used for building XED"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [
    ('binutils', '2.45'),
]

dependencies = [
    ('Python', '3.14.2'),
]

components = [
    ('mbuild', version, {
        'source_urls': ['https://github.com/intelxed/mbuild/archive/refs/tags/'],
        'sources': ['v%(version)s.tar.gz'],
        'checksums': ['800371afb849647cc8e4b5fe1fe5c20108f43fc5b77edceac6c22ca2928f3aa2'],
        'start_dir': 'mbuild-%(version)s',
    })
]

moduleclass = 'tools'
