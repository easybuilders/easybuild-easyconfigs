easyblock = 'ConfigureMake'

name = 'IBSimu'
version = '1.0.6dev'
versionsuffix = '-2023-10-26'
local_commit = '89c1280'

homepage = 'https://ibsimu.sourceforge.net/'
description = """Ion Beam Simulator or IBSimu is an ion optical computer simulation package for ion optics,
plasma extraction and space charge dominated ion beam transport using Vlasov iteration.
The code has several capabilities for solving electric fields in a defined geometry and tracking particles
in electric and magnetic fields. The code is a constructed as a C++ library for maximal versatility and openness."""

toolchain = {'name': 'gfbf', 'version': '2025b'}

source_urls = ['https://%(namelower)s.sourceforge.net']
sources = [{
    'download_filename': f'lib%(namelower)s-{version}_{local_commit}.tar.gz',
    'filename': f'{name}-{version}{versionsuffix}.tar.gz',
}]
checksums = ['d9f5108bacc24b1e9a82240b274623ea4d56588f088cfa5765572434bc3be0cc']

builddependencies = [
    ('binutils', '2.44'),
    ('pkgconf', '2.4.3'),
]

dependencies = [
    ('zlib', '1.3.1'),
    ('libpng', '1.6.50'),
    ('freetype', '2.13.3'),
    ('fontconfig', '2.17.0'),
    ('cairo', '1.18.4'),
    ('GSL', '2.8'),
    ('SuiteSparse', '7.11.0'),
]

# fix the path to umfpack.h in the configure scripts and make sure that FlexiBLAS is used as BLAS library
preconfigopts = 'sed -i "s@/include/suitesparse@/include@" configure && sed -i "s@lblas@lflexiblas@" configure && '
configopts = '--with-umfpack=$EBROOTSUITESPARSE'

sanity_check_paths = {
    'files': ['include/%(namelower)s-%(version)s/%(namelower)s.hpp',
              'lib/lib%(namelower)s-%(version)s.a',
              'lib/lib%%(namelower)s-%%(version)s.%s' % SHLIB_EXT],
    'dirs': [],
}

moduleclass = 'phys'
