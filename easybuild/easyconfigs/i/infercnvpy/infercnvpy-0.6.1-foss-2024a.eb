easyblock = 'PythonBundle'

name = 'infercnvpy'
version = '0.6.1'

homepage = 'https://github.com/icbi-lab/infercnvpy'
description = "Infer copy number variation (CNV) from scRNA-seq data. Plays nicely with Scanpy."

toolchain = {'name': 'foss', 'version': '2024a'}

builddependencies = [
    ('hatchling', '1.24.2'),
    ('Cython', '3.0.10'),
    ('poetry', '1.8.3'),
]
dependencies = [
    ('Python', '3.12.3'),
    ('SciPy-bundle', '2024.05'),
    ('tqdm', '4.66.5'),
    ('leidenalg', '0.10.2'),
    ('scanpy', '1.10.4'),
    ('anndata', '0.11.4'),
    ('libiconv', '1.17'),
    ('py-cpuinfo', '9.0.0'),
    ('polars', '1.28.1'),
    ('Arrow', '17.0.0'),
]

