easyblock = 'PythonBundle'

name = 'Squidpy'
version = '1.6.6'

homepage = 'https://github.com/scverse/squidpy'
description = "Squidpy is a tool for the analysis and visualization of spatial molecular data."

toolchain = {'name': 'foss', 'version': '2024a'}

builddependencies = [('poetry', '1.8.3')]
dependencies = [
    ('Python', '3.12.3'),
    ('SciPy-bundle', '2024.05'),
    ('anndata', '0.11.4'),
    ('matplotlib', '3.9.2'),
    ('networkx', '3.4.2'),
    ('numba', '0.60.0'),
    ('scanpy', '1.10.4'),
    ('scikit-learn', '1.5.2'),
    ('aiohttp', '3.10.10'),
    ('dask', '2024.9.1'),
    ('Pillow', '10.4.0'),
    ('scikit-image', '0.25.0'),
    ('imagecodecs', '2024.12.30'),
    ('tqdm', '4.66.5'),
    ('zarr', '2.18.4'),
    ('geopandas', '1.0.1'),
    ('wrapt', '1.16.0'),
    ('imageio', '2.36.1'),
    ('xarray', '2024.11.0'),
    ('Arrow', '17.0.0'),
    ('Shapely', '2.0.6'),
    ('statsmodels', '0.14.4'),
    ('python-igraph', '0.11.9'),
    ('leidenalg', '0.10.2'),
]

local_preinstallopts = "sed -i 's/imagecodecs>=2025.8.2,<2026/imagecodecs/' pyproject.toml && "
local_test_cmd = (
    'pytest -v -n %(parallel)s '
    'tests/read/test_visium.py '
    'tests/graph/test_spatial_neighbors.py '
    'tests/graph/test_utils.py '
    'tests/graph/test_nhood.py '
    'tests/tools/test_sliding_window.py '
    'tests/tools/test_var_by_distance.py'
)

