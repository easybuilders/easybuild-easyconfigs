# Barcelona Supercomputing Center 2025

easyblock = 'PythonPackage'

name = 'seawater'
version = '3.3.5'

homepage = 'https://github.com/pyoceans/python-seawater'
description = """This is a Python re-write of the CSIRO seawater toolbox (SEAWATER-3.3) for
 calculating the properties of sea water. The package uses the formulas from Unesco's joint panel
 on oceanographic tables and standards, UNESCO 1981 and UNESCO 1983 (EOS-80)."""

toolchain = {'name': 'foss', 'version': '2023b'}

sources = [SOURCE_TAR_GZ]
checksums = ['ed3443330d76e5054ad6e3f60ac5a1e407f703504887be9352c35a9d77fd6fa8']

dependencies = [
    ('Python', '3.11.5'),
    ('SciPy-bundle', '2023.11'),
]

moduleclass = 'geo'
