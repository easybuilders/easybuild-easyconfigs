    ('matplotlib', '3.9.2'),
    ('numba', '0.60.0'),
    ('scanpy', '1.10.4'),
    ('h5py', '3.12.1'),
    ('scikit-learn', '1.5.2'),
    ('scikit-misc', '0.5.1'),
    ('leidenalg', '0.10.2'),
    ('umap-learn', '0.5.7'),
    ('pydot', '3.0.3'),
    ('igraph', '0.10.16'),
    ('python-igraph', '0.11.9'),
    ('Deprecated', '1.2.18'),
]

exts_list = [
    (name, version, {
