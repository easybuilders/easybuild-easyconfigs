# Author: Anibal Moreno
easyblock = 'GoPackage'

name = 's9s'
version = '0.6.2'

homepage = 'https://github.com/jontk/s9s'
description = "s9s - Terminal UI for SLURM"

toolchain = SYSTEM

source_urls = ['https://github.com/jontk/s9s/archive']
sources = ['v%(version)s.tar.gz']
checksums = ['720d4e168e30c0c8d67f1bc69d2698066190cffe1ee912a9fb8b8a76a273fedd']

builddependencies = [
    ('Go', '1.25.7')
]

installopts = './cmd/%(namelower)s'

sanity_check_paths = {
    'files': ['bin/%(name)s'],
    'dirs': []
}

sanity_check_commands = ['%(name)s --version']

moduleclass = 'tools'
