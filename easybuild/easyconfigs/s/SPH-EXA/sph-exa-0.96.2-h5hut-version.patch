This patch allows to define the h5hut version to download on build time.
See https://github.com/sphexa-org/sphexa/issues/587
author: Pablo Escobar ( sciCORE - University of Basel)
diff -ruN sphexa-0.96.2.orig/CMakeLists.txt sphexa-0.96.2/CMakeLists.txt
--- sphexa-0.96.2.orig/CMakeLists.txt	2026-03-23 11:25:27.000000000 +0100
+++ sphexa-0.96.2/CMakeLists.txt	2026-04-08 19:33:07.514474000 +0200
@@ -84,7 +84,9 @@
     set(HDF5_ENABLE_PARALLEL ON)
     find_package(HDF5)
     # until merged, we need the cmake branch of H5hut from ethz repo
-    set(H5hut_VERSION git.cmake)
+    if(NOT DEFINED H5hut_VERSION)
+      set(H5hut_VERSION git.cmake)
+    endif()
     set(H5hut_WITH_MPI ON)
     include(Fetch_H5hut)
     if (HDF5_FOUND AND H5hut_FOUND)
