easyblock = 'MakeCp'

name = 'SOD'
version = '0.62'

homepage = 'https://github.com/gcmt-group/sod'
description = """
SOD (standing for Site-Occupancy Disorder) is a package of tools for the computer modelling of
periodic systems with site disorder, using the supercell ensemble method.
"""

toolchain = {'name': 'GCC', 'version': '14.2.0'}

github_account = 'gcmt-group'
source_urls = [GITHUB_LOWER_SOURCE]
sources = ['%(namelower)s-v%(version)s.tar.gz']
checksums = ['88be5357fd81a05b19313c1b1f51367d026b320887b19fbe1b86bfe93f0c3fc3']

_executables = ['combsod', 'genersod', 'spbesod', 'invertOUTSOD', 'statsod', 'gcstatsod', 'peaks2spec']
files_to_copy = ['bin', 'sgo']

sanity_check_paths = {
    'files': [f'bin/{x}' for x in _executables],
    'dirs': ['bin', 'sgo'],
}

modloadmsg = """
The SOD space group library is included at:
$EBROOTSOD/sgo
"""

moduleclass = 'chem'
