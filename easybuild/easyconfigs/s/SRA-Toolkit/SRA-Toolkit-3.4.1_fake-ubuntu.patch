SRA-Toolkit hardcodes checks for only Ubuntu.
If not detected as ubuntu, it does bad things like modifying the Python installation
by updating packages.
Workaround is to pretend that we are all Ubuntu.

author: micketeer@gmail.com
--- build/env.cmake.orig	2026-06-16 17:05:55.830192228 +0200
+++ build/env.cmake	2026-06-16 17:06:23.078759022 +0200
@@ -443,11 +443,7 @@
 endif()
 #message( CONFIGTOUSE: ${CONFIGTOUSE})
 
-find_program(LSB_RELEASE_EXEC lsb_release)
-execute_process(COMMAND ${LSB_RELEASE_EXEC} -is
-    OUTPUT_VARIABLE LSB_RELEASE_ID_SHORT
-    OUTPUT_STRIP_TRAILING_WHITESPACE
-)
+set(LSB_RELEASE_ID_SHORT "Ubuntu")
 message("LSB_RELEASE_ID_SHORT: ${LSB_RELEASE_ID_SHORT}")
 
 if( Python3_EXECUTABLE )
