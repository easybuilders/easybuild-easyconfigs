easyblock = 'MakeCp'

name = 'SymFPU'
local_commit = 'c3acaf6'
version = '20190518'

homepage = 'https://github.com/martin-cs/symfpu'
description = """
A (concrete or symbolic) implementation of IEEE-754 / SMT-LIB floating-point.
"""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

source_urls = ['https://github.com/martin-cs/symfpu/archive']
sources = [{
    'download_filename': '%s.tar.gz' % local_commit,
    'filename': SOURCE_TAR_GZ,
    'extract_cmd': "tar xfvz %s && mv symfpu-* symfpu",
}]
checksums = ['1a3a442320d39e151557421865ebecb68571b7121893a45e5ccd69238b0ea017']

builddependencies = [
    ('binutils', '2.42'),
]

maxparallel = 1

files_to_copy = [
    (['core', 'utils', 'baseTypes', 'applications'], 'include/symfpu'),
    (['symfpu.a'], 'lib'),
]

sanity_check_paths = {
    'files': ['lib/symfpu.a'],
    'dirs': ['include/symfpu/core', 'include/symfpu/baseTypes'],
}

moduleclass = 'lib'
