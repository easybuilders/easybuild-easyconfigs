easyblock = 'PythonPackage'

name = 'slepc4py'
version = '3.23.3'

homepage = 'https://gitlab.com/slepc/slepc'
description = "Python bindings for SLEPc, the Scalable Library for Eigenvalue Problem Computations."

toolchain = {'name': 'foss', 'version': '2025a'}

sources = [SOURCE_TAR_GZ]
checksums = ['aa00f90939c4b312b9efe041e4f50f8f7947f50cb8c0d8f6ca60d4d78dda92c9']

builddependencies = [
    ('Cython', '3.1.1'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('SLEPc', version),
    ('petsc4py', '3.23.5'),
]

sanity_check_commands = ["mpirun -N 1 python -s -c 'from slepc4py import SLEPc'"]

moduleclass = 'tools'
