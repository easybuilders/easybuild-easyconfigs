easyblock = 'PythonBundle'

name = 'SimNIBS'
version = '4.6.0'

homepage = 'https://simnibs.github.io/simnibs'
description = "SimNIBS is a free and open source software package for the Simulation of Non-invasive Brain Stimulation"

toolchain = {'name': 'foss', 'version': '2023b'}
toolchainopts = {'pic': True, 'lowopt': True}

modloadmsg = """
WARNING: This SimNIBS module is a standalone compatibility build.

Although the module is installed under the foss/2023b toolchain, it contains a
customized Python/runtime stack for SimNIBS, including locally provided or
overridden packages such as NumPy/SciPy, PyTorch, PETSc/petsc4py-related
components, and selected binary wheels/runtime libraries.

Do not combine this module with other Python foss/2023b modules
such as SciPy-bundle, NumPy, SciPy, PyTorch, PETSc, petsc4py, h5py, numba,
matplotlib, or similar packages, unless you know exactly what you are doing.

Recommended usage: load SimNIBS as a standalone application module in a clean
software environment.
"""

