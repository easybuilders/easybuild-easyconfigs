# John Dey Fred Hutch
# Original: https://github.com/FredHutch/easybuild-life-sciences/blob/main/easyconfigs/s/svaba/svaba-1.3.0-GCCcore-13.3.0.eb
# Updated by Emik Lin (HKUMed CPOS)
easyblock = 'CMakeMakeCp'

name = 'SvABA'
version = '1.3.0'
local_commit = '4edce7e'

homepage = 'https://github.com/walaj/svaba'
description = """SvABA - Structural variation and indel analysis by assembly"""

toolchain = {'name': 'GCC', 'version': '13.3.0'}

# create tar.xz from recursive clone of repository
sources = [{
    'filename': SOURCELOWER_TAR_XZ,
    'git_config': {
        'url': 'https://github.com/walaj/',
        'repo_name': 'svaba',
        'commit': local_commit,
        'recursive': True,
    },
}]

checksums = ['5ef48e3ab0140526a7955beabfe53cc47f7b466c4d3a894d2ea780e25e86ee1a']

builddependencies = [
    ('CMake', '3.29.3'),
    ('binutils', '2.42'),
]

dependencies = [
    ('HTSlib', '1.21'),
    ('XZ', '5.4.5'),
    ('bzip2', '1.0.8'),
]

separate_build_dir = True

configopts = "-DHTSLIB_DIR=$EBROOTHTSLIB/lib "

files_to_copy = [
    (['%(namelower)s'], 'bin'),
    (['SeqLib/libseqlib.a'], 'lib'),
    (['../%(namelower)s/R'], ''),
    (['../%(namelower)s/bin/memusg.sh'], 'bin'),
    (['../%(namelower)s/bin/profiler.sh'], 'bin'),
]

modextrapaths = {'R_LIBS_SITE': 'R'}

sanity_check_commands = ['%(namelower)s --version']

sanity_check_paths = {
    'files': ['bin/%(namelower)s', 'R/%(namelower)s-annotate.R'],
    'dirs': [],
}

moduleclass = 'bio'