easyblock = 'CMakeMake'

name = 'SuiteSparse'
version = '7.12.2'

homepage = 'https://faculty.cse.tamu.edu/davis/suitesparse.html'
description = """SuiteSparse is a collection of libraries to manipulate sparse matrices."""

toolchain = {'name': 'gfbf', 'version': '2026.1'}
toolchainopts = {'unroll': True, 'pic': True}

source_urls = ['https://github.com/DrTimothyAldenDavis/SuiteSparse/archive']
sources = ['v%(version)s.tar.gz']
checksums = ['679412daa5f69af96d6976595c1ac64f252287a56e98cc4a8155d09cc7fd69e8']

builddependencies = [
    ('CMake', '4.2.1'),
    ('pkgconf', '2.5.1'),
]

dependencies = [
    ('MPFR', '4.2.2'),
]


# customize the next row to add needed cmake options
configopts = '-DBLA_VENDOR=FlexiBLAS -DSUITESPARSE_INCLUDEDIR_POSTFIX=""'

sanity_check_paths = {
    'files': ['include/amd.h', 'include/btf.h', 'include/camd.h', 'include/ccolamd.h',
              'include/cholmod.h', 'include/colamd.h', 'include/cs.h', 'include/klu.h',
              'include/ldl.h', 'include/RBio.h', 'include/SuiteSparseQR.hpp', 'include/umfpack.h',
              f'lib/libamd.{SHLIB_EXT}', f'lib/libbtf.{SHLIB_EXT}', f'lib/libcamd.{SHLIB_EXT}',
              f'lib/libccolamd.{SHLIB_EXT}', f'lib/libcholmod.{SHLIB_EXT}', f'lib/libcolamd.{SHLIB_EXT}',
              f'lib/libcxsparse.{SHLIB_EXT}', f'lib/libklu.{SHLIB_EXT}', f'lib/libldl.{SHLIB_EXT}',
              f'lib/librbio.{SHLIB_EXT}', f'lib/libspqr.{SHLIB_EXT}', f'lib/libumfpack.{SHLIB_EXT}',
              'bin/suitesparse_mongoose'],
    'dirs': ['bin', 'include', 'lib'],
}

moduleclass = 'numlib'
