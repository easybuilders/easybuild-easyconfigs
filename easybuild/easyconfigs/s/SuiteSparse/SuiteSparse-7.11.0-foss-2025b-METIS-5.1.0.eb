name = 'SuiteSparse'
version = '7.11.0'
local_metis_ver = '5.1.0'
versionsuffix = '-METIS-%s' % local_metis_ver

homepage = 'https://faculty.cse.tamu.edu/davis/suitesparse.html'
description = """SuiteSparse is a collection of libraries to manipulate sparse matrices."""

toolchain = {'name': 'foss', 'version': '2025b'}
toolchainopts = {'unroll': True, 'pic': True}

source_urls = ['https://github.com/DrTimothyAldenDavis/SuiteSparse/archive']
sources = ['v%(version)s.tar.gz']
checksums = ['93ed4c4e546a49fc75884c3a8b807d5af4a91e39d191fbbc60a07380b12a35d1']

builddependencies = [
    ('CMake', '4.0.3'),
    ('pkgconf', '2.4.3'),
]

dependencies = [
    ('MPFR', '4.2.2'),
    ('METIS', local_metis_ver),
]

# make sure that bin/demo can find libsuitesparseconfig.so.5 during build
prebuildopts = "export LD_LIBRARY_PATH=%(builddir)s/SuiteSparse-%(version)s/lib:$LD_LIBRARY_PATH && "

# customize the next row to add needed cmake options
configopts = '-DBLA_VENDOR=FlexiBLAS -DSUITESPARSE_INCLUDEDIR_POSTFIX=""'

sanity_check_paths = {
    'files': ['include/suitesparse/amd.h', 'include/suitesparse/btf.h', 'include/suitesparse/camd.h',
              'include/suitesparse/ccolamd.h', 'include/suitesparse/cholmod.h', 'include/suitesparse/colamd.h',
              'include/suitesparse/cs.h', 'include/suitesparse/klu.h', 'include/suitesparse/ldl.h',
              'include/suitesparse/RBio.h', 'include/suitesparse/SuiteSparseQR.hpp', 'include/suitesparse/umfpack.h',
              'lib/libamd.so', 'lib/libbtf.so', 'lib/libcamd.so', 'lib/libccolamd.so',
              'lib/libcholmod.so', 'lib/libcolamd.so', 'lib/libcxsparse.so', 'lib/libklu.so',
              'lib/libldl.so', 'lib/librbio.so', 'lib/libspqr.so', 'lib/libumfpack.so',
              'bin/suitesparse_mongoose'],
    'dirs': ['bin', 'include', 'lib'],
}

moduleclass = 'numlib'
