# Notes::
#
# Updated to 1.14 and gcc-11.2.0
# J. Sassmannshausen / GSTT
# Updated to 1.21 jpecar / EMBL
# Updated to 1.23.1 Franky Backeljauw / Universiteit Antwerpen
name = 'SAMtools'
version = '1.23.1'

homepage = 'https://www.htslib.org/'
description = """SAM Tools provide various utilities for manipulating alignments in the SAM format,
 including sorting, merging, indexing and generating alignments in a per-position format."""

toolchain = {'name': 'GCC', 'version': '15.2.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/%(namelower)s/%(namelower)s/releases/download/%(version)s']
sources = [SOURCELOWER_TAR_BZ2]
checksums = ['32266198a4bc6a6df395d8526688c9697d9c8e472f888c749fdde2e08ea88dd2']

# The htslib component of SAMtools >= 1.4 uses zlib, bzip2 and lzma compression.
# The latter is currently provided by XZ.
dependencies = [
    ('ncurses', '6.6'),
    ('zlib', '2.3.2'),
    ('bzip2', '1.0.8'),
    ('XZ', '5.8.2'),
    ('cURL', '8.17.0'),
]

moduleclass = 'bio'
