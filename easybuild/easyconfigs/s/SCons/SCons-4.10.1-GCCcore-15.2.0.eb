easyblock = 'PythonBundle'

name = 'SCons'
version = '4.10.1'

homepage = 'https://www.scons.org'
description = "SCons is a software construction tool."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [('binutils', '2.45')]

dependencies = [('Python', '3.14.2')]

exts_list = [
    (name, version, {
        'modulename': False,
        'sources': ['%(namelower)s-%(version)s.tar.gz'],
        'checksums': ['99c0e94a42a2c1182fa6859b0be697953db07ba936ecc9817ae0d218ced20b15'],
    }),
]

sanity_check_paths = {
    'files': ['bin/scons', 'bin/sconsign'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/%(name)s'],
}

sanity_check_commands = ["scons --help"]

moduleclass = 'devel'
