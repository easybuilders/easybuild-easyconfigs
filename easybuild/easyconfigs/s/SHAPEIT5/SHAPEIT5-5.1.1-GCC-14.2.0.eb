easyblock = 'Bundle'

name = 'SHAPEIT5'
version = '5.1.1'

homepage = 'https://odelaneau.github.io/shapeit5/'
description = """
SHAPEIT5 is a software package to estimate haplotypes in large genotype datasets (WGS and SNP array).
"""

toolchain = {'name': 'GCC', 'version': '14.2.0'}
toolchainopts = {'opt': True}

github_account = 'odelaneau'
source_urls = [GITHUB_LOWER_SOURCE]

dependencies = [
    ('zlib', '1.3.1'),
    ('bzip2', '1.0.8'),
    ('XZ', '5.6.3'),
    ('Boost', '1.88.0'),
    ('HTSlib', '1.22.1'),
]

# Get the submodule xcftools and symlink it to the right location
_xcftools_commit = 'd6ce1e2c3767113c668b8ca386bcb78c6c46dac5'
_binaries = ['phase_common', 'phase_rare', 'switch', 'ligate', 'simulate', 'xcftools']

components = [
    ('xcftools', 'd6ce1e2', {
        'easyblock': 'Tarball',  # Building happens in the SHAPEIT5 component
        'source_urls': [GITHUB_LOWER_SOURCE],
        'sources': ['%(version)s.tar.gz'],
        'patches':  ['%(name)s_d6ce1e2_use_EB_settings.patch'],
        # Let the name of the binary not be its current dir (which is %(name)s-{_xcftools_commit})
        'preinstallopts': f"sed -i '/NAME=/s/.*/NAME=xcftools/' %(name)s-{_xcftools_commit}/makefile && ",
        'checksums': [
            '5cc966d05ea48fb55ad4b1fd5e0e3133cc0d0531374dd9870ea0619ab977e204',
            'b7ee9a535f88ea56d9f2ddeeb7d0a8e2d543459f45ea73c7ce470c5e1145dad6',
        ],
    }),
    (name, version, {
        'easyblock': 'MakeCp',
        'sources':  ['v%(version)s.tar.gz'],
        'patches':  [
            ('%(name)s_5.1.1_use_EB_settings.patch', '%(namelower)s-%(version)s'),
            ('%(name)s_5.1.1_fix_isnan_and_isinf.patch', '%(namelower)s-%(version)s'),
        ],
        'start_dir': '%(namelower)s-%(version)s',
        'prebuildopts': f'rmdir xcftools && ln -s %(builddir)s/xcftools-{_xcftools_commit} xcftools && ',
        'buildopts': (
            'HTSSRC="$EBROOTHTSLIB" HTSLIB_INC="$EBROOTHTSLIB/include" HTSLIB_LIB=-lhts '
            'BOOST_INC="$EBROOTBOOST/include" BOOST_LIB_IO=-lboost_iostreams BOOST_LIB_PO=-lboost_program_options '
            'CXX="$CXX" CXXFLAG+="$CXXFLAGS" LDFLAG="$CXXFLAGS" '
        ),
        'files_to_copy': [([f'{x}/bin/{x}' for x in _binaries], 'bin'), 'resources', 'tasks'],
        'checksums': [
            '76b57d8e4734d9d77e86e8b3867bb390b620c163e7a427ee657b2ad2a9f4b8a7',
            '9cc22c8e799e66183c33d559aaaef49b1e0c166ef6604a32d5ac3dea4d5196e4',
            'd81481ddc8d75408c4c6e8f91102fdb7cc63de2c0902d3bd67982fe5831aaa71',
        ],
    }),
]

sanity_check_paths = {
    'files': [f"bin/{x}" for x in _binaries],
    'dirs': ['resources', 'tasks']
}

sanity_check_commands = [f'{x} --help' for x in _binaries]

moduleclass = 'bio'
