easyblock = 'Bundle'

name = 'Seurat'
version = '5.4.0'
versionsuffix = '-R-%(rver)s'

homepage = 'https://satijalab.org/seurat'
description = "Seurat is an R package designed for QC, analysis, and exploration of single cell RNA-seq data."

toolchain = {'name': 'foss', 'version': '2024a'}

dependencies = [
    ('R', '4.4.2'),
    ('R-bundle-Bioconductor', '3.20', versionsuffix),
]

exts_defaultclass = 'RPackage'
exts_default_options = {
    'sources': ['%(name)s_%(version)s.tar.gz'],
    'source_urls': [
        'https://cran.r-project.org/src/contrib/Archive/%(name)s',  # package archive
        'https://cran.r-project.org/src/contrib/',  # current version of packages
        'https://cran.freestatistics.org/src/contrib',  # mirror alternative for current packages
    ],
}

exts_list = [
    ('Matrix', '1.7-4', {
        'checksums': ['7b131ecb6a21ff09a33691dac7bf8a7bc2eab9fd1dd09ef14856d74346eb4779'],
