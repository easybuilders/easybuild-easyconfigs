easyblock = 'PythonBundle'

name = 'scikit-build'
version = '0.19.0'

homepage = 'https://scikit-build.readthedocs.io/en/latest'
description = """Scikit-Build, or skbuild, is an improved build system generator
for CPython C/C++/Fortran/Cython extensions."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [
    ('binutils', '2.45'),
    ('hatchling', '1.29.0'),
]

dependencies = [
    ('Python', '3.14.2'),
]

exts_list = [
    ('distro', '1.9.0', {
        'checksums': ['2fa77c6fd8940f116ee1d6b94a2f90b13b5ea8d019b98bc8bafdcabcdd9bdbed'],
    }),
    ('pyproject-metadata', '0.11.0', {
        'checksums': ['c72fa49418bb7c5a10f25e050c418009898d1c051721d19f98a6fb6da59a66cf'],
    }),
    (name, version, {
        'modulename': 'skbuild',
        'sources': ['scikit_build-%(version)s.tar.gz'],
        'checksums': ['46e1b2d71343d14e4c07d7e60902e673c78defb9a2c282b70ad80fb8502ade2e'],
    }),
]

moduleclass = 'lib'
