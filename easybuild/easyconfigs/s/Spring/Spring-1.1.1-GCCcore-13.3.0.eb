# Spring-1.1.1-GCCcore-13.3.0.eb
easyblock = 'CMakeMake'

name = 'Spring'
version = '1.1.1'

homepage = 'https://github.com/shubhamchandak94/Spring'
description = 'FASTQ compression'

toolchain = {'name': 'GCCcore', 'version': '13.3.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.29.3'),
]


source_urls = ['https://github.com/shubhamchandak94/Spring/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
patches = ['Spring-1.1.1_fix_missing_cstdint.patch']
checksums = [
    {'v1.1.1.tar.gz': 'f3fdd6317295d143b244ca9dc0ca03e132a6fec3a60b8e42a514a705d49d6264'},
    {'Spring-1.1.1_fix_missing_cstdint.patch': '4896f0b8d2309f6674a10345a140f2a146809181256c11338222fc1b521ba28a'},
]

install_cmd = " && ".join([
    "mkdir -p %(installdir)s/bin",
    "cp -r spring %(installdir)s/bin/",
])

sanity_check_paths = {
    'files': ['bin/spring'],
    'dirs': ['bin'],
}

sanity_check_commands = [
    "spring -h 2>&1 | grep 'Allowed options:'",
]

moduleclass = 'bio'
