# Spring-1.1.1-GCCcore-13.3.0.eb
easyblock = 'CMakeMake'

name = 'Spring'
version = '1.1.1'

homepage = 'https://github.com/shubhamchandak94/Spring'
description = 'FASTQ compression'

toolchain = {'name': 'GCCcore', 'version': '13.3.0'}

builddependencies = [
    ('CMake', '3.29.3'),
]


