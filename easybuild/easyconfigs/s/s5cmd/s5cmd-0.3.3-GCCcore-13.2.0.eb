easyblock = 'PythonBundle'

name = 's5cmd'
version = '0.3.3'

homepage = 'https://pypi.org/project/s3cmd/'
description = """s5cmd is a very fast S3 and local filesystem execution tool. It comes with support
 for a multitude of operations including tab completion and wildcard support for files, which can
 be very handy for your object storage workflow while working with large number of files."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

builddependencies = [('binutils', '2.40')]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('pybind11', '2.11.1'),
    ('scikit-build-core', '0.10.7'),
]

exts_list = [
    (name, version, {
        'checksums': ['1c94d2bdff2937ac1610b52aef9219f446675f8cfc820c9d607cffe80daf2e57'],
    }),
]

moduleclass = 'lib'
