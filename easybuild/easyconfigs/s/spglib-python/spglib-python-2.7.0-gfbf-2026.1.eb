easyblock = 'PythonBundle'

name = 'spglib-python'
version = '2.7.0'

homepage = 'https://pypi.python.org/pypi/spglib'
description = """Spglib for Python.

Spglib is a library for finding and handling crystal symmetries written in C.
"""

toolchain = {'name': 'gfbf', 'version': '2026.1'}

builddependencies = [
    ('scikit-build-core', '0.12.2'),
    ('pybind11', '3.0.4'),
]
dependencies = [
    ('Python', '3.14.2'),
    ('Python-bundle-PyPI', '2026.04'),
    ('SciPy-bundle', '2026.05'),
]

exts_list = [
    ('spglib', version, {
        'checksums': ['c40907a42c9dc45572f46740bf95412f84fb0eda30267e31665d104a4bde6627'],
    }),
]

moduleclass = 'chem'
