easyblock = 'CMakeMake'

name = 'SDL3_ttf'
version = '3.2.2'

homepage = 'https://github.com/libsdl-org/SDL_ttf'
description = """
This library is a wrapper around the FreeType and Harfbuzz libraries, allowing
you to use TrueType fonts to render text in SDL applications.
"""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/libsdl-org/SDL_ttf/archive/refs/tags/']
sources = ['release-%(version)s.tar.gz']
checksums = ['ff6b81d3dc39d843cc3ead6dedd68043a79513d266792ea89445547ef4e9b073']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
    ('pkgconf', '2.4.3'),
]

dependencies = [
    ('SDL3', '3.4.8'),
    ('freetype', '2.13.3'),
    ('HarfBuzz', '11.4.1'),
]

sanity_check_paths = {
    'files': ['include/SDL3_ttf/SDL_ttf.h', f'lib/libSDL3_ttf.{SHLIB_EXT}',
              'lib/pkgconfig/sdl3-ttf.pc'],
    'dirs': [],
}

moduleclass = 'lib'
