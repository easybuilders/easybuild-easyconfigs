easyblock = 'PythonPackage'

name = 'schemdraw'
version = '0.23'

homepage = 'https://schemdraw.readthedocs.io/'
description = """Schemdraw is a Python package for producing high-quality electrical circuit schematic diagrams.
Circuit elements are added, one at a time, similar to how you might draw them by hand, using Python methods.
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['e71afd5ec84edfd9b707331c5bcb49ed7133af85bd17dae461de3fc260b0132f']

builddependencies = [('binutils', '2.45')]
dependencies = [('Python', '3.14.2')]

moduleclass = 'phys'
