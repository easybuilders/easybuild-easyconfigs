easyblock = 'PythonPackage'

name = 'scifem'
version = '0.17.0'

homepage = 'https://scientificcomputing.github.io/scifem/'
description = "Scientific finite element toolbox intended to be used in conjunction with dolfinx from FEniCSx."

toolchain = {'name': 'foss', 'version': '2025b'}
toolchainopts = {'pic': True}

github_account = 'scientificcomputing'
source_urls = ['https://github.com/%(github_account)s/%(name)s/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
checksums = ['3abf12d0bc10e19285bb64af7bbf8ecb19ecb8ba4c7faa5a4519da81c5471f94']

builddependencies = [
    ('CMake', '4.0.3'),
    ('scikit-build-core', '0.11.5'),
    ('nanobind', '2.9.2'),
    ('pkgconfig', '1.5.5', '-python'),
]

dependencies = [
    ('Python', '3.13.5'),
    ('SciPy-bundle', '2025.07'),
    ('mpi4py', '4.1.0'),
    ('petsc4py', '3.24.0'),
    ('FEniCS-DOLFINx-Python', '0.10.0.post5'),
]

sanity_check_paths = {
    'files': [],
    'dirs': ['lib/python%(pyshortver)s/site-packages/%(name)s'],
}

moduleclass = 'cae'
