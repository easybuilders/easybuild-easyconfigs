# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025

easyblock = 'PythonBundle'

name = 's3cmd'
version = '2.4.0'

homepage = 'https://pypi.org/project/s3cmd/'
description = """S3cmd lets you copy files from/to Amazon S3 (Simple Storage Service) using a
 simple to use command line client. Supports rsync-like backup, GPG encryption, and more. Also
 supports management of Amazon's CloudFront content delivery network."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

builddependencies = [('binutils', '2.40')]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
]

exts_list = [
    ('python-magic', '0.4.27', {
        'modulename': 'magic',
        'checksums': ['c1ba14b08e4a5f5c31a302b7721239695b2f0f058d125bd5ce1ee36b9d9d3c3b'],
    }),
    (name, version, {
        'modulename': 'S3',
        'checksums': ['6b567521be1c151323f2059c8feec85ded96b6f184ff80535837fea33798b40b'],
    }),
]

moduleclass = 'lib'
