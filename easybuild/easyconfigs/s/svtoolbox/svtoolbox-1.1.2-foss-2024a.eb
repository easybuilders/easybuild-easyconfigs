easyblock = 'PythonBundle'

name = 'svtoolbox'
version = '1.1.2'

homepage = 'https://github.com/MOMA-AUH/svtoolbox'
description = "Tools for structural variant analysis"

toolchain = {'name': 'foss', 'version': '2024a'}

dependencies = [
    ('Python', '3.12.3', '', ('GCCcore', '13.3.0')),
    ('Pysam', '0.22.1', '', ('GCC', '13.3.0')),
    ('Python-bundle-PyPI', '2024.06', '', ('GCCcore', '13.3.0')),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/MOMA-AUH/svtoolbox/archive/refs/tags/'],
        'sources': [{'download_filename': 'v%(version)s.tar.gz', 'filename': '%(name)s-%(version)s.tar.gz'}],
        'checksums': ['5cd267ea23be97b9894032fe49b7d905c9842d09a3d59e73eec0a73a7af919f7'],
        'click_autocomplete_bins': ['svtoolbox'],
    }),
]

sanity_check_commands = [
    "python -c 'from svtoolbox import * '",
]

moduleclass = 'bio'
