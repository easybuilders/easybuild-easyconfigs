easyblock = 'CMakeMake'

name = 'LPJ-GUESS'
version = '4.1.1'

homepage = 'https://web.nateko.lu.se/lpj-guess/'
description = """LPJ-GUESS is a process-based dynamic vegetation-terrestrial ecosystem model designed for regional or
global studies. Models of this kind are commonly known as dynamic global vegetation models (DGVMs)."""

toolchain = {'name': 'gompi', 'version': '2025b'}

source_urls = ['https://zenodo.org/records/8065737/files/']
sources = ['guess_%(version)s.tar.gz']
checksums = ['b76f9237d1d8cc705deefd623df3a9cb5a268b47d385ee74522a8868f0989e9d']

builddependencies = [
    ('CMake', '4.0.3'),
]

dependencies = [
    ('netCDF', '4.9.3'),
]

configopts = '-DUNIT_TESTS=ON'

test_cmd = './runtests'

# Lacks install step
install_cmd = 'mkdir %(installdir)s/bin && cp guess %(installdir)s/bin'

sanity_check_paths = {
    'files': ['bin/guess'],
    'dirs': [],
}

sanity_check_commands = ['guess -h']

moduleclass = 'geo'
