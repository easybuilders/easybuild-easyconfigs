easyblock = 'MakeCp'

name = 'libdierckx'
version = '1993'

homepage = 'http://www.netlib.org/dierckx'
description = """Fortran subroutines for calculating smoothing splines for various
 kinds of data and geometries, with automatic knot selection"""

toolchain = {'name': 'GCC', 'version': '13.2.0'}
toolchainopts = {'pic': True, 'r8': True}

sources = [{
    'source_urls': ['https://github.com/DaanVanVugt/%(name)s/archive/refs/heads'],
    'filename': '%(name)s-%(version)s.zip',
    'download_filename': 'master.zip',
}]
patches = ['%(name)s-%(version)s_EB.patch']
checksums = [
    {'libdierckx-1993.zip': 'cb37393f9bdc536f722062918bec5f85b92f769d2b4a36108cdbe303790949e5'},
    {'libdierckx-1993_EB.patch': '247481dffcdc9e85c07c8f932eccb91cedca9543cdb8c82c1524cb63564fc881'},
]

builddependencies = [
    ('binutils', '2.40'),
]

files_to_copy = ['libdierckx.a']

sanity_check_paths = {
    'files': ['libdierckx.a'],
    'dirs':  []
}

moduleclass = 'data'
