easyblock = 'CMakeMake'

name = 'libclc'
version = '21.1.8'

homepage = 'https://libclc.llvm.org/'
description = """
libclc is an open source, BSD/MIT dual licensed implementation of the library requirements of the OpenCL
C programming language, as specified by the OpenCL 1.1 Specification.
"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/llvm/llvm-project/releases/download/llvmorg-%(version)s/']
sources = ['libclc-%(version)s.src.tar.xz']
checksums = ['6c2677362a53531c35edf482bdc9171ea0471ca0a1e9138ac9b5a1782925616f']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
    ('LLVM', '21.1.8'),
]

sanity_check_paths = {
    'files': [
        'share/pkgconfig/libclc.pc',
        'include/clc/clc.h',
    ],
    'dirs': ['include/clc', 'share/clc'],
}

moduleclass = 'lib'
