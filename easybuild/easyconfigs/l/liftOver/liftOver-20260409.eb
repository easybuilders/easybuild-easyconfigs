easyblock = 'Binary'

name = 'liftOver'
version = '20260409'

homepage = 'https://genome.ucsc.edu/'
description = 'UCSC liftOver for converting genome coordinates between assemblies.'

toolchain = SYSTEM

osdependencies = ['curl']

download_instructions = """
The binary file and license for 'liftOver' could be obtained from genome.ucsc.edu
"""

sources = [{
    'filename': 'liftOver',
    'extract_cmd': 'cp -L %s .',
}]
checksums = [None]

install_cmd = 'install -D -m 755 liftOver %(installdir)s/bin/liftOver'

sanity_check_paths = {
    'files': ['bin/liftOver'],
    'dirs': [],
}

sanity_check_commands = [
    'liftOver 2>&1 | grep "Move annotations from one assembly to another"',
]

moduleclass = 'bio'
