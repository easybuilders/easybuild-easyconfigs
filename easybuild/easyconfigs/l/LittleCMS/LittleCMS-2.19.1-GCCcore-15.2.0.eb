easyblock = 'ConfigureMake'

name = 'LittleCMS'
version = '2.19.1'

homepage = 'https://www.littlecms.com/'
description = """ Little CMS intends to be an OPEN SOURCE small-footprint color management engine,
 with special focus on accuracy and performance. """

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://sourceforge.net/projects/lcms/files/lcms/%(version)s/']
sources = ['lcms2-%(version)s.tar.gz']
checksums = ['bfc54f7bab59fbc921012014a8032e4cba4abd46db47d46b76416a8c0b2815c8']

builddependencies = [('binutils', '2.45')]

dependencies = [('libjpeg-turbo', '3.1.4.1')]

sanity_check_paths = {
    'files': ['bin/jpgicc', 'bin/linkicc', 'bin/psicc', 'bin/transicc', 'include/lcms2.h', 'include/lcms2_plugin.h',
              'lib/liblcms2.a', f'lib/liblcms2.{SHLIB_EXT}', 'lib/pkgconfig/lcms2.pc'],
    'dirs': ['share/man'],
}

moduleclass = 'vis'
