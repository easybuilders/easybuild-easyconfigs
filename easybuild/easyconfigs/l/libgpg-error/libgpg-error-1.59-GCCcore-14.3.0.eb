easyblock = 'ConfigureMake'

name = 'libgpg-error'
version = '1.59'

homepage = 'https://gnupg.org/related_software/libgpg-error/index.html'
description = """Libgpg-error is a small library that defines common error
values for all GnuPG components."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://gnupg.org/ftp/gcrypt/%(name)s/']
sources = [SOURCE_TAR_BZ2]
checksums = ['a19bc5087fd97026d93cb4b45d51638d1a25202a5e1fbc3905799f424cfa6134']

builddependencies = [('binutils', '2.44')]

sanity_check_paths = {
    'files': ['bin/gpg-error', 'include/gpg-error.h', f'lib/libgpg-error.{SHLIB_EXT}'],
    'dirs': ['share']
}

moduleclass = 'system'
