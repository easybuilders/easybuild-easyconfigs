easyblock = 'PythonBundle'

name = 'litellm'
version = '1.61.0'

homepage = 'https://www.litellm.ai'
description = """Python SDK, Proxy Server (AI Gateway) to call 100+ LLM APIs in OpenAI (or native)
 format, with cost tracking, guardrails, loadbalancing and logging. [Bedrock, Azure, OpenAI,
 VertexAI, Cohere, Anthropic, Sagemaker, HuggingFace, VLLM, NVIDIA NIM]."""

toolchain = {'name': 'gfbf', 'version': '2025a'}

builddependencies = [
    ('binutils', '2.42'),
    ('hatchling', '1.27.0'),
    ('poetry', '2.1.2'),
    ('Cython', '3.1.1'),  # builds 'uvloop'
]

