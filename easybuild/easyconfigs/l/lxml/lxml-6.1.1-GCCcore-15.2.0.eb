easyblock = 'PythonPackage'

name = 'lxml'
version = '6.1.1'

homepage = 'https://lxml.de/'
description = """The lxml XML toolkit is a Pythonic binding for the C libraries libxml2 and libxslt."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['ba96ae44888e0185281e937633a743ea90d5a196c6000f82565ebb0580012d40']

builddependencies = [
    ('binutils', '2.45'),
]

dependencies = [
    ('Python', '3.14.2'),
    ('libxml2', '2.15.1'),
    ('libxslt', '1.1.45'),
]

moduleclass = 'lib'
