easyblock = 'ConfigureMake'

name = 'libspatialite'
version = '5.1.0'

homepage = "https://www.gaia-gis.it/fossil/libspatialite/home"
description = """SpatiaLite is an open source library intended to extend the SQLite core to support
 fully fledged Spatial SQL capabilities."""

toolchain = {'name': 'GCC', 'version': '14.3.0'}
toolchainopts = {'pic': True, 'extra_cflags': '-DLIBXML_HTTP_ENABLED'}

source_urls = ['https://www.gaia-gis.it/gaia-sins/libspatialite-sources/']
sources = [SOURCE_TAR_GZ]
patches = ['%(name)s-%(version)s_no_nano_http.patch']
checksums = [
    {'libspatialite-5.1.0.tar.gz': '43be2dd349daffe016dd1400c5d11285828c22fea35ca5109f21f3ed50605080'},
    {'libspatialite-5.1.0_no_nano_http.patch': 'f5b5a5d37b9ef2c2023c2a2bdb1437301af1f92ab4b627f4df7d98c058e6d056'},
]

builddependencies = [
    ('CMake', '4.0.3'),
    ('pkgconf', '2.4.3'),
]

dependencies = [
    ('zlib', '1.3.1'),
    ('minizip', '1.1'),
    ('FreeXL', '2.0.0'),
    ('GEOS', '3.13.1'),
    ('SQLite', '3.50.1'),
    ('PROJ', '9.6.2'),
    ('libxml2', '2.14.3'),
    ('librttopo', '1.1.0'),
]

configopts = '--disable-geosadvanced'

sanity_check_paths = {
    'files': ['include/spatialite.h', 'lib/libspatialite.a', f'lib/libspatialite.{SHLIB_EXT}'],
    'dirs': [],
}

moduleclass = 'lib'
