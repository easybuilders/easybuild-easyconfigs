libxml2 deprecated and disabled their nano HTTP library.
There should therefore not be anything to clean up, which was the only place
the nano http functions where called
--- src/wfs/wfs_in.c.orig	2026-03-19 16:30:49.064352570 +0100
+++ src/wfs/wfs_in.c	2026-03-19 16:33:25.476562562 +0100
@@ -76,7 +76,6 @@
 #ifdef ENABLE_LIBXML2		/* LIBXML2 enabled: supporting XML documents */
 
 #include <libxml/parser.h>
-#include <libxml/nanohttp.h>
 
 #define MAX_GTYPES	28
 
@@ -4636,8 +4635,7 @@
 SPATIALITE_DECLARE void
 reset_wfs_http_connection (void)
 {
-/* Resets the libxml2 "nano HTTP": useful when changing the HTTP_PROXY settings */
-    xmlNanoHTTPCleanup ();
+/* libxml2 isn't build with nano HTTP anymore */
 }
 
 #else /* LIBXML2 isn't enabled */
