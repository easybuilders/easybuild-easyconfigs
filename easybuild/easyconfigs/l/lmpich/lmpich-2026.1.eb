easyblock = 'Toolchain'

name = 'lmpich'
version = '2026.1'

homepage = '(none)'
description = """LLVM based compiler toolchain, including MPICH for MPI support."""

toolchain = SYSTEM

local_llvmver = '21.1.8'

dependencies = [
    ('llvm-compilers', local_llvmver),
    ('MPICH', '5.0.1', '', ('llvm-compilers', local_llvmver)),
]

moduleclass = 'toolchain'
