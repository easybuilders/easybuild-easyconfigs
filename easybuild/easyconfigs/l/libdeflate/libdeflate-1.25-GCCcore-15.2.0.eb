easyblock = 'CMakeMake'

name = 'libdeflate'
version = '1.25'

homepage = 'https://github.com/ebiggers/libdeflate'
description = """Heavily optimized library for DEFLATE/zlib/gzip compression and decompression."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

github_account = 'ebiggers'
source_urls = [GITHUB_SOURCE]
sources = [V_VERSION_TAR_GZ]
checksums = ['d11473c1ad4c57d874695e8026865e38b47116bbcb872bfc622ec8f37a86017d']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

sanity_check_paths = {
    'files': [
        'bin/%(name)s-gunzip', 'bin/%(name)s-gzip',
        'lib/%(name)s.a', f'lib/%(name)s.{SHLIB_EXT}',
        'include/%(name)s.h',
    ],
    'dirs': [],
}
sanity_check_commands = [
    '%(name)s-gzip -h',
    '%(name)s-gunzip -h',
]

moduleclass = 'system'
