easyblock = 'MesonNinja'

name = 'LibSoup'
version = '3.7.1'

homepage = 'https://libsoup.gnome.org'
description = """libsoup is an HTTP client/server library for GNOME. It
uses GObjects and the glib main loop, to integrate well with GNOME
applications, and also has a synchronous API, for use in threaded
applications."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'cstd': 'gnu11'}

source_urls = [FTPGNOME_SOURCE]
sources = [SOURCELOWER_TAR_XZ]
checksums = ['9c96e11bb91641fe21948013499ca716393c9e9336562f9ff849c41d4edab80e']

builddependencies = [
    ('binutils', '2.45'),
    ('Meson', '1.10.2'),
    ('Ninja', '1.13.2'),
    ('pkgconf', '2.5.1'),
    ('GObject-Introspection', '1.86.0'),
    ('CMake', '4.2.1'),
]

dependencies = [
    ('libxml2', '2.15.1'),
    ('SQLite', '3.51.1'),
    ('GLib', '2.89.0'),
    ('libpsl', '0.21.5'),
    ('cURL', '8.17.0'),
    ('GnuTLS', '3.8.13'),
    ('nghttp2', '1.69.0'),
    ('glib-networking', '2.80.1'),
    ('Brotli', '1.2.0'),
]

sanity_check_paths = {
    'files': [f'lib/libsoup-3.0.{SHLIB_EXT}'],
    'dirs': ['include/libsoup-3.0/libsoup/', 'lib/pkgconfig']
}

moduleclass = 'lib'
