# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025

easyblock = 'PythonPackage'

name = 'lpsolve55'
version = '5.5.2.11'

homepage = 'https://github.com/chandu-atina/lp_solve_python_3x'
description = """lpsolve python extension for python 2.x and python 3.x.
The lpsolve extension is ported to python3.x so that it works on both python2.x and python3.x."""

toolchain = {'name': 'gfbf', 'version': '2023b'}

source_urls = ['https://sourceforge.net/projects/lpsolve/files/lpsolve/%(version)s']
sources = ['lp_solve_%(version)s_Python_source.tar.gz']
patches = [
    ('%(name)s-%(version)s_fix-setup-py.patch'),
    ('%(name)s-%(version)s_fix-pythonmod-c.patch'),
]
checksums = [
    {'lp_solve_5.5.2.11_Python_source.tar.gz': 'ceb10b18bd169afaaac5f88072f406cd7539fb07cdf5de5b83f599f94159513b'},
    {'lpsolve55-5.5.2.11_fix-setup-py.patch': '515ef54742c7a6767d6c045e143a7d0dc270035dc5ec52b12bb4a907fa46d42a'},
    {'lpsolve55-5.5.2.11_fix-pythonmod-c.patch': '3e679a3a8dd9d0eb2f3d0a6acba0124b084aa175d38fbb087487ffcdd3e5847a'},
]

dependencies = [
    ('Python', '3.11.5'),
    ('lpsolve', version),
    ('SuiteSparse', '7.7.0'),
    ('SciPy-bundle', '2023.11'),
]

prebuildopts = 'cd extra/Python && '

sanity_check_commands = ["python -c 'import lpsolve55'"]

moduleclass = 'math'
