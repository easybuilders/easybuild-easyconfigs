# This file is an EasyBuild reciPY as per https://github.com/easybuilders/easybuild
# Author: Denis Kristak
easyblock = 'CMakeMake'

name = 'libde265'
version = '1.1.0'

homepage = 'https://github.com/strukturag/libde265'
description = "libde265 is an open source implementation of the h.265 video codec"

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/strukturag/libde265/releases/download/v%(version)s/']
sources = [SOURCE_TAR_GZ]
checksums = ['afc19dd28e2fc523de5952bba5224ee1d28e286c72436d2843df126cca1181fd']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

configopts = "-DENABLE_DECODER=ON -DENABLE_SDL=OFF"

sanity_check_paths = {
    'files': ['bin/dec265', 'bin/enc265', f'lib/libde265.{SHLIB_EXT}', 'lib/pkgconfig/libde265.pc'],
    'dirs': ['include/libde265', 'lib/cmake/libde265'],
}

sanity_check_commands = [
    "dec265 --help",
    "enc265 --help",
]

moduleclass = 'tools'
