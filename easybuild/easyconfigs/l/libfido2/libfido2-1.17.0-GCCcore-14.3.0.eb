easyblock = 'CMakeMake'

name = 'libfido2'
version = '1.17.0'

homepage = 'https://github.com/yubico/libfido2'
description = 'Provides library functionality for FIDO2, including communication with a device over USB or NFC.'

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/Yubico/libfido2/archive/refs/tags/']
sources = [VERSION_TAR_GZ]
checksums = ['ace062d14a482ff9325410ff63d06c8b5fe87e79ebc18dda07add2bc0188c77f']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
]

dependencies = [
    ('libcbor', '0.13.0'),
]

osdependencies = [('libsystemd-dev', 'libudev-dev', 'systemd-devel')]

sanity_check_paths = {
    'files': [f'lib/libfido2.{SHLIB_EXT}', 'lib/libfido2.a', 'include/fido.h'],
    'dirs': [],
}

moduleclass = 'lib'
