easyblock = 'CMakeMake'

name = 'libwebsockets'
version = '4.5.8'

homepage = 'https://libwebsockets.org/'
description = """Libwebsockets (LWS) is a flexible, lightweight pure C library for
implementing modern network protocols easily with a tiny footprint, using a nonblocking
event loop. It has been developed continuously since 2010 and is used in tens of millions
of devices and by thousands of developers around the world."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}
toolchainopts = {'pic': True}

source_urls = ['https://github.com/warmcat/libwebsockets/archive/']
sources = ['v%(version)s.tar.gz']
checksums = ['b6ade658f4af3a823d0dc806ae5ef0623f0f4f5e2aeb895a0f77c4783840c30e']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3')
]

dependencies = [('libuv', '1.52.1')]

configopts = '-DLWS_WITH_LIBUV=ON'

sanity_check_paths = {
    'files': ['lib/libwebsockets.so'],
    'dirs': ['lib', 'bin', 'include', 'share'],
}

moduleclass = 'lib'
