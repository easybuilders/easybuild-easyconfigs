easyblock = 'ConfigureMake'

name = 'Leptonica'
version = '1.87.0'

homepage = 'http://www.leptonica.org'
description = """Leptonica is a collection of pedagogically-oriented open source software
 that is broadly useful for image processing and image analysis applications."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/DanBloomberg/%(namelower)s/releases/download/%(version)s/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['c73363397f96eb1295602bf44d708a994ad42046c791bf03ea0505d829bdb6a7']

builddependencies = [
    ('binutils', '2.45'),
]

dependencies = [
    ('libpng', '1.6.56'),
    ('LibTIFF', '4.7.1'),
    ('libjpeg-turbo', '3.1.4.1'),
    ('giflib', '6.1.3'),
    ('libwebp', '1.6.0'),
    ('zlib', '2.3.2'),
]

sanity_check_paths = {
    'files': ['bin/convertformat'],
    'dirs': ['include/%(namelower)s', 'lib/pkgconfig'],
}

moduleclass = 'vis'
