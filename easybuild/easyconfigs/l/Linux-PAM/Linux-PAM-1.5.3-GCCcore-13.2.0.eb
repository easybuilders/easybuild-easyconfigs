# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2026

easyblock = 'ConfigureMake'

name = 'Linux-PAM'
version = '1.5.3'

homepage = 'https://github.com/linux-pam/linux-pam'
description = """Linux-PAM (Pluggable Authentication Modules for Linux)"""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

source_urls = ['https://github.com/linux-pam/linux-pam/releases/download/v%(version)s']
sources = ['Linux-PAM-%(version)s.tar.xz']
checksums = ['7ac4b50feee004a9fa88f1dfd2d2fa738a82896763050cd773b3c54b0a818283']

builddependencies = [
    ('binutils', '2.40'),
]

dependencies = [
    ('libxslt', '1.1.38'),
    ('libtirpc', '1.3.4'),
    ('libxml2', '2.11.5'),
    ('bzip2', '1.0.8'),
    ('gettext', '0.22'),
]

configopts = (
    "--prefix=%(installdir)s --libdir=%(installdir)s/lib "
    "--enable-shared --disable-static --disable-prelude "
)

sanity_check_paths = {
    'files': [
        'lib/libpam.%s' % SHLIB_EXT,
        'lib/libpam_misc.%s' % SHLIB_EXT,
        'include/pam_appl.h',
    ],
    'dirs': ['include', 'lib/security'],
}

moduleclass = 'system'
