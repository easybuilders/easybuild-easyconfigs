easyblock = 'CMakeNinja'

name = 'level-zero'
version = '1.28.0'

homepage = 'https://github.com/oneapi-src/level-zero'
description = '''
oneAPI Level Zero Specification Headers and Loader
'''

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://github.com/oneapi-src/level-zero/archive/refs/tags/']
sources = [V_VERSION_TAR_GZ]
checksums = ['92cdffb1e55084857c63672cfe6ef03fd763dec5cca0318d9d02583bf07064a5']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
    ('Ninja', '1.13.0'),
    ('git', '2.50.1'),
]

configopts = ' '.join([
    # Tests require Intel GPU and fetch googletest with no option
    # to use system-provided one.
    '-DBUILD_L0_LOADER_TESTS=OFF'
])

sanity_check_paths = {
    'files': [
        'include/level_zero/ze_api.h',
        f'lib/libze_loader.{SHLIB_EXT}',
        'lib/pkgconfig/level-zero.pc',
    ],
    'dirs': ['']
}

moduleclass = 'lib'
