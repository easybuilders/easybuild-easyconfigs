easyblock = 'CMakeMake'

name = 'libsolv'
version = '0.7.37'

homepage = 'https://github.com/openSUSE/libsolv'
description = """This is libsolv, a free package dependency solver using a satisfiability algorithm."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

source_urls = ['https://github.com/openSUSE/libsolv/archive/refs/tags/']
sources = ['%(version)s.tar.gz']
checksums = ['ad6a38624dde26fc59c41427608536c443b76f90dcb6bb96c2e70b8e3ee20419']

builddependencies = [
    ('make', '4.4.1'),
    ('CMake', '3.31.3'),
    ('binutils', '2.42'),
]
dependencies = [
    ('expat', '2.6.4'),
]

configopts = [
    '-DENABLE_STATIC:BOOL=ON'
]

sanity_check_paths = {
    'files': [
        'lib/libsolv.a',
        'lib/libsolvext.a',
        'lib/libsolv.%s' % SHLIB_EXT,
        'lib/libsolvext.%s' % SHLIB_EXT,
    ],
    'dirs': [
        'include/solv',
        'lib/pkgconfig',
    ],
}

moduleclass = 'lib'
