easyblock = 'MesonNinja'

name = 'libdrm'
version = '2.4.133'

homepage = 'https://dri.freedesktop.org'
description = """Direct Rendering Manager runtime library."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://dri.freedesktop.org/%(name)s/']
sources = [SOURCELOWER_TAR_XZ]
checksums = ['fc68f9d0ba2ea63c9432a299e14fea09fad7a8a66e8039fcd7802ca59f77b4f5']

builddependencies = [
    ('binutils', '2.45'),
    ('pkgconf', '2.5.1'),
    ('Meson', '1.10.2'),
    ('Ninja', '1.13.2'),
]
dependencies = [
    ('X11', '20260518'),
]

# installing manpages requires an extra build dependency (docbook xsl)
configopts = '-Dman-pages=disabled'


sanity_check_paths = {
    'files': [f'lib/%(name)s.{SHLIB_EXT}', 'include/%(name)s/drm.h'],
    'dirs': ['include', 'lib'],
}

moduleclass = 'lib'
