easyblock = 'JuliaBundle'

name = 'MacroTools'
version = '0.5.16'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/FluxML/MacroTools.jl'
description = "MacroTools provides a library of tools for working with Julia code and expressions."

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
]

exts_list = [
    (name, version, {
        'source_urls': ['https://github.com/FluxML/MacroTools.jl/archive/'],
        'sources': [{
            'download_filename': '1e0228a030642014fe5cfe68c2c0a818f9e3f522.tar.gz',
            'filename': 'MacroTools-0.5.16.tar.gz',
        }],
        'checksums': [None],
    }),
]

moduleclass = 'tools'
