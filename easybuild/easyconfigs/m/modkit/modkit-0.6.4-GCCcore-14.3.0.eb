builddependencies = [
    ('binutils', '2.44'),
    ('Rust', '1.91.1'),
    ('Perl-bundle-CPAN', '5.40.2'),
]

# Disable test that fails when run in release configuration (https://github.com/nanoporetech/modkit/issues/383)
prebuildopts = ' '.join([
    'sed',
    '-i',
    '"s/    fn test_alphabet_info()/    #[cfg(debug_assertions)]\\n    fn test_alphabet_info()/"',
    'modkit-core/src/entropy/methylation_entropy.rs',
    '&&',
])
preinstallopts = 'cd modkit &&'

sanity_check_paths = {
    'files': ['bin/%(namelower)s'],
    'dirs': [],
}

sanity_check_commands = ["%(namelower)s --help"]

# Avoid failure, see https://github.com/nanoporetech/modkit/issues/520
testopts = '-- --test-threads=1'

moduleclass = 'bio'
