easyblock = 'CMakeMake'

name = 'msdf-atlas-gen'
version = '1.4'

homepage = 'https://github.com/Chlumsky/msdf-atlas-gen'
description = """This is a utility for generating compact font atlases using MSDFgen. Also includes MSDFgen."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

sources = [{
    'filename': SOURCE_TAR_XZ,
    'git_config': {
        'url': 'https://github.com/Chlumsky/',
        'repo_name': '%(namelower)s',
        'tag': 'v%(version)s',
        'recursive': True,
    },
}]
checksums = ['ab2d30124c0edb7bb4212fc27b1283d3361c57e273483101c95a5733b1ec63ae']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
]

dependencies = [
    ('freetype', '2.13.3'),
    ('tinyxml2', '11.0.0'),
]

configopts = ' '.join([
    '-DMSDFGEN_BUILD_STANDALONE=ON',
    '-DMSDFGEN_DISABLE_SVG=OFF',
    '-DMSDF_ATLAS_USE_VCPKG=OFF',
    '-DMSDF_ATLAS_USE_SKIA=OFF',
    '-DMSDF_ATLAS_BUILD_STANDALONE=ON',
    '-DMSDF_ATLAS_INSTALL=ON',
])

sanity_check_paths = {
    'files': ['bin/msdfgen', 'lib/libmsdf-atlas-gen.a', 'lib/libmsdfgen-core.a', 'lib/libmsdfgen-ext.a'],
    'dirs': ['include'],
}

moduleclass = 'math'
