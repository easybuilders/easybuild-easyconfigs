easyblock = "ConfigureMake"

name = "MSCL"
version = "1.2.5"

homepage = "https://github.com/iterorganization/MSCL"
description = "Library of numerical and mathematical routines."

toolchain = {"name": "gfbf", "version": "2025b"}
toolchainopts = {"pic": True}

source_urls = ["https://github.com/iterorganization/%(name)s/archive/refs/tags/"]
sources = [{"download_filename": "%(version)s.tar.gz", "filename": SOURCELOWER_TAR_GZ}]
checksums = ['5afcb0bf22077d3467aadda892df3829c493c7d219df2c736dc9fa0e1e552007']

builddependencies = [("binutils", "2.44")]

preconfigopts = 'echo "%s" > .tarball-version && ./bootstrap &&' % (version)
runtest = "check"

sanity_check_paths = {
    "files": ["lib/libmscl.a", "lib/pkgconfig/mscl.pc"],
    "dirs": ["lib/pkgconfig"],
}

moduleclass = "numlib"
