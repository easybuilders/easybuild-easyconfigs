easyblock = 'CMakeMake'
name = 'MOPAC'
version = '23.2.5'

homepage = 'https://github.com/openmopac/mopac'
description = """MOPAC is a general-purpose semiempirical molecular orbital package
for the study of solid state and molecular structures and reactions."""

toolchain = {'name': 'gfbf', 'version': '2025b'}
toolchainopts = {'openmp': True}

builddependencies = [
    ('CMake', '4.0.3'),
    # required by test suite
    ('SciPy-bundle', '2025.07'),
]

source_urls = ['https://github.com/openmopac/mopac/archive']
sources = ["v%(version)s.tar.gz"]
checksums = ['febb957baed8445a60660859cd2b845dc166ecf48a03c6d55babe86e88cc0470']

runtest = True

sanity_check_paths = {
    'files': ['bin/mopac', f'lib/libmopac.{SHLIB_EXT}', 'include/mopac.h'],
    'dirs': ['bin', 'lib', 'include'],
}

sanity_check_commands = [
    'echo | mopac',
    'echo | mopac-makpol',
    'echo | mopac-param',
]

moduleclass = 'chem'
