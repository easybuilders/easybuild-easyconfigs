easyblock = 'PythonBundle'

name = 'MDAnalysis'
version = '2.10.0'

homepage = 'https://www.mdanalysis.org/'
description = """MDAnalysis is an object-oriented Python library to analyze trajectories from molecular dynamics (MD)
simulations in many popular formats."""

toolchain = {'name': 'foss', 'version': '2026.1'}

builddependencies = [
    ('Cython', '3.2.4'),
]
dependencies = [
    ('Python', '3.14.2'),
    ('Python-bundle-PyPI', '2026.04'),
    ('SciPy-bundle', '2026.05'),
    ('matplotlib', '3.10.9'),
    ('tqdm', '4.67.3'),
    ('mrcfile', '1.5.4'),  # needed by GridDataFormats
    ('Biopython', '1.87'),  # optional
    ('networkx', '3.6.1'),  # optional
    ('Seaborn', '0.13.2'),  # optional
    ('scikit-learn', '1.8.0'),  # optional
    ('hypothesis', '6.153.2'),  # mdanalysistests
]

