sanity_check_commands = [
    "export OMP_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1 && "
    "pytest --disable-pytest-warnings --numprocesses %(parallel)s "
    "--pyargs MDAnalysisTests -p no:warnings --dist=loadscope "
    # Skip two XDR offset lock-file tests that are incompatible with newer filelock
    # Upstream replaced these tests in PR #5237
    "--deselect=coordinates/test_xdr.py::TestTRRReader_offsets::test_offset_lock_created "
    "--deselect=coordinates/test_xdr.py::TestXTCReader_offsets::test_offset_lock_created"
]

moduleclass = 'bio'
