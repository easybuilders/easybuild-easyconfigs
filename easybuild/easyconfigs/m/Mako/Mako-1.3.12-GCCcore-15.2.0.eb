easyblock = 'PythonBundle'

name = 'Mako'
version = '1.3.12'

homepage = 'https://www.makotemplates.org'
description = """A super-fast templating language that borrows the best ideas from the existing templating languages"""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [('binutils', '2.45')]

dependencies = [('Python', '3.14.2')]

exts_list = [
    ('MarkUpSafe', '3.0.3', {
        'sources': ['%(namelower)s-%(version)s.tar.gz'],
        'checksums': ['722695808f4b6457b320fdc131280796bdceb04ab50fe1795cd540799ebe1698'],
    }),
    (name, version, {
        'sources': ['%(namelower)s-%(version)s.tar.gz'],
        'checksums': ['9f778e93289bd410bb35daadeb4fc66d95a746f0b75777b942088b7fd7af550a'],
    }),
]

sanity_check_paths = {
    'files': ['bin/mako-render'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/%(namelower)s'],
}

sanity_check_commands = ["mako-render --help"]

moduleclass = 'devel'
