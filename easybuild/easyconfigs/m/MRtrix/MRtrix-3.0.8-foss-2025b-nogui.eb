# Updated to version 3.0.8 and dependency to ANTs added
# Author: J. Saßmannshausen (Imperial College London/UK)

name = 'MRtrix'
version = '3.0.8'
versionsuffix = '-nogui'

homepage = 'http://www.brain.org.au/software/index.html#mrtrix'
description = """MRtrix provides a set of tools to perform diffusion-weighted
MR white-matter tractography in a manner robust to crossing fibres, using
constrained spherical deconvolution (CSD) and probabilistic streamlines."""

toolchain = {'name': 'foss', 'version': '2025b'}
toolchainopts = {'cstd': 'c++11'}

source_urls = ['https://github.com/MRtrix3/mrtrix3/archive/']
sources = ['%(version)s.tar.gz']
checksums = ['9c694934781c287c51a0d35ad5d7687b529e5c04e3b2ac0985599b0c48644721']

builddependencies = [
    ('Eigen', '3.4.0'),
    ('pkgconf', '2.4.3'),
]
dependencies = [
    ('zlib', '1.3.1'),
    ('Python', '3.13.5'),
    ('LibTIFF', '4.7.0'),
    ('FFTW', '3.3.10'),
    ('libpng', '1.6.50'),
    ('ANTs', '2.6.5'),
]

configopts = '-nogui '

postinstallcmds = ['mv %(builddir)s/share %(installdir)s/']

moduleclass = 'bio'
