# Template for a mixed bundle of components using different easyblocks on GCCcore 12.3.0
easyblock = 'CMakeMake'

name = 'MOAB'
version = '5.6.0'

homepage = 'https://sigma.mcs.anl.gov/moab-library/'
description = """
MOAB (Mesh-Oriented datABase) is a library for handling 3D-surface mashes
"""

toolchain = {'name': 'foss', 'version': '2023b'}


source_urls = ['http://bitbucket.org/fathomteam/%(namelower)s/get']
sources = [{'download_filename': '%s.tar.gz' % '3fa8ae9e8025e0c1349792dee1f39b82ad8c1a33',
            'filename': '%(namelower)s-%(version)s.tar.gz'}]

builddependencies = [
    ('CMake', '3.27.6'),
    ('make', '4.4.1'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('HDF5', '1.14.3'),
    ('h5py', '3.11.0'),
    ('SciPy-bundle', '2023.11'),
]

sanity_check_paths = {
    'files': ['bin/mbskin', 'lib/libMOAB.so.%(version)s'],
    'dirs': ['lib', 'include', 'include/moab'],
}

sanity_check_commands = [
    "mbskin -h",
]

moduleclass = 'lib'
