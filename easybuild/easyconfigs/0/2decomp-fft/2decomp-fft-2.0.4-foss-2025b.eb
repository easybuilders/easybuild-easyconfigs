easyblock = 'CMakeMake'
name = '2decomp-fft'
version = '2.0.4'

homepage = 'https://2decomp-fft.github.io/'
description = """The 2DECOMP&FFT library is a software framework written in modern Fortran to build large-scale
parallel applications.
"""

toolchain = {'name': 'foss', 'version': '2025b'}

github_account = '%(name)s'
source_urls = [GITHUB_SOURCE]
sources = [V_VERSION_TAR_GZ]
checksums = ['aedc767c66f43aea6a4aa88d1004a983a5837db077a28a02a0e870cdb2a2c4a5']

configopts = "-DFFT_Choice=fftw "

builddependencies = [
    ('CMake', '3.31.8'),
]

sanity_check_paths = {
    'files': ['lib/libdecomp2d.a'],
    'dirs': ['include'],
}

moduleclass = 'numlib'
