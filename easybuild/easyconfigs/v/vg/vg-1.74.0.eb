easyblock = 'Binary'

name = 'vg'
version = '1.74.0'

homepage = 'https://github.com/vgteam/vg'
description = 'Variation graph toolkit for genome graph construction, mapping, and variant calling.'

toolchain = SYSTEM

source_urls = ['https://github.com/vgteam/vg/releases/download/v%(version)s/']
sources = ['vg']
checksums = ['406864ece481148e47435bf2518e23e4939a473f3f51678be7e539ad9029242d']

install_cmd = "mkdir -p %(installdir)s/bin && cp %(builddir)s/vg %(installdir)s/bin/vg && chmod +x %(installdir)s/bin/vg"

sanity_check_paths = {
    'files': ['bin/vg'],
    'dirs': [],
}

sanity_check_commands = [
    'vg version',
    'vg help',
]

moduleclass = 'bio'
