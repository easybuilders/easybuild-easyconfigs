# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2026

easyblock = 'CargoPythonPackage'

name = 'vl-convert-python'
version = '1.2.3'

homepage = 'https://github.com/vega/vl-convert'
description = """
 VlConvert provides a Rust library, CLI utility, and Python library for converting
 Vega-Lite chart specifications into static images (SVG or PNG) or Vega chart specifications."""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

builddependencies = [
    ('binutils', '2.40'),
    ('Rust', '1.76.0'),
    ('maturin', '1.5.0', '-Rust-1.76.0'),
]

dependencies = [
    ('Python', '3.11.5'),
]

options = {'modulename': 'vl_convert'}

