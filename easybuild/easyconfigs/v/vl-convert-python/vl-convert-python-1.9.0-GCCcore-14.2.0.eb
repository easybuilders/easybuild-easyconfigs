easyblock = 'CargoPythonPackage'

name = 'vl-convert-python'
version = '1.9.0'

homepage = 'https://github.com/vega/vl-convert'
description = """VlConvert provides a Rust library, CLI utility, and Python library for
 converting Vega-Lite chart specifications into static images (SVG or PNG) or Vega chart
 specifications."""

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

builddependencies = [
    ('binutils', '2.42'),
    ('Rust', '1.91.1'),
    ('maturin', '1.8.3'),
]

dependencies = [
    ('Python', '3.13.1'),
]

options = {'modulename': 'vl_convert'}

