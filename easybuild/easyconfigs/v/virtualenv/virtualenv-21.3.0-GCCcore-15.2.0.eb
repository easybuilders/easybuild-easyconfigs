easyblock = 'PythonBundle'

name = 'virtualenv'
version = '21.3.0'

homepage = 'https://github.com/pypa/virtualenv'
description = "A tool for creating isolated virtual python environments."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}
toolchainopts = {'pic': True}

builddependencies = [
    ('binutils', '2.45'),
    ('hatchling', '1.29.0'),
]
dependencies = [('Python', '3.14.2')]

exts_list = [
    ('distlib', '0.4.0', {
        'checksums': ['feec40075be03a04501a973d81f633735b4b69f98b05450592310c0f401a4e0d'],
    }),
    ('filelock', '3.28.0', {
        'checksums': ['4ed1010aae813c4ee8d9c660e4792475ee60c4a0ba76073ceaf862bd317e3ca6'],
    }),
    ('platformdirs', '4.9.6', {
        'checksums': ['3bfa75b0ad0db84096ae777218481852c0ebc6c727b3168c1b9e0118e458cf0a'],
    }),
    ('python-discovery', '1.2.2', {
        'checksums': ['876e9c57139eb757cb5878cbdd9ae5379e5d96266c99ef731119e04fffe533bb'],
    }),
    (name, version, {
        'checksums': ['733750db978ec95c2d8eb4feadaa57091002bce404cb39ba69899cf7bd28944e'],
    }),
]

sanity_check_paths = {
    'files': ['bin/%(namelower)s'],
    'dirs': ['lib/python%(pyshortver)s/site-packages/%(namelower)s'],
}

sanity_check_commands = ["virtualenv --help"]

moduleclass = 'tools'
