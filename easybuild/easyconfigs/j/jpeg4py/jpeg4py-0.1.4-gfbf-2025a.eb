easyblock = 'PythonBundle'

name = 'jpeg4py'
version = '0.1.4'

homepage = 'https://github.com/ajkxyz/jpeg4py'
description = "Python cffi bindings and helper classes for libjpeg-turbo"

toolchain = {'name': 'gfbf', 'version': '2025a'}

dependencies = [
    ('Python', '3.13.1'),
    ('libjpeg-turbo', '3.1.0'),
    ('cffi', '1.17.1'),
    ('SciPy-bundle', '2025.06'),
]

exts_list = [
    ('jpeg4py', version, {
        'checksums': ['cec3adcb110bd1391659670f2fe64d2a70a0218e84fdb7b08506107946d3bdb0'],
    }),
]

moduleclass = 'lib'
