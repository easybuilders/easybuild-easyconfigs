        'julia-1.12.2-linux-x86_64.tar.gz':
            'a6d0c39ea57303ebcffa7a8d453429b86eb271e150c7cb0f5958fe65909b493a',
        'julia-1.12.2-linux-aarch64.tar.gz':
            '0383a2ce378b64356269f6f15e612f344523f507a9753f71a0b64ca02092445b',
    }
]

moduleclass = 'lang'
