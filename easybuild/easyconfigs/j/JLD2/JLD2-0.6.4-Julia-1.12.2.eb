easyblock = 'JuliaBundle'

name = 'JLD2'
version = '0.6.4'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/JuliaIO/JLD2.jl'
description = "JLD2 is a package for the julia programming language for saving and loading data."

toolchain = SYSTEM

builddependencies = [
    ('Aqua', '0.8.14', versionsuffix),
    ('TestItemRunner', '1.1.5', versionsuffix),
]

dependencies = [
    ('Julia', _julia_ver),
    ('MacroTools', '0.5.16', versionsuffix),
    ('OrderedCollections', '1.8.1', versionsuffix),
    ('ScopedValues', '1.6.2', versionsuffix),
    ('Requires', '1.3.1', versionsuffix),
    ('PrecompileTools', '1.3.3', versionsuffix),
    ('ChunkCodec', '1.0.1', versionsuffix),
]

exts_list = [
    ('FileIO', '1.18.0', {
        'source_urls': ['https://github.com/JuliaIO/FileIO.jl/archive/'],
        'checksums': [None],
    }),
    ('UnPack', '1.0.2', {
        'source_urls': ['https://github.com/mauro3/UnPack.jl/archive/'],
        'checksums': [None],
    }),
    ('JLD2Bzip2', version, {
        'source_urls': ['https://github.com/JuliaIO/JLD2.jl/archive/'],
        'start_dir': 'filterpkgs/JLD2Bzip2',
        'checksums': [None],
    }),
    ('JLD2Lz4', version, {
        'source_urls': ['https://github.com/JuliaIO/JLD2.jl/archive/'],
        'start_dir': 'filterpkgs/JLD2Lz4',
        'checksums': [None],
    }),
    (name, version, {
        'source_urls': ['https://github.com/JuliaIO/JLD2.jl/archive/'],
        'patches': ['JLD2-0.6.4-patch_tests.patch'],
        'checksums': [None],
        # 'test_online': True,
        'runtest': True,
    }),
]

moduleclass = 'tools'
