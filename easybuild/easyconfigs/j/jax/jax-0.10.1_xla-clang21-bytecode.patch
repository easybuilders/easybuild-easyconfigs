Fix MLIR bytecode builders for Clang 21.

Building the XLA/LLVM sources bundled with JAX 0.10.1 with Clang 21 can trigger
a Clang frontend crash while compiling MLIR's BuiltinDialectBytecode.cpp. The
crash happens in generated bytecode reader code, where TableGen-generated
builders call getChecked<T>(...) for MLIR attributes/types. With Clang 21 this
can lead to a frontend assertion failure during template instantiation/overload
resolution, for example while instantiating mlir::getChecked for generated
BuiltinDialectBytecode.cpp.inc code.

This is consistent with upstream LLVM issue llvm-project#188249:
"[clang][mlir] Crash when compiling mlir/IR/BuiltinDialectBytecode.cpp".

The workaround used here changes the generated MLIR bytecode builders from
getChecked<T>(...) to get<T>(...) in the affected TableGen definitions and in
BytecodeDialectGen.cpp. This avoids the problematic Clang 21 frontend path while
preserving the generated builders needed for the JAX/XLA build. The same change
is also applied to the explicit FusedLoc and DenseResourceElementsAttr builders
in BuiltinDialectBytecode.td.

In the EasyBuild setup, this patch is applied to the extracted XLA source tree.
XLA then applies it as an LLVM patch via third_party/llvm/workspace.bzl, so the
vendored LLVM source used by the Bazel build is patched without repacking the
XLA tarball or changing Bazel archive integrity hashes.

Author: Pavel Tomanek (Inuits/Ugent) with help of ChatGPT5.5
diff --git a/third_party/llvm/workspace.bzl b/third_party/llvm/workspace.bzl
--- a/third_party/llvm/workspace.bzl
+++ b/third_party/llvm/workspace.bzl
@@ -20,6 +20,7 @@ def repo(name):
             "//third_party/llvm:zstd.patch",
             "//third_party/llvm:lit_test.patch",
             "//third_party/llvm:run_lit.patch",
+            "//third_party/llvm:clang21-bytecode.patch",
         ],
         link_files = {"//third_party/llvm:run_lit.sh": "mlir/run_lit.sh"},
     )
diff --git a/third_party/llvm/clang21-bytecode.patch b/third_party/llvm/clang21-bytecode.patch
new file mode 100644
--- /dev/null
+++ b/third_party/llvm/clang21-bytecode.patch
@@ -0,0 +1,66 @@
+Fix MLIR bytecode builders for Clang 21/22.
+
+Use get<T> rather than getChecked<T> in generated bytecode builders for
+attributes/types where getChecked is only inherited. This avoids a Clang
+21 frontend crash while compiling BuiltinDialectBytecode.cpp.inc.
+
+diff -Nru a/mlir/include/mlir/IR/BuiltinDialectBytecode.td b/mlir/include/mlir/IR/BuiltinDialectBytecode.td
+--- a/mlir/include/mlir/IR/BuiltinDialectBytecode.td
++++ b/mlir/include/mlir/IR/BuiltinDialectBytecode.td
+@@ -124,7 +124,7 @@
+   // FusedLoc::get(context, locs) may return UnknownLoc when locs is empty.
+   // Pass Attribute() explicitly to bypass the folding logic and always
+   // construct a FusedLoc via Base::getChecked.
+-  let cBuilder = "cast<FusedLoc>(getChecked<FusedLoc>([&]() { return reader.emitError(); }, context, $_args, Attribute()))";
++  let cBuilder = "cast<FusedLoc>(get<FusedLoc>(context, $_args, Attribute()))";
+ }
+ 
+ def FusedLocWithMetadata : DialectAttribute<(attr
+@@ -132,7 +132,7 @@
+   Attribute:$metadata
+ )> {
+   let printerPredicate = "$_val.getMetadata()";
+-  let cBuilder = "cast<FusedLoc>(getChecked<FusedLoc>([&]() { return reader.emitError(); }, context, $_args))";
++  let cBuilder = "cast<FusedLoc>(get<FusedLoc>(context, $_args))";
+ }
+ }
+ 
+@@ -148,7 +148,7 @@
+   ResourceHandle<"DenseResourceElementsHandle">:$rawHandle
+ )> {
+   // Note: order of serialization does not match order of builder.
+-  let cBuilder = "getChecked<$_resultType>([&]() { return reader.emitError(); }, context, type, *rawHandle)";
++  let cBuilder = "get<$_resultType>(context, type, *rawHandle)";
+ }
+ 
+ let cType = "RankedTensorType" in {
+diff -Nru a/mlir/include/mlir/IR/BytecodeBase.td b/mlir/include/mlir/IR/BytecodeBase.td
+--- a/mlir/include/mlir/IR/BytecodeBase.td
++++ b/mlir/include/mlir/IR/BytecodeBase.td
+@@ -147,11 +147,11 @@
+ 
+ class DialectAttribute<dag d> : DialectAttrOrType<d>, AttributeKind {
+   let cParser = "succeeded($_reader.readAttribute<$_resultType>($_var))";
+-  let cBuilder = "getChecked<$_resultType>([&]() { return reader.emitError(); }, context, $_args)";
++  let cBuilder = "get<$_resultType>(context, $_args)";
+ }
+ class DialectType<dag d> : DialectAttrOrType<d>, TypeKind {
+   let cParser = "succeeded($_reader.readType<$_resultType>($_var))";
+-  let cBuilder = "getChecked<$_resultType>([&]() { return reader.emitError(); }, context, $_args)";
++  let cBuilder = "get<$_resultType>(context, $_args)";
+ }
+ 
+ class DialectAttributes<string d> {
+diff -Nru a/mlir/tools/mlir-tblgen/BytecodeDialectGen.cpp b/mlir/tools/mlir-tblgen/BytecodeDialectGen.cpp
+--- a/mlir/tools/mlir-tblgen/BytecodeDialectGen.cpp
++++ b/mlir/tools/mlir-tblgen/BytecodeDialectGen.cpp
+@@ -207,8 +207,7 @@
+ 
+   if (args.empty()) {
+     ios << formatv(
+-        "return getChecked<{0}>([&]() {{ return reader.emitError(); }, "
+-        "context);\n",
++        "return get<{0}>(context);\n",
+         returnType);
+     return;
+   }
