easyblock = 'CMakeMake'

name = 'json-fortran'
version = '9.2.1'

homepage = 'https://github.com/jacobwilliams/json-fortran'
description = "JSON-Fortran: A Modern Fortran JSON API"

toolchain = {'name': 'intel-compilers', 'version': '2025.3.0'}

source_urls = ['https://github.com/jacobwilliams/json-fortran/archive/']
sources = ['%(version)s.tar.gz']
checksums = ['f1158a684a5328f6e5e970009ddb75284ef1fc4b85d6726e8cbfc6291a4e47a3']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
]

configopts = '-DUSE_GNU_INSTALL_CONVENTION=TRUE'

runtest = 'check'

# make sure the *.mod files are copied over
postinstallcmds = ['cp -f json_*.mod %(installdir)s/include']

# the static library is called libjsonfortran-static.a
sanity_check_paths = {
    'files': ['lib/libjsonfortran-static.a', f'lib/libjsonfortran.{SHLIB_EXT}',
              'include/json_module.mod', 'include/json_parameters.mod'],
    'dirs': ['include'],
}

moduleclass = 'lib'
