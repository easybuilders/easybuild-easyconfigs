easyblock = 'CMakeMake'

name = 'json-fortran'
version = '9.3.1'

homepage = 'https://github.com/jacobwilliams/json-fortran'
description = "JSON-Fortran: A Modern Fortran JSON API"

toolchain = {'name': 'GCC', 'version': '15.2.0'}

source_urls = ['https://github.com/jacobwilliams/json-fortran/archive/']
sources = ['%(version)s.tar.gz']
checksums = ['301a8d205bc7510b21c731130c30babd552c33e3f20568ce732b5e165b1f7a86']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

configopts = '-DUSE_GNU_INSTALL_CONVENTION=TRUE'

runtest = 'check'

sanity_check_paths = {
    'files': ['lib/libjsonfortran.a', f'lib/libjsonfortran.{SHLIB_EXT}',
              'include/json_module.mod', 'include/json_parameters.mod'],
    'dirs': ['include'],
}

moduleclass = 'lib'
