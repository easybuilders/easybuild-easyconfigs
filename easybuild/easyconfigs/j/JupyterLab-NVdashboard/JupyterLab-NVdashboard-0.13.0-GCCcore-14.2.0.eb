easyblock = 'PythonBundle'

name = 'JupyterLab-NVdashboard'
version = '0.13.0'

homepage = 'https://pypi.org/project/jupyterlab-nvdashboard/'
description = 'NVDashboard is a JupyterLab extension for displaying GPU usage dashboards. It enables JupyterLab users to visualize system hardware metrics within the same interactive environment they use for development.'

