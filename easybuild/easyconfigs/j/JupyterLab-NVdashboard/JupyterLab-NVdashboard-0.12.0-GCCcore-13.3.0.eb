# Author: Ehsan Moravveji (VSC, KU Leuven)

easyblock = 'PythonBundle'

name = 'JupyterLab-NVdashboard'
version = '0.12.0'

homepage = 'https://pypi.org/project/jupyterlab-nvdashboard/'
description = '''
NVDashboard is a JupyterLab extension for displaying GPU usage dashboards.
It enables JupyterLab users to visualize system hardware metrics within the
same interactive environment they use for development.
'''

toolchain = {'name': 'GCCcore', 'version': '13.3.0'}

source_urls = [PYPI_LOWER_SOURCE]

builddependencies = [
    ('hatchling', '1.24.2'),
    ('binutils', '2.42'),
]

dependencies = [
    ('Python', '3.12.3'),
    ('IPython', '8.28.0'),
    ('Python-bundle-PyPI', '2024.06'),
    ('PDM', '2.18.2'),
    ('jupyter-server', '2.14.2'),
    ('JupyterLab', '4.2.5'),
]

exts_list = [
    ('arrow', '1.4.0', {
        'checksums': ['ed0cc050e98001b8779e84d461b0098c4ac597e88704a655582b21d116e526d7'],
    }),
    ('tzdata', '2024.2', {
        'checksums': ['7d85cc416e9382e69095b7bdf4afd9e3880418a2413feec7069d533d6b4e31cc'],
    }),
    ('fqdn', '1.5.1', {
        'checksums': ['105ed3677e767fb5ca086a0c1f4bb66ebc3c100be518f0e0d755d9eae164d89f'],
    }),
    ('isoduration', '20.11.0', {
        'checksums': ['ac2f9015137935279eac671f94f89eb00584f940f5dc49462a0c4ee692ba1bd9'],
    }),
    ('webcolors', '25.10.0', {
        'checksums': ['62abae86504f66d0f6364c2a8520de4a0c47b80c03fc3a5f1815fedbef7c19bf'],
    }),
    ('pynvml', '11.5.3', {
        'checksums': ['183d223ae487e5f00402d8da06c68c978ef8a9295793ee75559839c6ade7b229'],
    }),
    ('uri-template', '1.3.0', {
        'checksums': ['0e00f8eb65e18c7de20d595a14336e9f337ead580c70934141624b6d1ffdacc7'],
    }),
    ('jupyterlab_nvdashboard', version, {
        'source_tmpl': '%(name)s-%(version)s-py3-none-any.whl',
