    }),
]

sanity_check_paths = {
    'files': [],
    'dirs': ['etc/jupyter', 'share/jupyter']
}

modextrapaths = {
    'JUPYTER_PATH': 'share/jupyter',
    'JUPYTER_CONFIG_DIR': 'etc/jupyter',
}

moduleclass = 'tools'
