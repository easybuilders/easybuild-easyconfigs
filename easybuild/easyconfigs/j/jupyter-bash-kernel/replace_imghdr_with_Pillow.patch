-import imghdr
 import json
 import os
 import re
 
+from PIL import Image   # replacement for imghdr (removed in Python >3.13)
+import io
+
 
 _TEXT_SAVED_IMAGE = "bash_kernel: saved image data to: "
 _TEXT_SAVED_HTML = "bash_kernel: saved html data to: "
@@ -97,12 +99,23 @@
         os.unlink(filename)
 
 
+def imghdr_what_bytes(data: bytes):
+    try:
+        with Image.open(io.BytesIO(data)) as img:
+            fmt = img.format
+            if fmt is None:
+                return None
+            return fmt.lower()
+    except Exception:
+        return None
+
+
 def display_data_for_image(filename):
     with open(filename, 'rb') as f:
         image = f.read()
     _unlink_if_temporary(filename)
 
-    image_type = imghdr.what(None, image)
+    image_type = imghdr_what_bytes(image) 
     if image_type is None:
         raise ValueError("Not a valid image: %s" % image)
 
