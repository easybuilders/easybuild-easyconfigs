easyblock = 'CMakeNinja'

name = 'Quickshell'
version = '0.2.1'

homepage = 'https://quickshell.org'
description = """Quickshell is a toolkit for building status bars, widgets, lockscreens, and other desktop components
using QtQuick. It can be used alongside your wayland compositor or window manager to build a complete desktop
environment."""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

source_urls = ['https://git.outfoxxed.me/quickshell/quickshell/archive/']
sources = [V_VERSION_TAR_GZ]
checksums = ['d815c5f99f4a0a28545ffaa90464420c773b7c0ab62f713d9d8735a8e7282ca7']

builddependencies = [
    ('binutils', '2.44'),
    ('CMake', '4.0.3'),
    ('Ninja', '1.13.0'),
    ('pkgconf', '2.4.3'),
    ('CLI11', '2.6.2'),
    ('glslang-SPIRV', '15.4.0'),
]

dependencies = [
    ('jemalloc', '5.3.0'),
    ('OpenGL', '2025.09'),
    ('Qt6', '6.9.3'),
    ('Wayland', '1.24.0'),
    ('X11', '20250608'),
]

configopts = ' '.join([
    '-DCRASH_REPORTER=OFF',  # skips breakpad dependency since we strip debug symbols anyway
    '-DSERVICE_PIPEWIRE=OFF',  # to many deps for pipewire for now
    '-DINSTALL_QML_PREFIX=.'
])

sanity_check_paths = {
    'files': ['bin/qs'],
    'dirs': [],
}

sanity_check_commands = ['qs -h']

moduleclass = 'vis'
