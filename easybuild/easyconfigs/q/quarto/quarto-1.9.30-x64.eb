easyblock = 'Tarball'

name = 'quarto'
version = '1.9.30'
versionsuffix = '-x64'

homepage = 'https://quarto.org/'
description = '''
    An open-source scientific and technical publishing system.
'''

toolchain = {'name': 'system', 'version': 'system'}

source_urls = ['https://github.com/quarto-dev/quarto-cli/releases/download/v%(version)s/']
sources = ['quarto-%(version)s-linux-amd64.tar.gz']
checksums = ['ed0dad104cc0a78a4607cb284008d3e424509aa26041894a807c763a467d7ddc']

modextrapaths = {'PATH': ''}

sanity_check_paths = {
    'files': ['bin/quarto'],
    'dirs': []
}

sanity_check_commands = ["quarto check"]

moduleclass = 'devel'
