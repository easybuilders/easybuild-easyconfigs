Point AICD_BaseDir to the share directory, but allow binaries to be 
detected in the bin directory.
Author: Jarne Renders (Vrije Universiteit Brussel)
diff -ruN AICD-3.0.4.orig/AICD AICD-3.0.4/AICD
--- AICD-3.0.4.orig/AICD	2026-04-08 10:16:04.266370000 +0200
+++ AICD-3.0.4/AICD	2026-04-08 10:18:52.720334267 +0200
@@ -13,7 +13,8 @@
 }
 
 # Get the canonical path of the script.
-export AICD_BaseDir="$(readlink -f $(dirname "$0"))"
+export AICD_BaseDir="$EBROOTAICD/share"
+export AICD_BinDir="$EBROOTAICD/bin"
 
 # Source the include file holding the current version. It is created during the build process.
 # If it doesn't exist, there is someting wrong.
@@ -23,12 +24,12 @@
 export PATH=$AICD_BaseDir:$PATH
 
 # Set some constants
-export AICDaufbereit=$AICD_BaseDir/AICD-extract
-export AICDremap=$AICD_BaseDir/AICD-remap
-export AICDopt=$AICD_BaseDir/AICD-opt_remap
-export AICDcube=$AICD_BaseDir/AICD-cube
-export AICDisosurface=$AICD_BaseDir/AICD-smooth_isosurface
-export Animation=$AICD_BaseDir/AICD-rotate_mol
+export AICDaufbereit=$AICD_BinDir/AICD-extract
+export AICDremap=$AICD_BinDir/AICD-remap
+export AICDopt=$AICD_BinDir/AICD-opt_remap
+export AICDcube=$AICD_BinDir/AICD-cube
+export AICDisosurface=$AICD_BinDir/AICD-smooth_isosurface
+export Animation=$AICD_BinDir/AICD-rotate_mol
 
 #-------------------------------------------------------------
 # create a temporary directory for the generated povray files
