# What: The error indicates that arg_int.c is using the isspace() function without
#       including the required header file <ctype.h>.
#
#       To fix this error the #include <ctype.h> needs to be to the arg_int.c file.
#
#       This is a common issue with older code being built with newer GCC versions 
#       that have stricter implicit function declaration checks. GCC 14.3.0 now treats 
#       implicit function declarations as errors by default (previously they were warnings).
# Author: Thomas Eylenbosch

--- argtable2-13/src/arg_int.c.orig
+++ argtable2-13/src/arg_int.c
@@ -30,6 +30,7 @@
 #include <stdlib.h>
 #include <string.h>
 #include <limits.h>
+#include <ctype.h>
 
 static int strtol0X(const char* str, const char* *ptr, int base)
     {
