# Author: Emik Lin (HKUMed CPOS)
easyblock = 'MakeCp'

name = 'AnnotSV'
version = '3.5.10'

homepage = 'https://lbgi.fr/AnnotSV/'
description = "An integrated tool for structural variations annotation and ranking"

toolchain = {'name': 'foss', 'version': '2023b'}

source_urls = ['https://github.com/lgmgeo/AnnotSV/archive/refs/tags/']
sources = [{'download_filename': 'v%(version)s.tar.gz', 'filename': '%(name)s-%(version)s.tar.gz'}]
checksums = ['3cf870cf5a5f3b495b4f23eed8fee1e06ab9a6575b1324a20244db62c1e4a015']

dependencies = [
    ('Tcl', '8.6.13'),
    ('BEDTools', '2.31.1'),
    ('BCFtools', '1.20'),
    ('Java', '17', '', SYSTEM),
    ('Python', '3.11.5'),
    ('scikit-bio', '0.6.2'),
    ('pyfaidx','0.8.1.1'),
]

files_to_copy = ['bin', 'etc', 'share', 'changeLog.txt', 'commandLineOptions.txt', 'License.txt']

modextravars = {
    'ANNOTSV': '%(installdir)s',
}

# Annotation datasets are intentionally not installed by this easyconfig.
# Users can download them with:
#   INSTALL_annotations.sh 3.5 2406
# and then pass the directory via AnnotSV -annotationsDir.
sanity_check_paths = {
    'files': ['bin/%(name)s'],
    'dirs': [],
}

sanity_check_commands = [
    '%(name)s -help',
]

moduleclass = 'bio'