# Author: Anibal Moreno

easyblock = 'Bundle'

name = 'Aspera-CLI'
version = '4.25.6'

homepage = 'https://github.com/IBM/aspera-cli'
description = "Command line interface for IBM Aspera products"

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

dependencies = [
    ('Ruby', '3.4.7'),
]

exts_default_options = {
    'source_urls': ['https://rubygems.org/downloads/'],
    'source_tmpl': '%(name)s-%(version)s.gem',
}

exts_defaultclass = 'RubyGem'

