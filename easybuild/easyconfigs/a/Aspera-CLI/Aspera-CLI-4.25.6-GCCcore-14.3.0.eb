postinstallcmds = [
    "GEM_PATH=%(installdir)s %(installdir)s/bin/ascli config ascp install --sdk_folder=%(builddir)s/tmp",
    "cp %(builddir)s/tmp/ascp %(installdir)s/bin"
]

modextrapaths = {'GEM_PATH': ['']}

sanity_check_commands = ["ascli --version"]

sanity_check_paths = {
    'files': ['bin/ascli', 'bin/ascp'],
    'dirs': [],
}

