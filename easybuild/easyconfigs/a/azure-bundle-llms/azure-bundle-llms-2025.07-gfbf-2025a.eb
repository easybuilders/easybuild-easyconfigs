easyblock = 'PythonBundle'

name = 'azure-bundle-llms'
version = '2025.07'

homepage = 'https://github.com/Azure'
description = "Azure libraries needed for LiteLLM and Data-Formulator."

toolchain = {'name': 'gfbf', 'version': '2025a'}

