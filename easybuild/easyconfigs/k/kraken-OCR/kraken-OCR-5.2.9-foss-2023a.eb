easyblock = 'PythonBundle'

name = 'kraken-OCR'
version = '5.2.9'

homepage = 'https://kraken.re/main/index.html'
description = """kraken is a turn-key OCR system optimized for historical and non-Latin script material."""

toolchain = {'name': 'foss', 'version': '2023a'}

builddependencies = [
    ('Rust', '1.70.0'),
    ('maturin', '1.1.0'),
]


dependencies = [
    ('Python', '3.11.3'),
    ('lxml', '4.9.2'),
    ('Python-bundle-PyPI', '2023.06'),
    ('SciPy-bundle', '2023.07'),
    ('Pillow', '10.0.0'),
    ('torchvision', '0.16.0'),
    ('PyTorch', '2.1.2'),
    ('scikit-learn', '1.3.1'),
    ('scikit-image', '0.22.0'),
    ('Shapely', '2.0.1'),
    ('pyvips', '2.2.3'),
    ('ImageMagick', '7.1.1-15'),
    ('Arrow', '14.0.1'),
    ('Lightning', '2.2.1'),
    ('PyTorch-Lightning', '2.2.1'),
    ('coremltools', '8.3.0'),
]

exts_list = [
    ('threadpoolctl', '3.4.0', {
        'checksums': ['f11b491a03661d6dd7ef692dd422ab34185d982466c49c8f98c8f716b5c93196'],
    }),
    ('python-bidi', '0.6.0', {
        'modulename': 'bidi',
        'checksums': ['0665a0826074a9ff8d29640c0c405a2710b671db14fcc8b1c3ee6615ff10b837'],
    }),
    ('kraken', version, {
        'preinstallopts': "sed -i 's/~=/>=/g' setup.cfg && ",
        'checksums': ['0d132267bc168bebc27b961da7c917a8584363d497eb7a63fa2bcbd51f9edcae'],
    }),
]

sanity_check_commands = [
    "kraken list",
]

moduleclass = 'ai'
