# Contribution from the NIHR Biomedical Research Centre
easyblock = 'CMakeMake'

name = 'Kalign'
version = '3.5.1'

homepage = 'https://github.com/TimoLassmann/kalign'
description = "Kalign is a fast multiple sequence alignment program for biological sequences."

toolchain = {'name': 'GCCcore', 'version': '13.3.0'}

source_urls = ['https://github.com/TimoLassmann/kalign/archive/']
sources = ['v%(version)s.tar.gz']
checksums = ['983bfd7da76010d59c3de3bae3d977cac78642c5eb061009dd12b11b9db5190d']

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.29.3'),
]

sanity_check_paths = {
    'files': ['bin/kalign'],
    'dirs': [],
}

sanity_check_commands = ["kalign --help"]

moduleclass = 'bio'
