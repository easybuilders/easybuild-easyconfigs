easyblock = 'CMakeMake'

name = 'HiGHS'
version = '1.14.0'

homepage = 'https://ergo-code.github.io/HiGHS'
description = """Open source serial and parallel solvers for large-scale sparse linear programming (LP),
mixed-integer programming (MIP), and quadratic programming (QP) models."""

toolchain = {'name': 'gfbf', 'version': '2025b'}

github_account = 'ERGO-Code'
source_urls = [GITHUB_SOURCE]
sources = [{'download_filename': V_VERSION_TAR_GZ, 'filename': SOURCE_TAR_GZ}]
checksums = ['05931e8dd8c8cac514da8297003c31a206a0004d542b7da500810b85c87c20b9']

builddependencies = [
    ('CMake', '4.0.3'),
    ('scikit-build-core', '0.11.5'),
    ('pybind11', '3.0.0'),
]

dependencies = [
    ('Python', '3.13.5'),
    ('SciPy-bundle', '2025.07'),
    ('zlib', '1.3.1'),
]

exts_defaultclass = 'PythonPackage'
exts_list = [
    ('highspy', version, {
        'source_urls': ['https://github.com/ERGO-Code/HiGHS/archive/'],
        'sources': [{'download_filename': V_VERSION_TAR_GZ, 'filename': SOURCE_TAR_GZ}],
        'checksums': ['05931e8dd8c8cac514da8297003c31a206a0004d542b7da500810b85c87c20b9'],
    }),
]

sanity_check_paths = {
    'files': ['bin/highs'],
    'dirs': ['lib/python%(pyshortver)s/site-packages'],
}

moduleclass = 'lib'
