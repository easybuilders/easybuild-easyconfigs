easyblock = 'ROCmComponent'

name = 'hipSPARSELt'
version = '3.2.0'
_rocm_version = '6.4.1'

homepage = 'https://github.com/ROCm/hipSPARSELt'
description = """hipSPARSELt is a SPARSE marshalling library, with multiple supported backends. It sits
between the application and a 'worker' SPARSE library, marshalling inputs into the backend library and
marshalling results back to the application. hipSPARSELt exports an interface that does not require the
client to change, regardless of the chosen backend. Currently, hipSPARSELt supports rocSPARSELt and
NVIDIA CUDA cuSPARSELt v0.6.3 as backends."""
docurls = ['https://rocm.docs.amd.com/projects/hipSPARSELt/en/latest/']

toolchain = {'name': 'rocm-compilers', 'version': '19.0.0-ROCm-6.4.1'}
toolchainopts = {'pic': True}

github_account = 'ROCm'
source_urls = [GITHUB_SOURCE]
sources = [f'rocm-{_rocm_version}.tar.gz']
checksums = ['74836c789e912e61532aacf275efb053ac6d0818b3da360e7b236e1b82b3152b']

local_gcc_version = '14.2.0'
builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.31.3'),
    ('Python', '3.13.1'),
    ('rocm-cmake', '0.14.0'),
    ('ROCm-LLVM', '19.0.0', f'-ROCm-{_rocm_version}', ('GCCcore', local_gcc_version)),
]

dependencies = [
    ('HIP', _rocm_version),
    ('rocSPARSE', '3.4.0'),
]

# We need to build the internal Tensile, even though we have our own module.
# This requires passing the correct python
configopts = '-DPython_ROOT=$EBROOTPYTHON '
# Limit the number of threads Tensile can use to generate code.
# Note that each thread consumes MASSIVE amounts of memory once
# building multiple GPUs (32GB RAM + 32GB Swap ran OOM for 4 threads)
# for default values. See:
# https://github.com/ROCm/hipBLASLt/issues/1834
# We also use the internal Tensile instead of the EasyBuild one, as
# hipBLASLt requires a different version, and fails when using ours
# due to files not being created as expected.
configopts += '-DTensile_CPU_THREADS=%(parallel)s '

sanity_check_paths = {
    'files': ['include/hipSPARSELt/hipSPARSELt.h',
              f'lib/libhipSPARSELt.{SHLIB_EXT}',
              'lib/cmake/hipSPARSELt/hipSPARSELt-config.cmake'],
    'dirs': ['share/doc/hipSPARSELt',
             'include/hipSPARSELt'],
}

moduleclass = 'lib'
