easyblock = 'PythonPackage'

name = 'hatch-nodejs-version'
version = '0.3.2'

homepage = 'https://github.com/jupyterlab/hatch-nodejs-version'
description = """Hatch plugin for versioning from a package.json file"""

toolchain = {'name': 'GCCcore', 'version': '13.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['8a7828d817b71e50bbbbb01c9bfc0b329657b7900c56846489b9c958de15b54c']

builddependencies = [
    ('hatchling', '1.18.0'),
]

dependencies = [
    ('Python', '3.11.5'),
]

moduleclass = 'lib'
