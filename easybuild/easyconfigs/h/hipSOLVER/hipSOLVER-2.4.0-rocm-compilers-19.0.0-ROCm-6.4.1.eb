easyblock = 'ROCmComponent'

name = 'hipSOLVER'
version = '2.4.0'
_rocm_version = '6.4.1'

homepage = 'https://github.com/ROCm/hipSOLVER'
description = """hipSOLVER is a LAPACK marshalling library, with multiple supported backends. It sits between
the application and a 'worker' LAPACK library, marshalling inputs into the backend library and marshalling
results back to the application. hipSOLVER exports an interface that does not require the client to change,
regardless of the chosen backend. Currently, hipSOLVER supports rocSOLVER and cuSOLVER as backends."""
docurls = ['https://rocm.docs.amd.com/projects/hipSOLVER/en/latest/']

toolchain = {'name': 'rocm-compilers', 'version': '19.0.0-ROCm-6.4.1'}

github_account = 'ROCm'
source_urls = [GITHUB_SOURCE]
sources = [f'rocm-{_rocm_version}.tar.gz']
patches = ['hipSOLVER-2.4.0_use_FlexiBLAS.patch']
checksums = [
    # rocm-6.4.1.tar.gz
    '86ac30d5cf741a254485ed54c7f51e4c9bc9803cda31dab8e86f11b39742b28e',
    # hipSOLVER-2.4.0_use_FlexiBLAS.patch
    'd48f8b87f1eeeedd33b2aed85200750e0a4dfe6efc3ce7495307699e37aaf8a3',
]

builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.31.3'),
    ('rocm-cmake', '0.14.0'),
]

dependencies = [
    ('HIP', _rocm_version),
    ('rocBLAS', '4.4.0'),
    ('rocSOLVER', '3.28.0'),
    ('SuiteSparse', '7.10.3', '', ('foss', '2025a')),
]

configopts = '-DCUSTOM_ROCBLAS=$EBROOTROCBLAS -DCUSTOM_ROCSOLVER=$EBROOTROCSOLVER '
configopts += '-DBUILD_WITH_SPARSE=ON -DCUSTOM_ROCSPARSE=$EBROOTROCSPARSE '
configopts += '-DBUILD_BOOST=OFF -DBUILD_GTEST=OFF -DBUILD_LAPACK=OFF '

sanity_check_paths = {
    'files': ['include/hipsolver/hipsolver.h',
              f'lib/libhipsolver.{SHLIB_EXT}',
              'lib/cmake/hipsolver/hipsolver-config.cmake'],
    'dirs': ['share/doc/hipsolver',
             'include/hipsolver'],
}

moduleclass = 'lib'
