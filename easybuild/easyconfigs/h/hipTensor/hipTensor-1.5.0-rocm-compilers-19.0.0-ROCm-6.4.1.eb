easyblock = 'ROCmComponent'

name = 'hipTensor'
version = '1.5.0'
_rocm_version = '6.4.1'

homepage = 'https://github.com/ROCm/hipTensor'
description = """hiptensor is AMD's C++ library for accelerating tensor primitives
using GPU matrix cores on AMD's latest discrete GPUs."""
docurls = ['https://rocm.docs.amd.com/projects/hipTensor/en/latest/']

toolchain = {'name': 'rocm-compilers', 'version': '19.0.0-ROCm-6.4.1'}

github_account = 'ROCm'
source_urls = [GITHUB_SOURCE]
sources = [f'rocm-{_rocm_version}.tar.gz']
checksums = ['25d9d63bc4aef76e64b679b14c0fb102a0d513a3ab188d66ed91ac9bd35c5f39']

local_gcc_version = '14.2.0'
builddependencies = [
    ('binutils', '2.42'),
    ('CMake', '3.31.3'),
]

dependencies = [
    ('HIP', _rocm_version),
    ('composable_kernel', '1.1.0'),
]

sanity_check_paths = {
    'files': ['lib/cmake/hiptensor/hiptensorConfig.cmake',
              'include/hiptensor/hiptensor.hpp',
              'bin/hiptensor/bench/scripts/BenchmarkReduction.sh'],
    'dirs': ['lib/cmake/hiptensor',
             'share/doc/hiptensor',
             'include/hiptensor'],
}

moduleclass = 'lib'
