easyblock = 'JuliaBundle'

name = 'HashArrayMappedTries'
version = '0.2.0'
_julia_ver = '1.12.2'
versionsuffix = "-Julia-%s" % _julia_ver

homepage = 'https://github.com/vchuravy/HashArrayMappedTries.jl'
description = """A HashArrayMappedTrie or HAMT for short, is a data-structure that can be used efficient
persistent hash tables."""

toolchain = SYSTEM

dependencies = [
    ('Julia', _julia_ver),
]

exts_list = [
    (name, version, {
        'runtest': True,
        'source_urls': ['https://github.com/vchuravy/HashArrayMappedTries.jl/archive/'],
        'checksums': ['27e767bd47f2b344a4ddc4bc5e7006c2993f692918aa5791a330773112ad3b1d'],
    }),
]

moduleclass = 'tools'
