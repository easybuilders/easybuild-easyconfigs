easyblock = 'PythonBundle'

name = 'hatchling'
version = '1.29.0'

homepage = 'https://hatch.pypa.io'
description = """Extensible, standards compliant build backend used by Hatch,
a modern, extensible Python project manager."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

builddependencies = [('binutils', '2.45')]
dependencies = [('Python', '3.14.2')]

exts_list = [
    ('pathspec', '1.1.1', {
        'checksums': ['17db5ecd524104a120e173814c90367a96a98d07c45b2e10c2f3919fff91bf5a'],
    }),
