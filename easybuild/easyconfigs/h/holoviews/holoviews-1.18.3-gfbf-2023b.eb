# Barcelona Supercomputing Center 2024

easyblock = 'PythonPackage'

name = 'holoviews'
version = '1.18.3'

homepage = 'https://github.com/holoviz/holoviews'
description = """HoloViews is an open-source Python library designed to make data analysis and
 visualization seamless and simple. With HoloViews, you can usually express what you want to do in
 very few lines of code, letting you focus on what you are trying to explore and convey, not on the
 process of plotting."""

toolchain = {'name': 'gfbf', 'version': '2023b'}

sources = [SOURCE_TAR_GZ]
checksums = ['578e30e89d72754f97a83ebe08198fec8e87cc7e49b25b9f31ec393f939ca500']

builddependencies = [
    ('binutils', '2.40'),
]

dependencies = [
    ('Python', '3.11.5'),
    ('Python-bundle-PyPI', '2023.10'),
    ('SciPy-bundle', '2023.11'),
    ('param', '2.1.0'),
    ('pyct', '0.5.0'),
    ('pyviz-comms', '3.0.2'),
    ('panel', '1.3.8'),
    ('colorcet', '3.1.0'),
]

moduleclass = 'vis'
