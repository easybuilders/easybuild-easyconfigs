easyblock = 'CMakeMake'

name = 'HDF5'
version = '2.1.1'

homepage = 'https://portal.hdfgroup.org/display/support'
description = """HDF5 is a data model, library, and file format for storing and managing data.
 It supports an unlimited variety of datatypes, and is designed for flexible
 and efficient I/O and for high volume and complex data."""

toolchain = {'name': 'gompi', 'version': '2026.1'}
toolchainopts = {'pic': True, 'usempi': True}

source_urls = ['https://github.com/HDFGroup/hdf5/releases/download/%(version)s/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['efff93b5a904d66e8f626d7da60b5eedc9faf544be27dbabbaa87967b8ad798b']

builddependencies = [('CMake', '4.2.1')]

dependencies = [
    ('libaec', '1.1.7'),
    ('Perl', '5.42.0'),
    ('zlib', '2.3.2'),
]

preconfigopts = 'export LDFLAGS="$LDFLAGS -pthread" && '
preconfigopts += 'export RUNPARALLEL="mpirun -np $${NPROCS:=3}" && '
configopts = ' '.join([
    '-DHDF5_BUILD_CPP_LIB=ON',
    '-DHDF5_BUILD_FORTRAN=ON',
    '-DHDF5_ENABLE_ZLIB_SUPPORT=ON',
    '-DHDF5_ENABLE_SZIP_SUPPORT=ON',
    '-DHDF5_ENABLE_THREADSAFE=ON',
    '-DHDF5_ALLOW_UNSUPPORTED=ON',  # fortran+threadsafe requires unsupported
    '-DHDF5_ENABLE_PARALLEL=ON',
])

_extra_binaries = ["h5perf", "h5pcc", "h5pfc", "ph5diff"]
_h5binaries = ["c++", "copy", "debug", "diff", "dump", "import", "jam", "ls", "mkgrp", "perf_serial",
               "repack", "repart", "stat", "unjam"]
_binaries = ["h5%s" % x for x in _h5binaries] + _extra_binaries
_libs = [f"libhdf5{lib}.{SHLIB_EXT}" for lib in ['', '_cpp', '_fortran', '_hl_cpp', '_hl', '_hl_fortran']]

sanity_check_paths = {
    'files': [f"bin/{x}" for x in _binaries] + [f"lib/{lib}" for lib in _libs],
    'dirs': ['include'],
}

modextravars = {'HDF5_DIR': '%(installdir)s'}

moduleclass = 'data'
