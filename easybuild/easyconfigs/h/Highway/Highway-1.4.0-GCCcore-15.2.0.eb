easyblock = 'CMakeMake'

name = 'Highway'
version = '1.4.0'

homepage = 'https://github.com/google/highway'

description = """Highway is a C++ library for SIMD (Single Instruction, Multiple Data), i.e. applying the same
operation to 'lanes'."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/google/highway/archive/refs/tags/']
sources = ['%(version)s.tar.gz']
checksums = [
    {'1.4.0.tar.gz': 'e72241ac9524bb653ae52ced768b508045d4438726a303f10181a38f764a453c'},
]

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
    ('googletest', '1.17.0'),
]

configopts = "-DHWY_SYSTEM_GTEST=ON"

runtest = "test"

sanity_check_paths = {
    'files': ['lib/libhwy.a'],
    'dirs': ['include/hwy'],
}

moduleclass = 'lib'
