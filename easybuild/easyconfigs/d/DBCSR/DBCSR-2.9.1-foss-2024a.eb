easyblock = 'CMakeMake'

name = 'DBCSR'
version = '2.9.1'

homepage = 'https://cp2k.github.io/dbcsr'
description = """DBCSR is a library designed to efficiently perform sparse matrix-matrix multiplication, among other
operations. DBCSR stands for Distributed Blocked Compressed Sparse Row."""

toolchain = {'name': 'foss', 'version': '2024a'}
toolchainopts = {'pic': True, 'openmp': True}

source_urls = ['https://github.com/cp2k/%(namelower)s/releases/download/v%(version)s']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['fa5a4aeba0a07761511af2c26c779bd811b5ea0ef06a5d94535b6dd7b2e0ce59']

builddependencies = [
    ('CMake', '3.31.8'),
    ('pkgconf', '2.2.0'),
]

dependencies = [
#    ('libxsmm', '1.17'),
]

configopts = ' '.join([
#    '-DLIBXSMMROOT=$EBROOTLIBXSMM/lib',
])

sanity_check_paths = {
    'files': ['include/dbcsr_tensor_api.mod', 'include/dbcsr.h', 'lib/libdbcsr.a'],
    'dirs': ['lib/cmake/dbcsr'],
}

moduleclass = 'chem'
