easyblock = 'Binary'

name = 'DuckDB'
version = '1.4.4'

homepage = 'https://duckdb.org'
description = """DuckDB is a fast in-process database system."""

toolchain = SYSTEM

local_archs = {'aarch64': 'arm64', 'x86_64': 'amd64'}
source_urls = ['https://install.duckdb.org/v%(version)s/']
sources = [{
    'download_filename': '%%(namelower)s_cli-linux-%s.zip' % local_archs[ARCH],
    'filename': '%%(namelower)s_cli-%%(version)s-linux-%s.zip' % local_archs[ARCH],
    'extract_cmd': 'unzip -p %s > %(namelower)s'
}]

checksums = [{
    '%(namelower)s_cli-%(version)s-linux-amd64.zip': 'ea79eae4233f1aba9a020c8a61877de38a789bc62cdd37485d3589cd77dc0d3e',
    '%(namelower)s_cli-%(version)s-linux-arm64.zip': '97995363217ddef691fe53b26df3b55ff368d356613d9daaea5999bb7a637e60',
}]

extract_sources = True

postinstallcmds = [
    'mkdir -p %(installdir)s/bin',
    'mv %(installdir)s/%(namelower)s %(installdir)s/bin/',
    'chmod 755 %(installdir)s/bin/%(namelower)s',
]

sanity_check_paths = {
    'files': ['bin/%(namelower)s'],
    'dirs': [],
}

sanity_check_commands = [
    "duckdb -version",
    "duckdb -help || true",
]

moduleclass = 'data'
