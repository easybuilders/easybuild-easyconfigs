easyblock = 'CMakeMake'

name = 'double-conversion'
version = '3.4.0'

homepage = 'https://github.com/google/double-conversion'
description = "Efficient binary-decimal and decimal-binary conversion routines for IEEE doubles."

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/google/%(name)s/archive']
sources = ['v%(version)s.tar.gz']
checksums = ['42fd4d980ea86426e457b24bdfa835a6f5ad9517ddb01cdb42b99ab9c8dd5dc9']

builddependencies = [
    ('binutils', '2.45'),
    ('CMake', '4.2.1'),
]

# Build static lib, static lib with -fPIC and shared lib
configopts = [
    # v3.3.1 doesn't support CMake 4.0 yet. Bump policy (and therefore minimum version)
    # to 3.15, as done upstream: https://github.com/google/double-conversion/pull/246
    x + "-DCMAKE_POLICY_VERSION_MINIMUM=3.15 "
    for x in [
        "",
        "-DCMAKE_POSITION_INDEPENDENT_CODE=ON -DCMAKE_STATIC_LIBRARY_SUFFIX_CXX=_pic.a ",
        "-DBUILD_SHARED_LIBS=ON ",
    ]
]

sanity_check_paths = {
    'files': [f'include/double-conversion/{h}.h' for h in ['bignum', 'cached-powers', 'diy-fp', 'double-conversion',
                                                           'fast-dtoa', 'fixed-dtoa', 'ieee', 'strtod', 'utils']] +
             [f'lib/libdouble-conversion.{e}' for e in ['a', SHLIB_EXT]] + ['lib/libdouble-conversion_pic.a'],
    'dirs': [],
}

moduleclass = 'lib'
