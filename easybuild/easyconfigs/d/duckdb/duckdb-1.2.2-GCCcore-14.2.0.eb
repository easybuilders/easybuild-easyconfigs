# Author: Stamen Miroslavov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2026

easyblock = 'PythonPackage'

name = 'duckdb'
version = '1.2.2'

homepage = 'https://duckdb.org'
description = "DuckDB is an in-process SQL OLAP database management system."

toolchain = {'name': 'GCCcore', 'version': '14.2.0'}

sources = [SOURCE_TAR_GZ]
checksums = ['1e53555dece49201df08645dbfa4510c86440339889667702f936b7d28d39e43']

builddependencies = [
    ('CMake', '3.31.3'),
    ('Ninja', '1.12.1'),
    ('pybind11', '2.13.6'),
]

dependencies = [
    ('Python', '3.13.1'),
    ('Python-bundle-PyPI', '2025.04'),
]

sanity_check_commands = ['python -c "import %(name)s; %(name)s.sql(\'SELECT 42\').show()"']

moduleclass = 'lib'
