This patch removes a hardcoded prefix in the conda generating YAML file,
and adds a missing pytorch channel.
Author: Stamen Miroslavov Minkov <stamen.miroslavov@bsc.es>
Barcelona Supercomputing Center 2025
diff -ruBbw a/requirements/deep4downscaling-cpu.yml b/requirements/deep4downscaling-cpu.yml
--- a/requirements/deep4downscaling-cpu.yml	2025-01-17 09:49:25.000000000 +0100
+++ b/requirements/deep4downscaling-cpu.yml	2025-04-03 17:58:26.259922591 +0200
@@ -1,5 +1,6 @@
 name: deep4downscaling-cpu
 channels:
+  - pytorch
   - conda-forge
 dependencies:
   - conda-forge/linux-64::_libgcc_mutex==0.1=conda_forge
@@ -275,4 +276,3 @@
   - netcdf4
   - bottleneck
   - xskillscore
-prefix: /opt/conda/envs/deep4downscaling-cpu
