# Author: Stamen Miroslavov Minkov <stamen.miroslavov@bsc.es>
# Barcelona Supercomputing Center 2025
# CPU version of the software

easyblock = 'Conda'

name = 'deep4downscaling-CPU'
version = '1.0.0'
versionsuffix = '-conda'

homepage = 'https://github.com/SantanderMetGroup/deep4downscaling'
description = """deep4downscaling is a Python library designed for developing deep learning models
 for statistical downscaling. The library focuses on two main objectives: Ease of Research and
 Established Deep Learning Models. In addition to these main goals, deep4downscaling includes:
 Comprehensive Evaluation Metrics and eXplainable Artificial Intelligence (XAI) Techniques Tailored
 for Downscaling."""

toolchain = SYSTEM

source_urls = ['https://github.com/SantanderMetGroup/deep4downscaling/archive/refs/tags']
sources = ['v%(version)s.tar.gz']
patches = ['deep4downscaling-CPU-1.0.0_fix-yaml-file.patch']
checksums = [
    # v1.0.0.tar.gz:
    'fb7640516fd8499839f67ee1553d5b6d54068c0553f5c0e747fd54ccacc3c204',
    # deep4downscaling-CPU-1.0.0_fix-yaml-file.patch:
    '150d9234dd0d90089293dd1f7ad2e8d6ebc6795427c6c74237fe15eb361a541d',
]

extract_sources = True

builddependencies = [('Miniconda3', '23.9.0-0')]

environment_file = "requirements/deep4downscaling-cpu.yml"

postinstallcmds = [
    'cp -r %(builddir)s/deep4downscaling-%(version)s/deep4downscaling/* %(installdir)s/bin',
    'cp -r %(builddir)s/deep4downscaling-%(version)s/notebooks %(installdir)s',
]

sanity_check_paths = {
    'files': ['bin/viz.py'],
    'dirs': ['lib', 'include', 'bin/deep', 'notebooks'],
}

moduleclass = 'ai'
