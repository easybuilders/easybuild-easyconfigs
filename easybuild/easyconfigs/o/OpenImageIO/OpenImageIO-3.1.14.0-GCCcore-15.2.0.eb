easyblock = 'CMakeMake'

name = 'OpenImageIO'
version = '3.1.14.0'

homepage = 'https://openimageio.org/'
description = """OpenImageIO is a library for reading and writing images, and a bunch of related classes, utilities,
 and applications."""

toolchain = {'name': 'GCCcore', 'version': '15.2.0'}

source_urls = ['https://github.com/OpenImageIO/oiio/archive/refs/tags/']
sources = ['v%(version)s.tar.gz']
checksums = ['e6140dc6ffca92becbb1cc0ade2addb34a4b66df78f71cb9bc93380c0120e7de']

builddependencies = [
    ('CMake', '4.2.1'),
    ('git', '2.52.0'),
]
dependencies = [
    ('Boost', '1.90.0'),
    ('libjpeg-turbo', '3.1.4.1'),
    ('libpng', '1.6.56'),
    ('LibTIFF', '4.7.1'),
    ('OpenEXR', '3.4.12'),
    ('freetype', '2.14.3'),
    ('zlib', '2.3.2'),
]

configopts = '-DSTOP_ON_WARNING=OFF -DUSE_PYTHON=OFF'

sanity_check_paths = {
    'files': ['bin/oiiotool', f'lib/libOpenImageIO.{SHLIB_EXT}', f'lib/libOpenImageIO_Util.{SHLIB_EXT}'],
    'dirs': ['include/OpenImageIO', 'share'],
}

moduleclass = 'lib'
