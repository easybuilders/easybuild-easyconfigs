# Author:   Aayush Joglekar <aayush.joglekar@surf.nl>

easyblock = 'ConfigureMake'

name = 'OSU-Micro-Benchmarks'
version = '7.5'
_rocm_version = '6.4.1'

homepage = 'https://mvapich.cse.ohio-state.edu/benchmarks/'
description = """OSU Micro-Benchmarks"""

toolchain = {'name': 'rompi', 'version': '2025a'}
toolchainopts = {'usempi': True}

source_urls = ['https://mvapich.cse.ohio-state.edu/download/mvapich/']
sources = [SOURCELOWER_TAR_GZ]
checksums = ['1cf84ac5419456202757a757c5f9a4f5c6ecd05c65783c7976421cfd6020b3b3']

dependencies = [
    ('HIP', _rocm_version),
    ('RCCL', '2.22.3'),
]

configopts = '--enable-rocm --with-rocm=$EBROOTHIP '
configopts += '--enable-rcclomb --with-rccl=$EBROOTRCCL '

local_benchmark_dirs = [
    'libexec/osu-micro-benchmarks/mpi/%s' % x for x in ['collective', 'one-sided', 'pt2pt', 'startup']
] + [
    'libexec/osu-micro-benchmarks/xccl/%s' % x for x in ['collective', 'pt2pt']
]

modextrapaths = {'PATH': local_benchmark_dirs}

sanity_check_paths = {
    'files': [
        'libexec/osu-micro-benchmarks/mpi/pt2pt/osu_bw',
        'libexec/osu-micro-benchmarks/mpi/collective/osu_allreduce',
        'libexec/osu-micro-benchmarks/xccl/collective/osu_xccl_allreduce',
    ],
    'dirs': local_benchmark_dirs,
}

sanity_check_commands = [
    "osu_bw --help | grep -i rocm",
]

moduleclass = 'perf'
